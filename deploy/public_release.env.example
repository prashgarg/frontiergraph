# Copy this file to deploy/public_release.env and fill in your values.

PROJECT_ID=your-gcp-project-id
REGION=us-central1
SERVICE_NAME=frontiergraph-public
AR_REPOSITORY=frontiergraph
IMAGE_NAME=frontiergraph-app
IMAGE_TAG=

# Cloud Run sizing for the public release.
CPU=2
MEMORY=4Gi
TIMEOUT=300s
CONCURRENCY=4
MIN_INSTANCES=0
MAX_INSTANCES=3

# Recommended for the real economics corpus.
DATA_BUCKET=your-ranker-data-bucket
DB_FILENAME=frontiergraph-economics-public.db
DB_FILENAME_BROAD=frontiergraph-economics-broad-preview.db
CONCEPT_DB_FILENAME=
MOUNT_PATH=/mnt/ranker-data
VOLUME_NAME=ranker-data

# Optional: public mirror and branded Explorer route used by the Astro exports.
FRONTIERGRAPH_PUBLIC_DB_URL=
FRONTIERGRAPH_PUBLIC_APP_URL=https://frontiergraph.com/explorer/

# Optional: lightweight analytics + feedback for the Cloud Run app.
FRONTIERGRAPH_POSTHOG_KEY=
FRONTIERGRAPH_POSTHOG_HOST=https://eu.i.posthog.com
FRONTIERGRAPH_FEEDBACK_EMAIL=prashant.garg@imperial.ac.uk

# Cloudflare Pages uses its own environment settings.
# Set these there if you want page-level PostHog events and the site feedback modal:
# PUBLIC_POSTHOG_KEY=
# PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# PUBLIC_FEEDBACK_EMAIL=prashant.garg@imperial.ac.uk
