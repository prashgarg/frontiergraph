# Copy this file to deploy/public_beta.env and fill in your values.

PROJECT_ID=your-gcp-project-id
REGION=us-central1
SERVICE_NAME=economics-opportunity-ranker-beta
AR_REPOSITORY=economics-ranker
IMAGE_NAME=economics-opportunity-ranker
IMAGE_TAG=

# Cloud Run sizing for the first public beta.
CPU=2
MEMORY=4Gi
TIMEOUT=300s
CONCURRENCY=4
MIN_INSTANCES=0
MAX_INSTANCES=3

# Recommended for the real economics corpus.
DATA_BUCKET=your-ranker-data-bucket
DB_FILENAME=app_causalclaims.db
MOUNT_PATH=/mnt/ranker-data
VOLUME_NAME=ranker-data
