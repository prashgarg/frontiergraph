---
import BaseLayout from "../layouts/BaseLayout.astro";
import EditorialQuestionCarousel from "../components/EditorialQuestionCarousel.astro";
import { data } from "../lib/site-data";

const climatePattern =
  /\b(climate|carbon|co2|emissions?|pollution|environment(?:al)?|ecological|energy|oil|gas|electricity)\b/i;

const isClimateHeavy = (item: (typeof data.home.featured_questions)[number]) =>
  climatePattern.test(
    [item.public_pair_label, item.display_title, item.display_why, item.why_now, item.question_family]
      .filter(Boolean)
      .join(" "),
  );

const buildHomeCarouselPool = () => {
  const merged = Array.from(
    new Map(
      [...data.home.curated_questions, ...data.home.featured_questions].map((item) => [item.pair_key, item]),
    ).values(),
  );

  const prioritized = [
    ...merged.filter((item) => !isClimateHeavy(item)),
    ...merged.filter((item) => isClimateHeavy(item)),
  ];

  const selected: typeof merged = [];
  let climateCount = 0;

  for (const item of prioritized) {
    if (isClimateHeavy(item) && climateCount >= 1) continue;
    selected.push(item);
    if (isClimateHeavy(item)) climateCount += 1;
    if (selected.length >= 10) break;
  }

  if (selected.length < 8) {
    for (const item of prioritized) {
      if (selected.some((candidate) => candidate.pair_key === item.pair_key)) continue;
      selected.push(item);
      if (selected.length >= 8) break;
    }
  }

  return selected;
};

const homeCarouselPool = buildHomeCarouselPool();

const formatNumber = (value: number) => new Intl.NumberFormat("en-GB").format(value);
const scaleItems = [
  {
    label: "published-journal papers screened",
    value: formatNumber(data.metrics.papers),
  },
  {
    label: "papers in the normalized graph",
    value: formatNumber(data.metrics.normalized_graph_papers),
  },
  {
    label: "native concepts",
    value: formatNumber(data.metrics.native_concepts),
  },
];
---

<BaseLayout
  title="FrontierGraph"
  description="FrontierGraph is a public interface for browsing open questions in the economics literature."
>
  <main>
    <section class="hero hero-home">
      <div class="hero-panel hero-copy-panel hero-copy-panel-plain">
        <h1>Open economics questions, grounded in nearby evidence.</h1>
        <p class="lede">
          These questions sit close to existing topics, paths, and papers in the released graph, so you can start from something concrete instead of a blank page.
        </p>
        <div class="hero-actions">
          <a class="button-primary" href="/questions/">Browse questions</a>
          <a class="button-secondary" href={data.app_url}>Explore in app</a>
          <a class="button-tertiary" href="/paper/">Read paper</a>
          <a class="button-tertiary" href="/downloads/">Download data</a>
        </div>
      </div>
      <EditorialQuestionCarousel
        items={homeCarouselPool}
        title="A few concrete places to start"
        sectionId="home-editorial-carousel"
        variant="home"
        sampleSize={6}
      />
    </section>

    <section class="section">
      <div class="release-strip" data-role="homepage-scale-strip">
        <span class="tiny-label">Public release</span>
        <div class="hero-scale-metrics">
          {scaleItems.map((item) => (
            <div class="hero-scale-card">
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
