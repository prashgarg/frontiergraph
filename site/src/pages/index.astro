---
import BaseLayout from "../layouts/BaseLayout.astro";
import OpportunityCards from "../components/OpportunityCards.astro";
import { data, formatCompact, formatNumber, formatPercent, shortList } from "../lib/site-data";

const actions = [
  {
    href: "/graph/",
    title: "Explore the graph",
    copy: "Inspect the observed baseline concept network, expand local neighborhoods, and trace how ideas connect across the literature.",
  },
  {
    href: "/opportunities/",
    title: "See ranked opportunities",
    copy: "Open the suppressed baseline recommendation surface and inspect the strongest underexplored links the graph implies.",
  },
  {
    href: "/method/",
    title: "Read the method",
    copy: "Understand the corpus, extraction, ontology, ranking, and duplicate-cleanup logic without needing to read the raw protocols.",
  },
  {
    href: "/compare/",
    title: "Compare ontology views",
    copy: "See how Broad, Baseline, and Conservative regimes differ, and why Baseline exploratory is the default public view.",
  },
  {
    href: "/downloads/",
    title: "Download the artifacts",
    copy: "Get the code, data package, comparison summaries, and graph assets that power the public release.",
  },
];

const featuredConcepts = data.home.featured_central_concepts.slice(0, 6);
---

<BaseLayout
  title="FrontierGraph"
  description="A concept graph of economics with deterministic ranking for where the literature still looks incomplete."
>
  <main>
    <section class="hero hero-home">
      <div class="hero-panel hero-copy-panel">
        <span class="eyebrow">Concept graph of economics</span>
        <h1>A concept graph of economics, ranked for where to go next.</h1>
        <p class="lede">
          FrontierGraph extracts concept relationships from the literature, builds a concept-level map, and surfaces
          underexplored links worth investigating. The public default is <strong>{data.default_view.regime} {data.default_view.mapping}</strong>,
          with deterministic ranking and explicit duplicate cleanup on top of the recommendation surface.
        </p>
        <div class="hero-actions">
          <a class="button-primary" href={data.app_url}>Open the explorer</a>
          <a class="button-secondary" href="/graph/">Explore the graph</a>
          <a class="button-tertiary" href="/method/">Read the method</a>
        </div>
        <div class="hero-stat-strip">
          <div>
            <span class="tiny-label">Papers</span>
            <strong>{formatCompact(data.metrics.papers)}</strong>
          </div>
          <div>
            <span class="tiny-label">Concept heads</span>
            <strong>{formatNumber(data.metrics.baseline_head_concepts)}</strong>
          </div>
          <div>
            <span class="tiny-label">Exploratory coverage</span>
            <strong>{formatPercent(data.metrics.baseline_soft_coverage)}</strong>
          </div>
        </div>
      </div>

      <div class="hero-panel hero-visual-panel">
        <div class="graph-preview-card">
          <span class="eyebrow">Observed baseline graph</span>
          <h3>{formatNumber(data.home.graph_snapshot.nodes)} concepts · {formatNumber(data.home.graph_snapshot.edges)} backbone edges</h3>
          <p class="card-copy">
            The public graph viewer opens on a backbone view and expands local neighborhoods on click, so users see
            the real network rather than a marketing mock-up.
          </p>
          <div class="button-row">
            <a class="button-secondary" href="/graph/">Open graph viewer</a>
            <span class="field-pill">{data.default_view.regime} {data.default_view.mapping}</span>
          </div>
        </div>
        <div class="hero-snapshot-list">
          {featuredConcepts.slice(0, 3).map((concept) => (
            <article class="mini-snapshot-card">
              <strong>{concept.label}</strong>
              <div class="mini-copy">
                {formatNumber(concept.distinct_paper_support)} papers · degree {formatNumber(Math.round(concept.weighted_degree))}
              </div>
              <div class="mini-copy">{shortList(concept.top_countries)}</div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="metrics-grid metrics-grid-seven">
        <article class="metric-card">
          <div class="metric-value">{formatNumber(data.metrics.papers)}</div>
          <div class="metric-label">papers in the current public production corpus</div>
        </article>
        <article class="metric-card">
          <div class="metric-value">{formatNumber(data.metrics.node_instances)}</div>
          <div class="metric-label">extracted node instances across paper-local graphs</div>
        </article>
        <article class="metric-card">
          <div class="metric-value">{formatNumber(data.metrics.edges)}</div>
          <div class="metric-label">extracted concept relationships from titles and abstracts</div>
        </article>
        <article class="metric-card">
          <div class="metric-value">{formatNumber(data.metrics.baseline_head_concepts)}</div>
          <div class="metric-label">baseline head concepts in the default ontology view</div>
        </article>
        <article class="metric-card">
          <div class="metric-value">{formatPercent(data.metrics.baseline_soft_coverage)}</div>
          <div class="metric-label">baseline exploratory coverage of extracted node instances</div>
        </article>
        <article class="metric-card">
          <div class="metric-value">{formatNumber(data.metrics.suppressed_candidate_count)}</div>
          <div class="metric-label">suppressed top-slice candidate links available to browse</div>
        </article>
        <article class="metric-card">
          <div class="metric-value">{formatNumber(data.metrics.duplicate_loops_removed_top100)}</div>
          <div class="metric-label">near-duplicate top-100 loops removed by deterministic cleanup</div>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <div>
          <span class="eyebrow">What you can do</span>
          <h2>Use FrontierGraph at three depths</h2>
        </div>
        <p class="section-copy">
          Start from a simple graph and opportunity surface, then go deeper only if you want the ontology and ranking details.
        </p>
      </div>
      <div class="card-grid action-grid">
        {actions.map((action) => (
          <a class="card action-card" href={action.href}>
            <span class="eyebrow">Public surface</span>
            <h3>{action.title}</h3>
            <p class="card-copy">{action.copy}</p>
          </a>
        ))}
      </div>
    </section>

    <OpportunityCards
      items={data.home.featured_opportunities}
      title="Featured opportunities from the default surface"
      caption="These rows come from the baseline exploratory recommendation surface after deterministic duplicate suppression. They are the same kinds of opportunities shown in the app."
    />

    <section class="section">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Why trust it</span>
          <h2>Transparent before broad</h2>
        </div>
      </div>
      <div class="trust-grid">
        <article class="card">
          <h3>AI stops at extraction</h3>
          <p class="card-copy">
            AI converts paper text into local graph structure. Ranking, ontology comparison, and duplicate cleanup are deterministic and inspectable.
          </p>
        </article>
        <article class="card">
          <h3>Ontology sensitivity is visible</h3>
          <p class="card-copy">
            Broad, Baseline, and Conservative concept regimes remain available as advanced comparison views rather than being hidden behind one fixed choice.
          </p>
        </article>
        <article class="card">
          <h3>Recommendation cleanup is explicit</h3>
          <p class="card-copy">
            Near-synonym and same-family concept pairs are not silently collapsed. The app shows base score, duplicate penalty, and adjusted score.
          </p>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Central concepts</span>
          <h2>What the baseline graph revolves around</h2>
        </div>
        <a class="text-link" href="/graph/">Open the full graph viewer</a>
      </div>
      <div class="fields-grid concept-grid">
        {featuredConcepts.map((concept) => (
          <article class="field-card concept-card">
            <span class="eyebrow">{concept.bucket_hint}</span>
            <h3>{concept.label}</h3>
            <p class="card-copy">
              {formatNumber(concept.instance_support)} node instances · {formatNumber(concept.distinct_paper_support)} papers
            </p>
            <div class="button-row">
              <span class="field-pill">in {formatNumber(concept.in_degree)}</span>
              <span class="field-pill">out {formatNumber(concept.out_degree)}</span>
              <span class="field-pill">{shortList(concept.top_units, 2)}</span>
            </div>
            <div class="button-row">
              <a class="button-secondary" href={`/graph/?q=${encodeURIComponent(concept.label)}`}>See in graph</a>
              <a class="button-tertiary" href={concept.app_link}>Open in app</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="cta-band">
        <span class="eyebrow">Open release</span>
        <h2>Code, data, comparison summaries, and graph assets are part of the product.</h2>
        <p class="section-copy">
          FrontierGraph is designed to be inspected. The public release includes the repo, the current beta database,
          graph assets, central concept exports, and comparison summaries for the ontology regimes.
        </p>
        <div class="button-row">
          <a class="button-primary" href="/downloads/">Open downloads</a>
          <a class="button-secondary" href={data.repo_url}>View repository</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
