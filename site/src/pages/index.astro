---
import BaseLayout from "../layouts/BaseLayout.astro";
import CuratedOpportunityCards from "../components/CuratedOpportunityCards.astro";
import { data } from "../lib/site-data";

const audience = [
  "PhD students choosing topics",
  "Researchers looking for the next paper",
  "People moving into a nearby area",
];
---

<BaseLayout
  title="FrontierGraph"
  description="FrontierGraph helps academics find research questions worth pursuing."
>
  <main>
    <section class="hero hero-home hero-home-simple">
      <div class="hero-panel hero-copy-panel">
        <span class="eyebrow">For academics</span>
        <h1>Find research questions worth pursuing.</h1>
        <p class="lede">
          Academics do not just need to know what is popular. They need questions that still look open, but grounded
          enough to be worth reading, scoping, or testing next.
        </p>
        <p class="hero-note">The underlying question is simple: where do we go next?</p>
        <div class="hero-actions">
          <a class="button-primary" href="/questions/">Browse research questions</a>
          <a class="button-secondary" href={data.app_url}>Open workbench</a>
        </div>
      </div>
    </section>

    <section class="section">
      <article class="content-panel summary-panel">
        <span class="eyebrow">Why this exists</span>
        <h2>It is hard to tell whether a question is genuinely underworked, already crowded, or only superficially interesting.</h2>
        <p class="card-copy">
          FrontierGraph tries to surface research questions that still look underexplored relative to the surrounding literature,
          so a visitor can decide what is worth reading or testing next.
        </p>
      </article>
    </section>

    <section class="section">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Who it is for</span>
          <h2>Built for people choosing what to work on next.</h2>
        </div>
      </div>
      <div class="card-grid action-grid">
        {audience.map((label) => (
          <article class="card action-card audience-card">
            <h3>{label}</h3>
          </article>
        ))}
      </div>
    </section>

    <CuratedOpportunityCards
      items={data.home.curated_questions}
      title="A few places to start"
      caption="These three questions are hand-picked from the current public ranking. They are examples of the kind of question FrontierGraph is meant to help you notice quickly."
      sectionId="home-curated-questions"
      variant="home"
    />

    <section class="section">
      <div class="cta-band">
        <span class="eyebrow">Deeper evidence</span>
        <h2>If you want the deeper evidence, open the workbench.</h2>
        <div class="button-row">
          <a class="button-primary" href={data.app_url}>Open workbench</a>
          <a class="button-tertiary" href="/how-it-works/">How it works</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
