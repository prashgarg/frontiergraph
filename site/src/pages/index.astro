---
import BaseLayout from "../layouts/BaseLayout.astro";
import OpportunityCards from "../components/OpportunityCards.astro";
import { data, formatCompact, formatNumber, formatPercent, shortList } from "../lib/site-data";

const actions = [
  {
    href: "/graph/",
    title: "Start with the graph",
    copy: "Open the observed backbone first, then isolate one local neighborhood at a time.",
  },
  {
    href: "/opportunities/",
    title: "Open ranked links",
    copy: "Browse the cleaned Baseline exploratory surface instead of a raw score dump.",
  },
  {
    href: "/method/",
    title: "Check the method",
    copy: "Read the short protocol first. Open the deeper machinery only if you need it.",
  },
];

const featuredConcepts = data.home.featured_central_concepts.slice(0, 4);
---

<BaseLayout
  title="FrontierGraph"
  description="A concept graph of economics with deterministic ranking for where the literature still looks incomplete."
>
  <main>
    <section class="hero hero-home">
      <div class="hero-panel hero-copy-panel">
        <span class="eyebrow">Concept graph of economics</span>
        <h1>A graph of economics that points to what to study next.</h1>
        <p class="lede">
          FrontierGraph turns paper text into a reusable concept graph and ranks the links that still look underexplored.
          The public default is <strong>{data.default_view.regime} {data.default_view.mapping}</strong>.
        </p>
        <div class="hero-actions">
          <a class="button-primary" href="/graph/">Explore the graph</a>
          <a class="button-secondary" href="/opportunities/">See opportunities</a>
          <a class="button-tertiary" href={data.app_url}>Open deeper explorer</a>
        </div>
        <p class="hero-note">
          Broad and Conservative remain available as advanced comparison views. They do not lead the public product.
        </p>
        <div class="hero-stat-strip hero-stat-strip-compact">
          <div>
            <span class="tiny-label">Production corpus</span>
            <strong>{formatCompact(data.metrics.papers)}</strong>
          </div>
          <div>
            <span class="tiny-label">Default view</span>
            <strong>{data.default_view.regime} {data.default_view.mapping}</strong>
          </div>
          <div>
            <span class="tiny-label">Visible links</span>
            <strong>{formatNumber(data.metrics.suppressed_candidate_count)}</strong>
          </div>
        </div>
      </div>

      <div class="hero-panel hero-visual-panel">
        <div class="graph-preview-card">
          <span class="eyebrow">Graph-first public surface</span>
          <h3>Start on the observed backbone, not a control panel.</h3>
          <p class="card-copy">
            The graph page opens on a filtered public backbone, then narrows to one concept and its local neighborhood when you click.
          </p>
          <div class="pill-row">
            <span class="field-pill">{formatNumber(data.home.graph_snapshot.nodes)} concepts</span>
            <span class="field-pill">{formatNumber(data.home.graph_snapshot.edges)} backbone edges</span>
            <span class="field-pill">{formatPercent(data.metrics.baseline_soft_coverage)} exploratory coverage</span>
          </div>
          <div class="button-row">
            <a class="button-secondary" href="/graph/">Open graph viewer</a>
            <a class="button-tertiary" href="/compare/">Advanced compare</a>
          </div>
        </div>
        <div class="hero-snapshot-list hero-snapshot-list-wide">
          {featuredConcepts.map((concept) => (
            <a class="mini-snapshot-card" href={`/graph/?q=${encodeURIComponent(concept.label)}`}>
              <strong>{concept.label}</strong>
              <div class="mini-copy">
                {formatNumber(concept.distinct_paper_support)} papers · degree {formatNumber(Math.round(concept.weighted_degree))}
              </div>
              <div class="mini-copy">{shortList(concept.top_countries)}</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Use the product</span>
          <h2>Three clear entry points</h2>
        </div>
        <p class="section-copy">Start with the graph or the cleaned opportunity surface. Open comparison only when you want a sensitivity check.</p>
      </div>
      <div class="card-grid action-grid">
        {actions.map((action) => (
          <a class="card action-card" href={action.href}>
            <span class="eyebrow">Public surface</span>
            <h3>{action.title}</h3>
            <p class="card-copy">{action.copy}</p>
          </a>
        ))}
      </div>
    </section>

    <OpportunityCards
      items={data.home.featured_opportunities}
      title="A few opportunities from the default surface"
      caption="These examples come directly from the cleaned Baseline exploratory ranking surface used in the public app."
    />

    <section class="section">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Why not a chatbot</span>
          <h2>The product is a persistent map, not a one-off answer.</h2>
        </div>
      </div>
      <div class="trust-grid why-grid">
        <article class="card">
          <h3>Shared graph, not one prompt</h3>
          <p class="card-copy">FrontierGraph keeps a reusable map of concepts, neighborhoods, and bridges that can be inspected across sessions.</p>
        </article>
        <article class="card">
          <h3>Deterministic ranking, not just prose</h3>
          <p class="card-copy">AI extracts graph structure from text, but the ranking, ontology comparison, and cleanup layers are deterministic and inspectable.</p>
        </article>
        <article class="card">
          <h3>Advanced views stay visible</h3>
          <p class="card-copy">Baseline exploratory is the default, while Broad and Conservative stay available when you want to inspect ontology sensitivity.</p>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="cta-band">
        <span class="eyebrow">Open release</span>
        <h2>Use the graph first. Open the deeper app, method, or downloads only when you need them.</h2>
        <div class="button-row">
          <a class="button-primary" href={data.app_url}>Open deeper explorer</a>
          <a class="button-secondary" href="/downloads/">Open downloads</a>
          <a class="button-tertiary" href="/method/">Read the method</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
