---
import BaseLayout from "../layouts/BaseLayout.astro";
import { data } from "../lib/site-data";

const formatNumber = (value: number) => new Intl.NumberFormat("en-GB").format(value);
const scaleItems = [
  {
    label: "papers screened",
    value: formatNumber(data.metrics.papers),
    help: "Papers screened from the journal corpus before building the public release.",
  },
  {
    label: "journals covered",
    value: "300 journals",
    help: "Top 150 core economics journals plus Top 150 adjacent journals used to build the release.",
  },
  {
    label: "topic links",
    value: formatNumber(data.metrics.edges),
    help: "Directed topic-to-topic links extracted from papers and used to build the map.",
  },
  {
    label: "suggested questions",
    value: formatNumber(data.metrics.visible_public_questions),
    help: "Question suggestions currently exposed in the public browser after release filters.",
  },
];
---

<BaseLayout
  title="FrontierGraph"
  description="FrontierGraph is a public interface for browsing open questions in the economics literature."
>
  <main>
    <section class="hero hero-home">
      <div class="hero-panel hero-copy-panel hero-copy-panel-plain hero-copy-panel-home">
        <h1 class="hero-title-home">Organizing open questions in economics.</h1>
        <p class="lede">
          Browse question candidates suggested by short routes through nearby topics and papers.
        </p>
        <div class="hero-actions hero-actions-home">
          <a class="button-secondary" href="/questions/">Browse questions</a>
          <a class="button-secondary" href="/paper/">Working paper</a>
          <a class="button-tertiary" href="/downloads/">Download data</a>
          <a class="button-tertiary" href={data.app_url}>Open app for papers</a>
        </div>
        <p class="mini-copy">
          <a href="/paper/">The working paper explains the method behind the public browser.</a>
        </p>
      </div>
      <div class="hero-visual-panel home-hero-side hero-visual-panel-home">
        <div class="home-intro-grid home-intro-grid-hero">
        <article class="card home-intro-card">
          <span class="tiny-label">What</span>
          <ul class="home-intro-list">
            <li>The browser surfaces question candidates from nearby topics and papers.</li>
            <li>Each question stays tied to intermediate topics and starter papers.</li>
            <li>One short route helps explain why a question is worth inspecting.</li>
          </ul>
        </article>
        <article class="card home-intro-card">
          <span class="tiny-label">Why</span>
          <p class="card-copy">
            As it gets easier to produce more analysis, choosing where to look next matters more.
          </p>
          <p class="mini-copy">
            <a href="/about/">About the project</a>
          </p>
        </article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="release-strip" data-role="homepage-scale-strip">
        <span class="tiny-label">Public release</span>
        <div class="hero-scale-metrics">
          {scaleItems.map((item) => (
            <div class="hero-scale-card">
              <strong>{item.value}</strong>
              <div class="hero-scale-label-row">
                <span>{item.label}</span>
                <span class="info-tip">
                  <button class="info-tip-trigger" type="button" aria-label={`Explain ${item.label}`}>i</button>
                  <span class="info-tip-panel">{item.help}</span>
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="card graph-explainer-card">
        <div class="graph-explainer-copy">
          <span class="tiny-label">How to read the map</span>
          <h2>Start with one short path.</h2>
          <p class="card-copy">
            Start with one nearby chain of topics. It shows how one topic already leads into another in the surrounding literature and gives you a concrete way to read the map.
          </p>
          <ul class="home-intro-list graph-explainer-list">
            <li>Circles are topics.</li>
            <li>Arrows show one topic leading into another in nearby papers.</li>
            <li>One short path is often enough to see the mechanism linking two sides of a question.</li>
          </ul>
        </div>
        <div class="graph-explainer-visual" aria-hidden="true">
          <span class="tiny-label">Example path in the map</span>
          <svg class="graph-explainer-diagram" viewBox="0 0 440 156" role="presentation">
            <defs>
              <marker id="home-arrowhead" markerWidth="10" markerHeight="10" refX="8" refY="5" orient="auto">
                <path d="M0,0 L10,5 L0,10 z"></path>
              </marker>
            </defs>
            <line x1="100" y1="82" x2="202" y2="82" marker-end="url(#home-arrowhead)"></line>
            <line x1="274" y1="82" x2="364" y2="82" marker-end="url(#home-arrowhead)"></line>
            <text x="151" y="60">raises</text>
            <text x="319" y="60">feeds into</text>
            <circle cx="66" cy="82" r="22"></circle>
            <circle cx="238" cy="82" r="22"></circle>
            <circle cx="390" cy="82" r="22"></circle>
            <text x="66" y="116">
              <tspan x="66" dy="0">trade</tspan>
              <tspan x="66" dy="15">liberalisation</tspan>
            </text>
            <text x="238" y="116">
              <tspan x="238" dy="0">productivity</tspan>
              <tspan x="238" dy="15">growth</tspan>
            </text>
            <text x="390" y="116">
              <tspan x="390" dy="0">real</tspan>
              <tspan x="390" dy="15">wages</tspan>
            </text>
          </svg>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
