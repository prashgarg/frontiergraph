---
import BaseLayout from "../layouts/BaseLayout.astro";
import QuickConceptSearch from "../components/QuickConceptSearch.astro";
import OpportunityCards from "../components/OpportunityCards.astro";
import { data, formatCompact, formatNumber } from "../lib/site-data";

const actions = [
  {
    href: "/opportunities/",
    title: "Browse ranked opportunities",
    copy: "Start with the cleaned Baseline exploratory list and open one idea at a time.",
  },
  {
    href: "/graph/",
    title: "Read one neighborhood",
    copy: "Open the observed graph, focus one concept, and inspect the local structure in plain language.",
  },
  {
    href: "/method/",
    title: "Check the method later",
    copy: "Use the product first, then open the glossary and scoring details only if you need them.",
  },
];
---

<BaseLayout
  title="FrontierGraph"
  description="A concept graph of economics with deterministic ranking for where the literature still looks incomplete."
>
  <main>
    <section class="hero hero-home">
      <div class="hero-panel hero-copy-panel">
        <span class="eyebrow">Concept graph of economics</span>
        <h1>Find the next research link worth checking.</h1>
        <p class="lede">
          FrontierGraph turns paper text into a reusable concept graph and highlights links that still look incomplete.
          The public default is <strong>{data.default_view.regime} {data.default_view.mapping}</strong>, with complexity held back unless you ask for it.
        </p>
        <div class="hero-actions">
          <a class="button-primary" href="/opportunities/">Browse opportunities</a>
          <a class="button-secondary" href="/graph/">Open the graph</a>
          <a class="button-tertiary" href={data.app_url}>Open app</a>
        </div>
        <p class="hero-note">
          Broad and Conservative stay available as advanced comparison views, but they no longer lead the public path.
        </p>
        <div class="hero-stat-strip hero-stat-strip-compact">
          <div>
            <span class="tiny-label">Production corpus</span>
            <strong>{formatCompact(data.metrics.papers)}</strong>
          </div>
          <div>
            <span class="tiny-label">Default view</span>
            <strong>{data.default_view.regime} {data.default_view.mapping}</strong>
          </div>
          <div>
            <span class="tiny-label">Visible links</span>
            <strong>{formatNumber(data.metrics.suppressed_candidate_count)}</strong>
          </div>
        </div>
      </div>

      <div class="hero-panel hero-visual-panel">
        <QuickConceptSearch conceptIndexPath={data.graph.concept_index_path} appUrl={data.app_url} />
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <div>
          <span class="eyebrow">How to use it</span>
          <h2>One clear first path, plus two secondary ones</h2>
        </div>
        <p class="section-copy">Most people should start on Opportunities. Graph is for local reading. Method is for definitions and scoring terms.</p>
      </div>
      <div class="card-grid action-grid">
        {actions.map((action) => (
          <a class="card action-card" href={action.href}>
            <span class="eyebrow">Public surface</span>
            <h3>{action.title}</h3>
            <p class="card-copy">{action.copy}</p>
          </a>
        ))}
      </div>
    </section>

    <OpportunityCards
      items={data.home.featured_opportunities}
      title="A few examples from the default surface"
      caption="These examples come from the cleaned Baseline exploratory ranking surface, but they are described here in plain language rather than raw graph metrics."
    />

    <section class="section">
      <div class="section-heading">
        <div>
          <span class="eyebrow">What the product does</span>
          <h2>Lead with use, then let experts open the machinery.</h2>
        </div>
      </div>
      <div class="trust-grid why-grid">
        <article class="card">
          <h3>Search one concept</h3>
          <p class="card-copy">Start from a term you already know, then read its local graph and the nearby opportunity surface in one place.</p>
        </article>
        <article class="card">
          <h3>Open one opportunity</h3>
          <p class="card-copy">The public cards explain why a link is surfaced and what kind of follow-up it suggests before exposing raw graph terms.</p>
        </article>
        <article class="card">
          <h3>Check method only when needed</h3>
          <p class="card-copy">Baseline exploratory is the default. Compare and downloads remain available, but they now live under Advanced instead of the main path.</p>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="cta-band">
        <span class="eyebrow">Advanced surfaces</span>
        <h2>Use Opportunities or Graph first. Open comparison, downloads, or the heavier app only when your question needs them.</h2>
        <div class="button-row">
          <a class="button-primary" href="/advanced/">Open advanced pages</a>
          <a class="button-secondary" href={data.app_url}>Open app</a>
          <a class="button-tertiary" href="/method/">Read the method</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
