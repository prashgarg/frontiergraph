---
import BaseLayout from "../layouts/BaseLayout.astro";
import CuratedOpportunityCards from "../components/CuratedOpportunityCards.astro";
import { data } from "../lib/site-data";
---

<BaseLayout
  title="FrontierGraph"
  description="FrontierGraph helps academics find the next paper to work on."
>
  <main>
    <section class="hero hero-home hero-home-simple">
      <div class="hero-panel hero-copy-panel">
        <span class="eyebrow">For academics</span>
        <h1>Find the next paper to work on.</h1>
        <p class="lede">
          Popular topics are often crowded, while neglected ones are often vague or weak. FrontierGraph helps surface
          questions that still look open but already have enough nearby work to investigate seriously.
        </p>
        <div class="hero-actions">
          <a class="button-primary" href="/questions/">Browse research questions</a>
          <a class="button-secondary" href={data.app_url}>Inspect evidence</a>
        </div>
      </div>
    </section>

    <section class="section">
      <article class="content-panel summary-panel">
        <span class="eyebrow">Why this exists</span>
        <h2>Choosing a paper idea is harder than it should be.</h2>
        <p class="card-copy">
          The hard part is not finding topics. It is deciding which questions still look open, which ones are already
          crowded, and which ones only sound interesting at first glance.
        </p>
        <p class="mini-copy summary-note">
          Useful for PhD students choosing topics, researchers scoping the next paper, and people moving into a nearby field.
        </p>
      </article>
    </section>

    <CuratedOpportunityCards
      items={data.home.curated_questions}
      title="Three questions to start with"
      caption="These hand-picked examples show the kind of question FrontierGraph is meant to help you notice quickly."
      sectionId="home-curated-questions"
      variant="home"
    />

    <section class="section">
      <div class="cta-band">
        <span class="eyebrow">Deeper evidence</span>
        <h2>When a question looks promising, inspect the evidence.</h2>
        <div class="button-row">
          <a class="button-primary" href={data.app_url}>Inspect evidence</a>
          <a class="button-tertiary" href="/how-it-works/">How it works</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
