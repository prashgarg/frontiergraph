---
import BaseLayout from "../layouts/BaseLayout.astro";
import { data } from "../lib/site-data";

const formatNumber = (value: number) => new Intl.NumberFormat("en-GB").format(value);
const scaleItems = [
  {
    label: "published-journal papers screened",
    value: formatNumber(data.metrics.papers),
  },
  {
    label: "Top 150 core economics + Top 150 adjacent journals",
    value: "300 journals",
  },
  {
    label: "extracted relationships",
    value: formatNumber(data.metrics.edges),
  },
  {
    label: "question candidates in the public release",
    value: formatNumber(data.metrics.visible_public_questions),
  },
];
---

<BaseLayout
  title="FrontierGraph"
  description="FrontierGraph is a public interface for browsing open questions in the economics literature."
>
  <main>
    <section class="hero hero-home">
      <div class="hero-panel hero-copy-panel hero-copy-panel-plain hero-copy-panel-home">
        <h1>Organizing open questions in economics.</h1>
        <p class="lede">
          Browse questions that sit near existing topics, paths, and papers in the released economics map.
        </p>
        <div class="hero-actions hero-actions-home">
          <a class="button-primary" href="/questions/">Browse questions</a>
          <a class="button-secondary" href="/paper/">Read paper</a>
          <a class="button-tertiary" href="/downloads/">Download data</a>
          <a class="button-tertiary" href={data.app_url}>Explore in app</a>
        </div>
      </div>
      <div class="hero-visual-panel home-hero-side hero-visual-panel-home">
        <div class="home-intro-grid home-intro-grid-hero">
        <article class="card home-intro-card">
          <span class="tiny-label">What</span>
          <ul class="home-intro-list">
            <li>Built from a published-journal economics corpus.</li>
            <li>Organized as a public set of browsable question candidates.</li>
            <li>Each question stays tied to nearby topics, paths, and papers.</li>
          </ul>
        </article>
        <article class="card home-intro-card">
          <span class="tiny-label">Why</span>
          <p class="card-copy">
            As it gets easier to produce more analysis, choosing where to look next matters more.
          </p>
          <p class="mini-copy">
            <a href="/about/">About the project</a>
          </p>
        </article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="release-strip" data-role="homepage-scale-strip">
        <span class="tiny-label">Public release</span>
        <div class="hero-scale-metrics">
          {scaleItems.map((item) => (
            <div class="hero-scale-card">
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="card graph-explainer-card">
        <div class="graph-explainer-copy">
          <span class="tiny-label">How to read the map</span>
          <h2>Each arrow is a directed relation already present in papers.</h2>
          <p class="card-copy">
            FrontierGraph is easier to read when you start with one short path. The point is not abstract graph theory. It is seeing how one topic already leads into another through the literature around it.
          </p>
          <ul class="home-intro-list graph-explainer-list">
            <li>Circles are topics.</li>
            <li>Arrows are directed relations already stated or studied in papers.</li>
            <li>Short paths help explain why nearby questions are plausible enough to inspect.</li>
          </ul>
        </div>
        <div class="graph-explainer-visual" aria-hidden="true">
          <span class="tiny-label">Example path in the map</span>
          <svg class="graph-explainer-diagram" viewBox="0 0 420 150" role="presentation">
            <defs>
              <marker id="home-arrowhead" markerWidth="10" markerHeight="10" refX="8" refY="5" orient="auto">
                <path d="M0,0 L10,5 L0,10 z"></path>
              </marker>
            </defs>
            <line x1="98" y1="82" x2="208" y2="82" marker-end="url(#home-arrowhead)"></line>
            <line x1="278" y1="82" x2="388" y2="82" marker-end="url(#home-arrowhead)"></line>
            <text x="153" y="62">raises</text>
            <text x="333" y="62">feeds into</text>
            <circle cx="64" cy="82" r="22"></circle>
            <circle cx="244" cy="82" r="22"></circle>
            <circle cx="404" cy="82" r="22"></circle>
            <text x="64" y="114">
              <tspan x="64" dy="0">trade</tspan>
              <tspan x="64" dy="15">liberalisation</tspan>
            </text>
            <text x="244" y="114">
              <tspan x="244" dy="0">productivity</tspan>
              <tspan x="244" dy="15">growth</tspan>
            </text>
            <text x="404" y="122">real wages</text>
          </svg>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
