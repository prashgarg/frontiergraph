---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomepageQuestionCarousel from "../components/HomepageQuestionCarousel.astro";
import { homepageCarouselSlides } from "../content/homepage-carousel";
import { data } from "../lib/site-data";

const lookup = new Map();
for (const item of data.home.curated_questions) lookup.set(item.pair_key, item);
for (const item of data.questions.curated_front_set) lookup.set(item.pair_key, item);
for (const group of data.questions.field_shelves) {
  for (const item of group.items) lookup.set(item.pair_key, item);
}
for (const group of data.questions.collections) {
  for (const item of group.items) lookup.set(item.pair_key, item);
}

const carouselSlides = homepageCarouselSlides.flatMap((slide) => {
  const match = slide.pairKey ? lookup.get(slide.pairKey) : null;
  if (slide.pairKey && !match && !slide.primaryHref) return [];
  return [
    {
      ...slide,
      primaryHref: slide.primaryHref ?? (slide.pairKey ? `/questions/#${slide.pairKey}` : "/paper/full/"),
      primaryLabel: slide.primaryLabel ?? (slide.pairKey ? "See question" : "Read paper"),
      secondaryHref: slide.secondaryHref ?? match?.app_link ?? data.app_url,
      secondaryLabel: slide.secondaryLabel ?? "Open app",
    },
  ];
});

const formatNumber = (value: number) => new Intl.NumberFormat("en-GB").format(value);
const scaleItems = [
  {
    label: "published-journal papers screened",
    value: formatNumber(data.metrics.papers),
  },
  {
    label: "papers in the normalized graph",
    value: formatNumber(data.metrics.normalized_graph_papers),
  },
  {
    label: "native concepts",
    value: formatNumber(data.metrics.native_concepts),
  },
];
---

<BaseLayout
  title="FrontierGraph"
  description="FrontierGraph is a public interface for browsing open research questions in economics."
>
  <main>
    <section class="hero hero-home">
      <div class="hero-panel hero-copy-panel">
        <h1>Browse open questions in the economics literature.</h1>
        <p class="lede">
          FrontierGraph organizes candidate questions from a large published-journal corpus and lets you inspect the nearby literature behind each one.
        </p>
        <div class="hero-actions">
          <a class="button-primary" href="/questions/">Browse questions</a>
          <a class="button-secondary" href={data.app_url}>Open app</a>
          <a class="button-tertiary" href="/paper/">Read paper</a>
          <a class="button-tertiary" href="/downloads/">Download data</a>
        </div>
      </div>
      <HomepageQuestionCarousel slides={carouselSlides} compact={true} />
    </section>

    <section class="section">
      <div class="release-strip" data-role="homepage-scale-strip">
        <span class="tiny-label">Public release</span>
        <div class="hero-scale-metrics">
          {scaleItems.map((item) => (
            <div class="hero-scale-card">
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
