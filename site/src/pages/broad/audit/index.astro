---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import audit from "../../../generated/regime-audit.json";
const payload = audit as {
  summary: {
    current_topics: number;
    broad_topics: number;
    current_visible_questions: number;
    broad_visible_questions: number;
    top80_overlap_after_mirror_dedupe: number;
    current_top: Record<string, number>;
    broad_top: Record<string, number>;
  };
  current_top_questions: Array<Record<string, string | number>>;
  broad_top_questions: Array<Record<string, string | number>>;
  broad_only_examples: Array<Record<string, string | number>>;
  current_only_examples: Array<Record<string, string | number>>;
  comparison_note?: string;
};

const broadLinks = [
  { href: "/broad/", label: "Home" },
  { href: "/broad/questions/", label: "Questions" },
  { href: "/broad/graph/", label: "Explorer" },
  { href: "/broad/audit/", label: "Audit" },
  { href: "/paper/", label: "Paper" },
];

const fmt = (value: number) => new Intl.NumberFormat("en-GB").format(value);
---

<BaseLayout
  title="Broad Preview Audit | FrontierGraph"
  description="Side-by-side audit of the current FrontierGraph release and the broader 16.5k-topic preview."
  navPrefix="/broad"
  variantLabel="Broad preview"
  links={broadLinks}
>
  <main>
    <section class="page-hero">
      <h1>Side-by-side regime audit.</h1>
      <p class="lede">
        This page helps us inspect whether the broader 16.5k-topic regime gives more specific, more useful public questions than the current release before we change the main site or rerun the paper.
      </p>
    </section>

    <section class="section">
      <div class="metrics-grid">
        <article class="metric-card">
          <div class="metric-value">{fmt(payload.summary.current_topics)}</div>
          <div class="metric-label">topics in the current release</div>
        </article>
        <article class="metric-card">
          <div class="metric-value">{fmt(payload.summary.broad_topics)}</div>
          <div class="metric-label">topics in the broad preview</div>
        </article>
        <article class="metric-card">
          <div class="metric-value">{fmt(payload.summary.current_visible_questions)}</div>
          <div class="metric-label">questions in the current release surface</div>
        </article>
        <article class="metric-card">
          <div class="metric-value">{fmt(payload.summary.broad_visible_questions)}</div>
          <div class="metric-label">questions in the broad preview surface</div>
        </article>
        <article class="metric-card">
          <div class="metric-value">{fmt(payload.summary.top80_overlap_after_mirror_dedupe)}</div>
          <div class="metric-label">top-80 overlap after mirror dedupe</div>
        </article>
      </div>
    </section>

    {payload.comparison_note && (
      <section class="section">
        <article class="card">
          <p class="section-copy">{payload.comparison_note}</p>
        </article>
      </section>
    )}

    <section class="section">
      <div class="editorial-carousel-grid editorial-carousel-grid-use-cases">
        <article class="card">
          <span class="tiny-label">Current release</span>
          <h2>Top questions</h2>
          <ul class="home-intro-list">
            {payload.current_top_questions.slice(0, 12).map((row) => (
              <li>{String(row.question)}</li>
            ))}
          </ul>
        </article>
        <article class="card">
          <span class="tiny-label">Broad preview</span>
          <h2>Top questions</h2>
          <ul class="home-intro-list">
            {payload.broad_top_questions.slice(0, 12).map((row) => (
              <li>{String(row.question)}</li>
            ))}
          </ul>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="editorial-carousel-grid editorial-carousel-grid-use-cases">
        <article class="card">
          <span class="tiny-label">Broad-only examples</span>
          <h2>What appears only in the broad top window</h2>
          <ul class="home-intro-list">
            {payload.broad_only_examples.slice(0, 12).map((row) => (
              <li>{String(row.question)}</li>
            ))}
          </ul>
        </article>
        <article class="card">
          <span class="tiny-label">Current-release-only examples</span>
          <h2>What disappears from the broad preview surface</h2>
          <ul class="home-intro-list">
            {payload.current_only_examples.slice(0, 12).map((row) => (
              <li>{String(row.question)}</li>
            ))}
          </ul>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
