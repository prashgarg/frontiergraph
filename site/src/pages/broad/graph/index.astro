---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import GraphWorkbench from "../../../components/GraphWorkbench.astro";
import { data } from "../../../lib/site-data-broad";

const broadLinks = [
  { href: "/broad/", label: "Home" },
  { href: "/broad/questions/", label: "Questions" },
  { href: "/broad/graph/", label: "Graph" },
  { href: "/broad/audit/", label: "Audit" },
  { href: "/paper/", label: "Paper" },
];
---

<BaseLayout
  title="Broad Preview Graph | FrontierGraph"
  description="Choose a topic and inspect the broader 16.5k-topic graph preview."
  navPrefix="/broad"
  appUrl={data.app_url}
  appLabel="Broad app preview"
  variantLabel="Broad preview"
  links={broadLinks}
  shellClass="site-shell"
>
  <main>
    <GraphWorkbench
      graphPath={data.graph.backbone_path}
      conceptIndexPath={data.graph.concept_index_path}
    neighborhoodsIndexPath={data.graph.concept_neighborhoods_index_path}
    opportunitiesIndexPath={data.graph.concept_opportunities_index_path}
    centralConceptsPath={data.graph.central_concepts_path}
    contextLabel="broad preview"
  />
  </main>
</BaseLayout>
