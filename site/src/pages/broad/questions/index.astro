---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import EditorialQuestionCarousel from "../../../components/EditorialQuestionCarousel.astro";
import OpportunityCards from "../../../components/OpportunityCards.astro";
import { data } from "../../../lib/site-data-broad";

const questions = data.questions.ranked_questions;
const broadLinks = [
  { href: "/broad/", label: "Home" },
  { href: "/broad/questions/", label: "Questions" },
  { href: "/broad/graph/", label: "Graph" },
  { href: "/broad/audit/", label: "Audit" },
  { href: "/paper/", label: "Paper" },
];
---

<BaseLayout
  title="Broad Preview Questions | FrontierGraph"
  description="Browse question candidates from the broader 16.5k-topic FrontierGraph preview."
  navPrefix="/broad"
  variantLabel="Broad preview"
  links={broadLinks}
>
  <main>
    <section class="page-hero">
      <h1>Browse questions from the broad preview.</h1>
      <p class="lede">
        This surface uses the broader 16.5k-topic regime directly, so the wording and the candidate set can move noticeably away from the current release.
      </p>
    </section>

    <section class="section">
      <div class="editorial-carousel-grid editorial-carousel-grid-fields">
        {data.questions.field_carousels.map((group, index) => (
          <div id={group.slug}>
            <EditorialQuestionCarousel
              items={group.items}
              title={group.title}
              caption={group.caption}
              groupLabel="Field"
              sectionId={`broad-field-carousel-${group.slug}`}
              initialDelayMs={index * 700}
            />
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="editorial-carousel-grid editorial-carousel-grid-use-cases">
        {data.questions.use_case_carousels.map((group, index) => (
          <EditorialQuestionCarousel
            items={group.items}
            title={group.title}
            caption={group.caption}
            groupLabel="Use case"
            sectionId={`broad-use-case-carousel-${group.slug}`}
            initialDelayMs={(index + data.questions.field_carousels.length) * 700}
          />
        ))}
      </div>
    </section>

    <OpportunityCards
      items={questions}
      title="Search the wider broad preview"
      caption="Use the filters when you want to inspect how the broader regime changes the default surface."
      sectionId="broad-overall-ranked-questions"
      enableFilters={true}
      initialVisibleCount={18}
    />
  </main>
</BaseLayout>
