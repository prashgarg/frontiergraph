---
import BaseLayout from "../../../layouts/BaseLayout.astro";
const broadLinks = [
  { href: "/broad/", label: "Home" },
  { href: "/broad/questions/", label: "Questions" },
  { href: "/broad/graph/", label: "Explorer" },
  { href: "/broad/audit/", label: "Audit" },
  { href: "/paper/", label: "Paper" },
];
---

<BaseLayout
  title="Broad Preview Paper Status | FrontierGraph"
  description="Status page for the paper-side implications of the broad preview."
  navPrefix="/broad"
  variantLabel="Broad preview"
  links={broadLinks}
>
  <main>
    <section class="page-hero">
      <h1>Broad preview is being evaluated outside the current paper.</h1>
      <p class="lede">
        The 12 April 2026 paper remains the current reference version. This broad preview is a separate local check of whether the finer 16.5k-topic regime yields sharper, more useful questions before any rerun of the benchmark or manuscript.
      </p>
      <div class="button-row">
        <a class="button-primary" href="/paper/">Open current paper</a>
        <a class="button-secondary" href="/broad/audit/">Open broad preview audit</a>
        <a class="button-tertiary" href="/broad/questions/">Browse broad questions first</a>
      </div>
    </section>
  </main>
</BaseLayout>
