---
import BaseLayout from "../../../layouts/BaseLayout.astro";
const broadLinks = [
  { href: "/broad/", label: "Home" },
  { href: "/broad/questions/", label: "Questions" },
  { href: "/broad/graph/", label: "Graph" },
  { href: "/broad/audit/", label: "Audit" },
  { href: "/paper/", label: "Paper" },
];
---

<BaseLayout
  title="Broad Preview Paper Status | FrontierGraph"
  description="Status page for the paper-side implications of the broad preview."
  navPrefix="/broad"
  variantLabel="Broad preview"
  links={broadLinks}
>
  <main>
    <section class="page-hero">
      <h1>Paper rerun is pending the broad preview decision.</h1>
      <p class="lede">
        The current working paper still reflects the baseline release. We are using this broad preview to inspect whether the finer 16.5k-topic regime produces sharper, more useful questions before rerunning the benchmark and the paper results.
      </p>
      <div class="button-row">
        <a class="button-primary" href="/paper/">Open current working paper</a>
        <a class="button-secondary" href="/broad/audit/">Open broad preview audit</a>
        <a class="button-tertiary" href="/broad/questions/">Browse broad questions first</a>
      </div>
    </section>
  </main>
</BaseLayout>
