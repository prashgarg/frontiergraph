---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GraphWorkbench from "../../components/GraphWorkbench.astro";
import { data, formatNumber } from "../../lib/site-data";

const defaultRegime = `${data.default_view.regime} ${data.default_view.mapping}`;
---

<BaseLayout
  title="Graph | FrontierGraph"
  description="Explore the observed baseline concept graph of the economics literature."
>
  <main>
    <section class="page-hero">
      <span class="eyebrow">Graph</span>
      <h1>Read one part of the literature at a time.</h1>
      <p class="lede">
        The public graph opens in one focused neighborhood by default. Search or click a concept, read the local structure beside the canvas, and only switch to the full map when you want wider orientation across the public backbone.
      </p>
      <div class="button-row">
        <span class="field-pill">Default: {defaultRegime}</span>
        <span class="field-pill">{formatNumber(data.home.graph_snapshot.nodes)} concepts available in the public map</span>
        <a class="button-secondary" href="/opportunities/">See ranked opportunities</a>
        <a class="button-tertiary" href={data.app_url}>Open deeper explorer</a>
      </div>
    </section>

    <GraphWorkbench
      graphPath={data.graph.backbone_path}
      conceptIndexPath={data.graph.concept_index_path}
      neighborhoodsIndexPath={data.graph.concept_neighborhoods_index_path}
      opportunitiesIndexPath={data.graph.concept_opportunities_index_path}
      centralConceptsPath={data.graph.central_concepts_path}
    />
  </main>
</BaseLayout>
