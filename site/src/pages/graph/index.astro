---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GraphWorkbench from "../../components/GraphWorkbench.astro";
import { data } from "../../lib/site-data";
---

<BaseLayout
  title="Map | FrontierGraph"
  description="Read one topic through the FrontierGraph literature map."
  shellClass="site-shell site-shell-wide"
>
  <main>
    <section class="page-hero">
      <h1>Use the map when you already have a topic in mind.</h1>
      <p class="lede">
        Read the nearby literature first, then open the app when you want deeper evidence around one topic or question.
      </p>
      <div class="button-row">
        <a class="button-secondary" href="/questions/">Browse questions</a>
        <a class="button-tertiary" href={data.app_url}>Explore in app</a>
      </div>
    </section>

    <GraphWorkbench
      graphPath={data.graph.backbone_path}
      conceptIndexPath={data.graph.concept_index_path}
      neighborhoodsIndexPath={data.graph.concept_neighborhoods_index_path}
      opportunitiesIndexPath={data.graph.concept_opportunities_index_path}
      centralConceptsPath={data.graph.central_concepts_path}
    />
  </main>
</BaseLayout>
