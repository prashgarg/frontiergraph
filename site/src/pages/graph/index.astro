---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GraphWorkbench from "../../components/GraphWorkbench.astro";
import { data } from "../../lib/site-data";
---

<BaseLayout
  title="Graph | FrontierGraph"
  description="Choose a topic and start with the questions around it."
  shellClass="site-shell site-shell-wide"
>
  <main>
    <section class="page-hero">
      <h1>Choose a topic and start with the questions around it.</h1>
      <p class="lede">
        Start with one topic, see the questions touching it, and use the graph only as nearby context.
      </p>
    </section>

    <GraphWorkbench
      graphPath={data.graph.backbone_path}
      conceptIndexPath={data.graph.concept_index_path}
      neighborhoodsIndexPath={data.graph.concept_neighborhoods_index_path}
      opportunitiesIndexPath={data.graph.concept_opportunities_index_path}
      centralConceptsPath={data.graph.central_concepts_path}
    />
  </main>
</BaseLayout>
