---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GraphWorkbench from "../../components/GraphWorkbench.astro";
import { data } from "../../lib/site-data";
---

<BaseLayout
  title="Literature Map | FrontierGraph"
  description="Read one topic through the FrontierGraph literature map."
>
  <main>
    <section class="page-hero">
      <span class="eyebrow">Literature map</span>
      <h1>Use the literature map when you want to read one topic in more detail.</h1>
      <p class="lede">
        Most visitors should start with Research Questions. This page is for people who already have a topic in mind and want a slower, text-first way to inspect related ideas and nearby research before opening the full map.
      </p>
      <div class="button-row">
        <a class="button-secondary" href="/questions/">Browse research questions</a>
        <a class="button-tertiary" href="/how-it-works/">How it works</a>
        <a class="button-tertiary" href="/downloads/">Downloads</a>
      </div>
    </section>

    <GraphWorkbench
      graphPath={data.graph.backbone_path}
      conceptIndexPath={data.graph.concept_index_path}
      neighborhoodsIndexPath={data.graph.concept_neighborhoods_index_path}
      opportunitiesIndexPath={data.graph.concept_opportunities_index_path}
      centralConceptsPath={data.graph.central_concepts_path}
    />
  </main>
</BaseLayout>
