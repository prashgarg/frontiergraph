---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MechanismEditorialCarousel from "../../components/MechanismEditorialCarousel.astro";
import MechanismQuestionCards from "../../components/MechanismQuestionCards.astro";
import { data } from "../../lib/site-data";
import mechanismEditorialSource from "../../content/mechanism-editorial-opportunities.json";
import mechanismCarouselGroupsSource from "../../content/mechanism-carousel-groups.json";
import mechanismArchiveSource from "../../content/mechanism-archive-generated.json";

const mechanismCurated = Object.values((data.questions?.mechanism_curated_set ?? mechanismEditorialSource) as Record<string, any>);
const mechanismByKey = new Map(mechanismCurated.map((item) => [item.pair_key, item]));
const mechanismGroups = mechanismCarouselGroupsSource as {
  front: { title: string; caption: string; items: string[] };
  field_shelves: { slug: string; title: string; caption: string; items: string[] }[];
  use_case_shelves: { slug: string; title: string; caption: string; items: string[] }[];
};

function buildMechanismGroup(group) {
  return {
    ...group,
    items: group.items.map((pairKey) => mechanismByKey.get(pairKey)).filter(Boolean),
  };
}

const mechanismFront = buildMechanismGroup(mechanismGroups.front);
const fieldShelves = mechanismGroups.field_shelves.map(buildMechanismGroup).filter((group) => group.items.length > 0);
const useCaseShelves = mechanismGroups.use_case_shelves.map(buildMechanismGroup).filter((group) => group.items.length > 0);
const shelfBySlug = new Map([...fieldShelves, ...useCaseShelves].map((group) => [group.slug, group]));
const mechanismGrid = [
  mechanismFront,
  shelfBySlug.get("innovation-productivity-mechanisms"),
  shelfBySlug.get("macro-finance-mechanisms"),
  shelfBySlug.get("labor-household-mechanisms"),
  shelfBySlug.get("climate-energy-mechanisms"),
  shelfBySlug.get("longer-horizon-project-ideas"),
].filter(Boolean);
const mechanismArchive = Object.values(mechanismArchiveSource);
---

<BaseLayout
  title="Questions | FrontierGraph"
  description="Start with a tighter mechanism front stack, then browse mechanism shelves by field and project type before dropping into the larger public archive."
>
  <main>
    <section class="page-hero">
      <h1>Curated research questions.</h1>
      <p class="lede">
        Start with a tighter front stack of mechanism questions, then browse smaller mechanism shelves by field and project type. The larger archive below is there when you want the broader public release set rather than the tighter editorial pass.
      </p>
    </section>

    <section class="section">
      <div class="editorial-carousel-grid editorial-carousel-grid-fields">
        {mechanismGrid.map((group, index) => (
          <div id={index === 0 ? "mechanism-front-carousel" : group.slug}>
            <MechanismEditorialCarousel
              items={group.items}
              title={group.title}
              caption={group.caption}
              groupLabel={index === 0 ? "Mechanism" : index === 5 ? "Use case" : "Field"}
              sectionId={index === 0 ? "mechanism-front-carousel" : index === 5 ? `use-case-carousel-${group.slug}` : `field-carousel-${group.slug}`}
            />
          </div>
        ))}
      </div>
    </section>

    <MechanismQuestionCards
      items={mechanismArchive}
      title="Broader mechanism archive"
      caption="This archive is drawn from the wider new mechanism pass, not the older public direct-link set."
      sectionId="overall-ranked-questions"
    />
  </main>
</BaseLayout>

<script is:inline>
  const focusQuestionFromHash = () => {
    const hash = window.location.hash;
    if (!hash || hash.length <= 1) return;
    const target = document.getElementById(hash.slice(1));
    if (!(target instanceof HTMLElement)) return;
    for (const card of document.querySelectorAll(".opportunity-card.is-targeted")) {
      card.classList.remove("is-targeted");
    }
    target.classList.add("is-targeted");
    const evidence = target.querySelector("[data-role='opportunity-evidence']");
    if (evidence instanceof HTMLDetailsElement) {
      evidence.open = true;
    }
  };

  window.addEventListener("hashchange", focusQuestionFromHash);
  window.addEventListener("load", focusQuestionFromHash);
</script>
