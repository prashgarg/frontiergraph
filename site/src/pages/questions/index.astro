---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CuratedOpportunityCards from "../../components/CuratedOpportunityCards.astro";
import OpportunityCards from "../../components/OpportunityCards.astro";
import { data } from "../../lib/site-data";

const questions = data.questions.ranked_questions;
---

<BaseLayout
  title="Research Questions | FrontierGraph"
  description="Browse questions that could become your next paper."
>
  <main>
    <section class="page-hero">
      <span class="eyebrow">Research Questions</span>
      <h1>Browse questions that could become your next paper.</h1>
      <p class="lede">
        These are starting points, not verdicts. Use them to decide what looks worth reading, scoping, or testing next.
      </p>
      <div class="button-row">
        <a class="button-secondary" href={data.app_url}>Inspect evidence</a>
        <a class="button-tertiary" href="/how-it-works/">How it works</a>
      </div>
    </section>

    <CuratedOpportunityCards
      items={data.questions.curated_front_set}
      title="Start here"
      caption="These six questions are manually curated from the current public ranking. Use them as starting points, not as verdicts."
      sectionId="questions-curated-front-set"
      variant="questions"
    />

    <section class="section">
      <div class="section-heading">
        <div>
          <span class="eyebrow">By field</span>
          <h2>Browse by field</h2>
        </div>
        <p class="section-copy">
          These shelves are hand-curated for people who already know the part of economics they want to work in.
        </p>
      </div>
      <div class="editorial-group-stack">
        {data.questions.field_shelves.map((group) => (
          <CuratedOpportunityCards
            items={group.items}
            title={group.title}
            caption={group.caption}
            sectionId={`field-shelf-${group.slug}`}
            standalone={false}
            variant="compact"
          />
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Collections</span>
          <h2>Browse by use case</h2>
        </div>
        <p class="section-copy">
          These smaller collections are meant to answer the question a researcher usually has in practice, not to expose raw ranking slices.
        </p>
      </div>
      <div class="editorial-group-stack">
        {data.questions.collections.map((group) => (
          <CuratedOpportunityCards
            items={group.items}
            title={group.title}
            caption={group.caption}
            sectionId={`question-collection-${group.slug}`}
            standalone={false}
            variant="compact"
          />
        ))}
      </div>
    </section>

    <OpportunityCards
      items={questions}
      title="Broader ranked list"
      caption="Below the curated sections, the ranked list stays available as a secondary browse layer. Use it when you want more ideas after the editorial pass."
      sectionId="overall-ranked-questions"
      enableFilters={true}
    />

    <section class="section">
      <article class="content-panel summary-panel">
        <span class="eyebrow">Before you trust a question</span>
        <h2>Check what the evidence shown here means, and what it does not mean, before you decide a question is truly open.</h2>
        <div class="button-row">
          <a class="button-secondary" href="/how-it-works/">Open How It Works</a>
          <a class="button-tertiary" href="/method/">Open Method</a>
          <a class="button-tertiary" href={data.app_url}>Inspect evidence</a>
        </div>
      </article>
    </section>
  </main>
</BaseLayout>
