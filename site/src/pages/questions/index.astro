---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CuratedOpportunityCards from "../../components/CuratedOpportunityCards.astro";
import OpportunityCards from "../../components/OpportunityCards.astro";
import { data } from "../../lib/site-data";

const questions = data.questions.top_slices.overall;
---

<BaseLayout
  title="Research Questions | FrontierGraph"
  description="Browse questions that could become your next paper."
>
  <main>
    <section class="page-hero">
      <span class="eyebrow">Research Questions</span>
      <h1>Browse questions that could become your next paper.</h1>
      <p class="lede">
        These are starting points, not verdicts. Use them to decide what looks worth reading, scoping, or testing next.
      </p>
      <div class="button-row">
        <a class="button-secondary" href={data.app_url}>Inspect evidence</a>
        <a class="button-tertiary" href="/how-it-works/">How it works</a>
      </div>
    </section>

    <CuratedOpportunityCards
      items={data.questions.curated_front_set}
      title="Start here"
      caption="These six questions are manually curated from the current public ranking. Use them as starting points, not as verdicts."
      sectionId="questions-curated-front-set"
      variant="questions"
    />

    <OpportunityCards
      items={questions}
      title="Full ranked list"
      caption="Below the curated set, the broader ranked list stays available as structured evidence. Search by topic, filter for the kind of question you want, and inspect the evidence when you want a deeper pass."
      sectionId="overall-ranked-questions"
      enableFilters={true}
    />

    <section class="section">
      <article class="content-panel summary-panel">
        <span class="eyebrow">Before you trust a question</span>
        <h2>Check what the evidence shown here means, and what it does not mean, before you decide a question is truly open.</h2>
        <div class="button-row">
          <a class="button-secondary" href="/how-it-works/">Open How It Works</a>
          <a class="button-tertiary" href="/method/">Open Method</a>
          <a class="button-tertiary" href={data.app_url}>Inspect evidence</a>
        </div>
      </article>
    </section>
  </main>
</BaseLayout>
