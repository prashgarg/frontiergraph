---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EditorialQuestionCarousel from "../../components/EditorialQuestionCarousel.astro";
import OpportunityCards from "../../components/OpportunityCards.astro";
import { data } from "../../lib/site-data";

const questions = data.questions.ranked_questions;
---

<BaseLayout
  title="Questions | FrontierGraph"
  description="Browse question candidates surfaced from nearby topics, directed links, and papers."
>
  <main>
    <section class="page-hero">
      <h1>Browse questions by field.</h1>
      <p class="lede">
        Start with the part of economics you care about, then widen to the broader public list when you want more range.
      </p>
    </section>

    <section class="section">
      <div class="editorial-carousel-grid editorial-carousel-grid-fields">
        {data.questions.field_carousels.map((group, index) => (
          <div id={group.slug}>
            <EditorialQuestionCarousel
              items={group.items}
              title={group.title}
              groupLabel="Field"
              sectionId={`field-carousel-${group.slug}`}
              initialDelayMs={index * 700}
            />
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="editorial-carousel-grid editorial-carousel-grid-use-cases">
        {data.questions.use_case_carousels.map((group, index) => (
          <EditorialQuestionCarousel
            items={group.items}
            title={group.title}
            groupLabel="Use case"
            sectionId={`use-case-carousel-${group.slug}`}
            initialDelayMs={(index + data.questions.field_carousels.length) * 700}
          />
        ))}
      </div>
    </section>

    <OpportunityCards
      items={questions}
      title="Search the wider released list"
      caption="Use the filters when you want a broader pass across the public question window."
      sectionId="overall-ranked-questions"
      enableFilters={true}
      initialVisibleCount={18}
    />
  </main>
</BaseLayout>

<script is:inline>
  const focusQuestionFromHash = () => {
    const hash = window.location.hash;
    if (!hash || hash.length <= 1) return;
    const target = document.getElementById(hash.slice(1));
    if (!(target instanceof HTMLElement)) return;
    for (const card of document.querySelectorAll(".opportunity-card.is-targeted")) {
      card.classList.remove("is-targeted");
    }
    target.classList.add("is-targeted");
    const evidence = target.querySelector("[data-role='opportunity-evidence']");
    if (evidence instanceof HTMLDetailsElement) {
      evidence.open = true;
    }
  };

  window.addEventListener("hashchange", focusQuestionFromHash);
  window.addEventListener("load", focusQuestionFromHash);
</script>
