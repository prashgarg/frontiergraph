---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CuratedOpportunityCards from "../../components/CuratedOpportunityCards.astro";
import OpportunityCards from "../../components/OpportunityCards.astro";
import { data } from "../../lib/site-data";

const questions = data.questions.ranked_questions;
---

<BaseLayout
  title="Questions | FrontierGraph"
  description="Browse released questions from the FrontierGraph literature graph."
>
  <main>
    <section class="page-hero">
      <h1>Browse released questions from the literature graph.</h1>
      <p class="lede">
        Start with the curated examples, then open the wider list only when you want more to inspect.
      </p>
    </section>

    <CuratedOpportunityCards
      items={data.questions.curated_front_set}
      title="Start here"
      caption="Six hand-picked examples from the current public release."
      sectionId="questions-curated-front-set"
      variant="questions"
    />

    <section class="section">
      <div class="section-heading">
        <div>
          <h2>Browse by field</h2>
        </div>
        <p class="section-copy">
          Pick the part of economics you care about and move quickly to examples.
        </p>
      </div>
      <div class="editorial-group-stack">
        {data.questions.field_shelves.map((group) => (
          <CuratedOpportunityCards
            items={group.items}
            title={group.title}
            caption={group.caption}
            sectionId={`field-shelf-${group.slug}`}
            standalone={false}
            variant="compact"
          />
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <div>
          <h2>Browse by use case</h2>
        </div>
        <p class="section-copy">
          These shelves are grouped by the kind of question people usually have in practice.
        </p>
      </div>
      <div class="editorial-group-stack">
        {data.questions.collections.map((group) => (
          <CuratedOpportunityCards
            items={group.items}
            title={group.title}
            caption={group.caption}
            sectionId={`question-collection-${group.slug}`}
            standalone={false}
            variant="compact"
          />
        ))}
      </div>
    </section>

    <OpportunityCards
      items={questions}
      title="More questions"
      caption="Use search and filters when you want a wider pass through the released list."
      sectionId="overall-ranked-questions"
      enableFilters={true}
    />
  </main>
</BaseLayout>

<script is:inline>
  const focusQuestionFromHash = () => {
    const hash = window.location.hash;
    if (!hash || hash.length <= 1) return;
    const target = document.getElementById(hash.slice(1));
    if (!(target instanceof HTMLElement)) return;
    for (const card of document.querySelectorAll(".opportunity-card.is-targeted")) {
      card.classList.remove("is-targeted");
    }
    target.classList.add("is-targeted");
    const evidence = target.querySelector("[data-role='opportunity-evidence']");
    if (evidence instanceof HTMLDetailsElement) {
      evidence.open = true;
    }
  };

  window.addEventListener("hashchange", focusQuestionFromHash);
  window.addEventListener("load", focusQuestionFromHash);
</script>
