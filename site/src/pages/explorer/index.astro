---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Deprecated Route | Frontier Graph"
  description="This route has been deprecated. Use Questions, Graph, or Literature Graph instead."
>
  <main>
    <section class="page-hero">
      <h1>This route has been deprecated.</h1>
      <p class="lede">
        Use Questions for candidate paper ideas, Graph for missing paths, or Literature Graph for the local literature map.
      </p>
      <div class="button-row">
        <a class="button-primary" href="/questions/">Questions</a>
        <a class="button-secondary" href="/graph/">Graph</a>
        <a class="button-secondary" href="/literature/">Literature Graph</a>
      </div>
    </section>
  </main>
  <script is:inline>
    const params = new URLSearchParams(window.location.search);
    const view = params.get("view") || "";
    const pair = params.get("pair") || "";
    if (view === "question" && pair) {
      window.location.replace(`/questions/#${encodeURIComponent(pair)}`);
    }
  </script>
</BaseLayout>
