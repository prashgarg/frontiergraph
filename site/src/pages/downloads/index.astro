---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { data, formatBytes, formatCompact } from "../../lib/site-data";

const publicDb = data.downloads.public_db;
const artifacts = data.downloads.artifacts;
const artifactDetails = data.downloads.artifact_details;
const guides = data.downloads.guides;
const tierBundles = data.downloads.tier_bundles;

const tier1Files = [
  { title: "Top questions CSV", path: artifacts.top_questions_csv, size: artifactDetails.top_questions_csv.size_bytes },
  { title: "Central concepts CSV", path: artifacts.central_concepts_csv, size: artifactDetails.central_concepts_csv.size_bytes },
  { title: "Curated questions JSON", path: artifacts.curated_questions_json, size: artifactDetails.curated_questions_json.size_bytes },
  { title: "Benchmark manifest JSON", path: artifacts.benchmark_manifest_json, size: artifactDetails.benchmark_manifest_json.size_bytes },
];

const tier2Files = [
  { title: "Literature map JSON", path: artifacts.graph_backbone_json, size: artifactDetails.graph_backbone_json.size_bytes },
  { title: "Concept index JSON", path: artifacts.concept_index_json, size: artifactDetails.concept_index_json.size_bytes },
  { title: "Concept neighborhoods index", path: artifacts.concept_neighborhoods_index_json, size: artifactDetails.concept_neighborhoods_index_json.size_bytes },
  { title: "Concept opportunities index", path: artifacts.concept_opportunities_index_json, size: artifactDetails.concept_opportunities_index_json.size_bytes },
];

const tier3Files = [
  { title: publicDb.filename, path: publicDb.public_url, size: publicDb.db_size_bytes },
  { title: "Manifest", path: data.downloads.manifest_path, size: artifactDetails.manifest_json.size_bytes },
  { title: "Checksum", path: data.downloads.checksum_path, size: artifactDetails.checksum_txt.size_bytes },
];
---

<BaseLayout
  title="Downloads | FrontierGraph"
  description="Download released FrontierGraph tables, graph assets, and the SQLite bundle."
>
  <main>
    <section class="page-hero">
      <h1>Download the released files.</h1>
      <p class="lede">
        Start with the small tables unless you already know you need the full SQLite bundle.
      </p>
    </section>

    <section class="section download-stack">
      <div class="button-row download-doc-row">
        <a class="button-secondary" href={guides.readme.path}>README ({formatBytes(guides.readme.size_bytes)})</a>
        <a class="button-secondary" href={guides.data_dictionary.path}>Data dictionary ({formatBytes(guides.data_dictionary.size_bytes)})</a>
      </div>

      <div class="editorial-carousel-grid editorial-carousel-grid-use-cases download-tier-grid">
        <article class="download-panel download-tier-tile">
          <span class="eyebrow">Tier 1</span>
          <h2>Lightweight tables</h2>
          <p class="download-copy">Best for spreadsheets, reading lists, and quick sorting.</p>
          <div class="download-tier-meta">
            <span>{formatBytes(tierBundles.tier1.size_bytes)}</span>
            <span>CSV and small JSON files</span>
          </div>
          <div class="button-row">
            <a class="button-primary" href={tierBundles.tier1.path}>Download all</a>
          </div>
          <details class="download-tier-detail">
            <summary>What’s inside</summary>
            <ul class="download-tier-list">
              {tier1Files.map((file) => (
                <li>
                  <a href={file.path}>{file.title}</a>
                  <span>{formatBytes(file.size)}</span>
                </li>
              ))}
            </ul>
          </details>
        </article>

        <article class="download-panel download-tier-tile">
          <span class="eyebrow">Tier 2</span>
          <h2>Structured graph assets</h2>
          <p class="download-copy">Best for rebuilding the public map or using the released JSON directly.</p>
          <div class="download-tier-meta">
            <span>{formatBytes(tierBundles.tier2.size_bytes)}</span>
            <span>Machine-readable site assets</span>
          </div>
          <div class="button-row">
            <a class="button-primary" href={tierBundles.tier2.path}>Download all</a>
          </div>
          <details class="download-tier-detail">
            <summary>What’s inside</summary>
            <ul class="download-tier-list">
              {tier2Files.map((file) => (
                <li>
                  <a href={file.path}>{file.title}</a>
                  <span>{formatBytes(file.size)}</span>
                </li>
              ))}
            </ul>
          </details>
        </article>

        <article class="download-panel download-tier-tile">
          <span class="eyebrow">Tier 3</span>
          <h2>SQLite bundle</h2>
          <p class="download-copy">Best for deeper local analysis and app-equivalent evidence tables.</p>
          <div class="download-tier-meta">
            <span>{formatBytes(publicDb.db_size_bytes)}</span>
            <span>{publicDb.filename}</span>
          </div>
          <div class="button-row">
            <a class="button-primary" href={publicDb.public_url}>Download all</a>
          </div>
          <details class="download-tier-detail">
            <summary>What’s inside</summary>
            <ul class="download-tier-list">
              {tier3Files.map((file) => (
                <li>
                  <a href={file.path}>{file.title}</a>
                  <span>{formatBytes(file.size)}</span>
                </li>
              ))}
            </ul>
          </details>
        </article>
      </div>

      <details class="download-guidance">
        <summary>About the release</summary>
        <div class="download-guidance-body">
          <div class="metrics-grid">
            <article class="metric-card">
              <div class="metric-value">{formatCompact(data.metrics.papers)}</div>
              <div class="metric-label">published-journal papers screened</div>
            </article>
            <article class="metric-card">
              <div class="metric-value">{formatCompact(data.metrics.papers_with_extracted_edges)}</div>
              <div class="metric-label">papers with extracted graph structure</div>
            </article>
            <article class="metric-card">
              <div class="metric-value">{formatCompact(data.metrics.normalized_graph_papers)}</div>
              <div class="metric-label">papers in the normalized concept graph</div>
            </article>
            <article class="metric-card">
              <div class="metric-value">{formatCompact(data.metrics.normalized_links)}</div>
              <div class="metric-label">normalized concept links</div>
            </article>
            <article class="metric-card">
              <div class="metric-value">{formatCompact(data.metrics.native_concepts)}</div>
              <div class="metric-label">native concepts</div>
            </article>
            <article class="metric-card">
              <div class="metric-value">{formatCompact(data.metrics.visible_public_questions)}</div>
              <div class="metric-label">questions in the released browsing surface</div>
            </article>
          </div>
        </div>
      </details>
    </section>
  </main>
</BaseLayout>
