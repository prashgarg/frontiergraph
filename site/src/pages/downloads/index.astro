---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { data, formatCompact, formatNumber } from "../../lib/site-data";

const betaDb = data.downloads.beta_db;
const artifacts = data.downloads.artifacts;
const publicReady = Boolean(betaDb.public_url);
---

<BaseLayout
  title="Downloads | FrontierGraph"
  description="Download the FrontierGraph code, beta database, graph assets, and comparison summaries."
>
  <main>
    <section class="page-hero">
      <span class="eyebrow">Downloads</span>
      <h1>Code, data, graph assets, and comparison summaries.</h1>
      <p class="lede">
        The public release exposes the repository, the current beta database package, the graph assets used by the site,
        and the comparison summaries used to choose the default concept view.
      </p>
      <div class="button-row">
        <a class="button-primary" href={data.repo_url}>Open repository</a>
        <a class="button-secondary" href="/how-it-works/">How It Works</a>
        <a class="button-tertiary" href="/advanced/">Back to advanced hub</a>
      </div>
    </section>

    <section class="section download-stack">
      <article class="download-panel">
        <span class="eyebrow">Main database</span>
        <h3>{betaDb.filename}</h3>
        <div class="download-meta">
          <div>
            <span class="tiny-label">Approximate size</span>
            <div class="big-number">{betaDb.db_size_gb} GB</div>
          </div>
          <div>
            <span class="tiny-label">SHA-256</span>
            <div class="card-copy">{betaDb.sha256.slice(0, 16)}...</div>
          </div>
        </div>
        <p class="download-copy">
          The public beta database package behind the release. It is accompanied by manifest and checksum files so users
          can verify the bundle they download.
        </p>
        {!publicReady && <p class="warning-note">Public mirror pending. The metadata is live, but the object is not yet public.</p>}
        <div class="button-row">
          {publicReady ? (
            <a class="button-primary" href={betaDb.public_url}>Download beta DB</a>
          ) : (
            <span class="download-badge">Mirror pending</span>
          )}
          <a class="button-secondary" href={data.downloads.checksum_path}>Checksum</a>
          <a class="button-secondary" href={data.downloads.manifest_path}>Manifest</a>
        </div>
      </article>

      <article class="download-panel">
        <span class="eyebrow">Site assets</span>
        <h3>Literature map, question, and comparison artifacts</h3>
        <p class="download-copy">
          These are the same static assets the public site uses for the literature map, top research questions, central concept
          tables, and ontology comparison summaries.
        </p>
        <div class="card-grid download-artifact-grid">
          <a class="card artifact-card" href={artifacts.graph_backbone_json}>
            <span class="eyebrow">Map asset</span>
            <h3>Literature map JSON</h3>
            <p class="card-copy">Observed baseline backbone used on the public literature map page.</p>
          </a>
          <a class="card artifact-card" href={artifacts.central_concepts_csv}>
            <span class="eyebrow">Concept export</span>
            <h3>Central concepts CSV</h3>
            <p class="card-copy">Weighted-degree and support statistics for the public central concept table.</p>
          </a>
          <a class="card artifact-card" href={artifacts.top_opportunities_csv}>
            <span class="eyebrow">Question export</span>
            <h3>Top research questions CSV</h3>
            <p class="card-copy">The current suppressed baseline research-question surface in a lightweight tabular form.</p>
          </a>
          <a class="card artifact-card" href={artifacts.compare_summary_json}>
            <span class="eyebrow">Comparison export</span>
            <h3>Compare summary JSON</h3>
            <p class="card-copy">Broad, Baseline, and Conservative regime summaries used on the comparison page.</p>
          </a>
        </div>
      </article>

      <article class="download-panel">
        <span class="eyebrow">Working facts</span>
        <h3>Current public build at a glance</h3>
        <div class="metrics-grid">
          <article class="metric-card">
            <div class="metric-value">{formatCompact(data.metrics.papers)}</div>
            <div class="metric-label">papers</div>
          </article>
          <article class="metric-card">
            <div class="metric-value">{formatCompact(data.metrics.baseline_head_concepts)}</div>
            <div class="metric-label">baseline head concepts</div>
          </article>
          <article class="metric-card">
            <div class="metric-value">{formatCompact(data.metrics.suppressed_candidate_count)}</div>
            <div class="metric-label">visible candidates in the default public surface</div>
          </article>
        </div>
      </article>
    </section>
  </main>
</BaseLayout>
