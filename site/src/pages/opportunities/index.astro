---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ConceptOpportunityLookup from "../../components/ConceptOpportunityLookup.astro";
import OpportunityCards from "../../components/OpportunityCards.astro";
import { data, formatNumber } from "../../lib/site-data";

const slices = data.opportunities.top_slices;
const defaultRegime = `${data.default_view.regime} ${data.default_view.mapping}`;
---

<BaseLayout
  title="Opportunities | FrontierGraph"
  description="Browse suppressed baseline opportunities from the concept graph of economics."
>
  <main>
    <section class="page-hero">
      <span class="eyebrow">Opportunities</span>
      <h1>Browse the public opportunity surface in plain language.</h1>
      <p class="lede">
        These links come from the public <strong>{defaultRegime}</strong> ranking surface after deterministic near-synonym cleanup.
        This page keeps the list readable for newcomers first. The app and Method page keep the deeper score mechanics and raw graph terms.
      </p>
      <div class="button-row">
        <span class="field-pill">{formatNumber(data.metrics.suppressed_candidate_count)} visible candidates</span>
        <span class="field-pill">{formatNumber(data.metrics.duplicate_loops_removed_top100)} duplicate loops removed from the top 100</span>
        <a class="button-secondary" href={data.app_url}>Open explorer</a>
      </div>
    </section>

    <ConceptOpportunityLookup
      appUrl={data.app_url}
      conceptIndexPath={data.graph.concept_index_path}
      neighborhoodsIndexPath={data.graph.concept_neighborhoods_index_path}
      opportunitiesIndexPath={data.graph.concept_opportunities_index_path}
      title="Search one concept and inspect the local opportunity surface"
      caption="Use lexical search to jump to a concept, see the observed neighborhood around it, and open the strongest nearby ranked links."
    />

    <OpportunityCards
      items={slices.overall}
      title="Top opportunities overall"
      caption="This is the main public list. Secondary slices stay tucked behind a disclosure below, and the Method page explains the raw score terms."
    />

    <section class="section">
      <details class="method-detail">
        <summary>
          <span>
            <span class="eyebrow">Secondary slices</span>
            <strong>Open the narrower opportunity views</strong>
          </span>
        </summary>
        <div class="method-body opportunity-slice-stack">
          <div class="split-section">
            <OpportunityCards
              items={slices.bridges}
              title="Connect separate literatures"
              caption="Links where the graph suggests separate literatures are ready to connect."
              compact={true}
              standalone={false}
            />
            <OpportunityCards
              items={slices.frontier}
              title="Missing direct link"
              caption="Links where the surrounding literature is already close, but the public sample still shows little or no direct work."
              compact={true}
              standalone={false}
            />
          </div>

          <div class="split-section">
            <OpportunityCards
              items={slices.fast_follow}
              title="Ready to follow through"
              caption="Ideas that look ready for a direct follow-through because the surrounding graph is already strong."
              compact={true}
              standalone={false}
            />
            <OpportunityCards
              items={slices.underexplored}
              title="Early but promising"
              caption="Pairs where nearby evidence looks richer than the direct connection itself."
              compact={true}
              standalone={false}
            />
          </div>
        </div>
      </details>
    </section>
  </main>
</BaseLayout>
