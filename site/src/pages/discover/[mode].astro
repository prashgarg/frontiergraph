---
import BaseLayout from "../../layouts/BaseLayout.astro";
import OpportunityTable from "../../components/OpportunityTable.astro";
import { data } from "../../lib/site-data";

export function getStaticPaths() {
  return Object.keys(data.discover).map((mode) => ({ params: { mode } }));
}

const mode = Astro.params.mode as keyof typeof data.discover;
const slice = data.discover[mode];
if (!slice) {
  throw new Error(`Unknown discovery mode: ${mode}`);
}
---

<BaseLayout
  title={`${slice.title} | FrontierGraph`}
  description={slice.description}
>
  <main>
    <section class="page-hero">
      <span class="eyebrow">{slice.preset}</span>
      <h1>{slice.title}</h1>
      <p class="lede">{slice.description}</p>
      <div class="button-row">
        <a class="button-primary" href={slice.app_link}>Open this slice in the app</a>
        <a class="button-secondary" href={slice.download_path}>Download CSV</a>
      </div>
    </section>

    <section class="section spotlight-grid">
      {slice.items.slice(0, 2).map((item: any) => (
        <article class="card">
          <span class="eyebrow">{item.novelty}</span>
          <h3>{item.opportunity}</h3>
          <p class="card-copy">{item.why_now}</p>
          <div class="button-row">
            <span class="field-pill">{item.source_field_name}</span>
            <span class="field-pill">{item.target_field_name}</span>
          </div>
        </article>
      ))}
    </section>

    <OpportunityTable items={slice.items} title="Ranked opportunities" />
  </main>
</BaseLayout>
