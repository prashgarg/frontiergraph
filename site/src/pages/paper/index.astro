---
import PaperLayout from "../../layouts/PaperLayout.astro";
import PaperOverview from "../../generated/paper/research_allocation_paper_overview.md";
import manifest from "../../generated/paper/paper_manifest.json";
import { data } from "../../lib/site-data";

const toc = manifest.overview.headings;
---

<PaperLayout
  title="What FrontierGraph Finds"
  description="A skim-first web overview of the FrontierGraph paper, benchmark, and public release."
  eyebrow="Paper overview"
  deck="Start here if you want the setup, the benchmark, and the strongest results without reading the full manuscript first."
  toc={toc}
  pdfUrl={data.downloads.artifacts.working_paper_pdf}
  variant="overview"
  appUrl={data.app_url}
>
  <PaperOverview />
</PaperLayout>
