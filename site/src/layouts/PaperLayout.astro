---
import BaseLayout from "./BaseLayout.astro";

interface TocEntry {
  level: number;
  text: string;
  id: string;
}

interface Props {
  title: string;
  subtitle?: string;
  description: string;
  eyebrow: string;
  deck?: string;
  toc?: TocEntry[];
  pdfUrl: string;
  author?: string;
  authorUrl?: string;
  affiliation?: string;
  draftLabel?: string;
  lastUpdated?: string;
}

const {
  title,
  subtitle = "",
  description,
  eyebrow,
  deck = "",
  toc = [],
  pdfUrl,
  author = "",
  authorUrl = "",
  affiliation = "",
  draftLabel = "",
  lastUpdated = "",
} = Astro.props;
const showToc = toc.length > 0;
---

<BaseLayout title={`${title} | Frontier Graph`} description={description} shellClass="site-shell site-shell-wide">
  <main>
    <section class="page-hero paper-hero">
      <span class="eyebrow">{eyebrow}</span>
      <h1>{title}</h1>
      {subtitle && <p class="paper-subtitle">{subtitle}</p>}
      {(author || affiliation) && (
        <div class="paper-author-block">
          {author && (
            authorUrl ? (
              <a class="paper-author" href={authorUrl}>{author}</a>
            ) : (
              <p class="paper-author">{author}</p>
            )
          )}
          {affiliation && <p class="paper-affiliation">{affiliation}</p>}
        </div>
      )}
      {(draftLabel || lastUpdated) && (
        <div class="paper-hero-meta">
          {draftLabel && <p class="paper-draft-label">{draftLabel}</p>}
          {lastUpdated && <p class="paper-last-updated">Last Updated: {lastUpdated}</p>}
        </div>
      )}
      {deck && <p class="lede">{deck}</p>}
      <div class="button-row">
        <a class="button-primary" href={pdfUrl}>Download PDF</a>
        <a class="button-secondary" href="/downloads/">Open downloads</a>
      </div>
    </section>

    <section class="paper-shell">
      {showToc && (
        <aside class="paper-toc-shell">
          <div class="paper-toc-card">
            <span class="eyebrow">Contents</span>
            <nav class="paper-toc">
              {toc.map((entry) => (
                <a class:list={["paper-toc-link", entry.level === 3 && "is-sub"]} href={`#${entry.id}`}>{entry.text}</a>
              ))}
            </nav>
          </div>
        </aside>
      )}
      <article class="paper-article">
        <slot />
        <div class="paper-exit-card">
          <span class="eyebrow">Keep going</span>
          <h2>Take the paper away with the released files.</h2>
          <div class="button-row">
            <a class="button-primary" href={pdfUrl}>Download PDF</a>
            <a class="button-secondary" href="/downloads/">Open downloads</a>
          </div>
        </div>
      </article>
    </section>
  </main>
</BaseLayout>

<script>
  import mermaid from "mermaid";

  const renderPaperMermaid = async () => {
    mermaid.initialize({
      startOnLoad: false,
      securityLevel: "loose",
      theme: "base",
      themeVariables: {
        background: "#ffffff",
        primaryColor: "#eaf2ff",
        primaryTextColor: "#102037",
        primaryBorderColor: "#2b5fdd",
        lineColor: "#6c7d95",
        tertiaryColor: "#eff5fb",
        clusterBkg: "#f7fbff",
        clusterBorder: "#c9d9f2",
        fontFamily: "Source Sans 3, sans-serif",
      },
      flowchart: {
        useMaxWidth: true,
        htmlLabels: true,
        curve: "basis",
      },
    });

    const mermaidBlocks = Array.from(document.querySelectorAll(".paper-article pre[data-language='mermaid']"));
    mermaidBlocks.forEach((preBlock, index) => {
      if (!(preBlock instanceof HTMLElement)) return;
      const codeBlock = preBlock.querySelector("code");
      const source =
        codeBlock instanceof HTMLElement
          ? codeBlock.innerText.trim()
          : codeBlock?.textContent?.trim();
      if (!source) return;

      const wrapper = document.createElement("div");
      wrapper.className = "paper-mermaid";

      const container = document.createElement("div");
      container.className = "mermaid";
      container.id = `paper-mermaid-${index}`;
      container.textContent = source;

      wrapper.appendChild(container);
      preBlock.replaceWith(wrapper);
    });

    const nodes = Array.from(document.querySelectorAll(".paper-mermaid .mermaid"));
    if (nodes.length === 0) return;

    try {
      await mermaid.run({ nodes });
    } catch (error) {
      console.error("Failed to render Mermaid diagrams in paper view", error);
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => void renderPaperMermaid(), { once: true });
  } else {
    void renderPaperMermaid();
  }
</script>
