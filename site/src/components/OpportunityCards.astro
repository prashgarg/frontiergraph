---
import type { Opportunity } from "../lib/site-data";

interface Props {
  items: Opportunity[];
  title?: string;
  caption?: string;
  compact?: boolean;
  standalone?: boolean;
  sectionId?: string;
}

const {
  items,
  title,
  caption,
  compact = false,
  standalone = true,
  sectionId = "ranked-opportunities",
} = Astro.props;
---

<section class:list={[standalone && "section"]} data-role={sectionId}>
  {title && (
    <div class:list={["section-heading", !standalone && "section-heading-compact"]}>
      <div>
        <span class="eyebrow">Ranked opportunities</span>
        <h2>{title}</h2>
      </div>
      {caption && <p class="section-copy">{caption}</p>}
    </div>
  )}
  <div class:list={["opportunity-cards", compact && "compact"]}>
    {items.map((item) => (
      <article class="opportunity-card" data-role="structured-opportunity-card">
        <div class="opportunity-kicker">
          <span>{item.slice_label}</span>
          <span>{item.direct_link_status}</span>
        </div>
        <h3>{item.source_label} → {item.target_label}</h3>
        <div class="opportunity-summary-row">
          <span class="field-pill">Supported by {item.supporting_path_count} nearby concepts</span>
        </div>
        <p class="opportunity-context">
          Public context: {item.source_context_summary} on one side and {item.target_context_summary} on the other.
        </p>
        <a class="text-link" href={item.app_link}>Open in app</a>
      </article>
    ))}
  </div>
</section>
