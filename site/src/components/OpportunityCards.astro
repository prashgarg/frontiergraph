---
import { formatPercent, shortList, type Opportunity } from "../lib/site-data";

interface Props {
  items: Opportunity[];
  title?: string;
  caption?: string;
  compact?: boolean;
  standalone?: boolean;
}

const { items, title, caption, compact = false, standalone = true } = Astro.props;
---

<section class:list={[standalone && "section"]}>
  {title && (
    <div class:list={["section-heading", !standalone && "section-heading-compact"]}>
      <div>
        <span class="eyebrow">Ranked opportunities</span>
        <h2>{title}</h2>
      </div>
      {caption && <p class="section-copy">{caption}</p>}
    </div>
  )}
  <div class:list={["opportunity-cards", compact && "compact"]}>
    {items.map((item) => (
      <article class="opportunity-card">
        <div class="opportunity-kicker">
          <span>{item.source_bucket} → {item.target_bucket}</span>
          <span>score {item.score.toFixed(3)}</span>
        </div>
        <h3>{item.source_label} → {item.target_label}</h3>
        <p class="card-copy">
          Path support {formatPercent(item.path_support_norm)} with {item.mediator_count} mediators and {item.cooc_count} direct co-occurrences in the current graph.
        </p>
        <div class="opportunity-stat-row">
          <span>Gap {item.gap_bonus.toFixed(2)}</span>
          <span>Motifs {item.motif_count}</span>
          <span>Co-occurrence {item.cooc_count}</span>
        </div>
        <p class="opportunity-context">
          Source context {shortList(item.top_countries_source)} · Target context {shortList(item.top_countries_target)}
        </p>
        <a class="text-link" href={item.app_link}>Open in app</a>
      </article>
    ))}
  </div>
</section>
