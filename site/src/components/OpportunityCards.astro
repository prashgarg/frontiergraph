---
import { formatPercent, type Opportunity } from "../lib/site-data";

interface Props {
  items: Opportunity[];
  title?: string;
  caption?: string;
  compact?: boolean;
  standalone?: boolean;
}

const { items, title, caption, compact = false, standalone = true } = Astro.props;
---

<section class:list={[standalone && "section"]}>
  {title && (
    <div class:list={["section-heading", !standalone && "section-heading-compact"]}>
      <div>
        <span class="eyebrow">Ranked opportunities</span>
        <h2>{title}</h2>
      </div>
      {caption && <p class="section-copy">{caption}</p>}
    </div>
  )}
  <div class:list={["opportunity-cards", compact && "compact"]}>
    {items.map((item) => (
      <article class="opportunity-card">
        <div class="opportunity-kicker">
          <span>{item.slice_label}</span>
          <span>{item.direct_link_status}</span>
        </div>
        <h3>{item.source_label} → {item.target_label}</h3>
        <p class="card-copy">
          {item.why_now}
        </p>
        <div class="opportunity-summary-row">
          <span class="field-pill">Supported by {item.supporting_path_count} nearby concepts</span>
          <span class="field-pill">{item.source_bucket} → {item.target_bucket}</span>
        </div>
        <p class="opportunity-context">
          Source context: {item.source_context_summary}. Target context: {item.target_context_summary}.
        </p>
        <p class="mini-copy">{item.recommended_move}</p>
        <details class="opportunity-detail">
          <summary>Advanced graph detail</summary>
          <div class="opportunity-advanced">
            <span>Path support {formatPercent(item.path_support_norm)}</span>
            <span>Gap bonus {item.gap_bonus.toFixed(2)}</span>
            <span>Motifs {item.motif_count}</span>
            <span>Direct co-occurrences {item.cooc_count}</span>
          </div>
        </details>
        <a class="text-link" href={item.app_link}>Open in app</a>
      </article>
    ))}
  </div>
</section>
