---
import OpportunityEvidence from "./OpportunityEvidence.astro";
import {
  getPublicLabel,
  getPublicLabelSubtitle,
  type Opportunity,
} from "../lib/site-data";

interface Props {
  items: Opportunity[];
  title?: string;
  caption?: string;
  compact?: boolean;
  standalone?: boolean;
  sectionId?: string;
  enableFilters?: boolean;
  initialVisibleCount?: number;
}

const {
  items,
  title,
  caption,
  compact = false,
  standalone = true,
  sectionId = "ranked-opportunities",
  enableFilters = false,
  initialVisibleCount = 0,
} = Astro.props;

const rootId = `opportunity-cards-${Math.random().toString(36).slice(2, 10)}`;

const filters = [
  { id: "cross-area", label: "Cross-area" },
  { id: "strong-nearby", label: "Stronger nearby evidence" },
  { id: "broader-project", label: "Broader project" },
];

const buildGlossNotes = (item: Opportunity) => {
  const sourceDisplayLabel = getPublicLabel(item.source_id, item.source_label);
  const targetDisplayLabel = getPublicLabel(item.target_id, item.target_label);
  const notes = [
    getPublicLabelSubtitle(item.source_id)
      ? `${sourceDisplayLabel}: ${getPublicLabelSubtitle(item.source_id)}.`
      : "",
    getPublicLabelSubtitle(item.target_id)
      ? `${targetDisplayLabel}: ${getPublicLabelSubtitle(item.target_id)}.`
      : "",
  ].filter(Boolean);
  return notes.join(" ");
};
---

<section id={rootId} class:list={[standalone && "section"]} data-role={sectionId}>
  {title && (
    <div class:list={["section-heading", !standalone && "section-heading-compact"]}>
      <div>
        <h2>{title}</h2>
      </div>
      {caption && <p class="section-copy">{caption}</p>}
    </div>
  )}
  {enableFilters && (
    <div class="opportunity-filter-shell" data-role="opportunity-filter-shell">
      <label class="search-shell opportunity-search-shell">
        <span>Search questions</span>
        <input type="search" placeholder="Search by topic" data-role="opportunity-search-input" />
      </label>
      <div class="opportunity-filter-bar" data-role="opportunity-filter-bar">
        {filters.map((filter) => (
          <button
            class="button-tertiary opportunity-filter-chip"
            type="button"
            data-role="opportunity-filter-chip"
            data-filter-id={filter.id}
            aria-pressed="false"
          >
            {filter.label}
          </button>
        ))}
      </div>
    </div>
  )}
  <div class:list={["opportunity-cards", compact && "compact"]}>
    {items.map((item, index) => (
      <article
        class="opportunity-card"
        id={item.pair_key}
        data-role="structured-opportunity-card"
        data-card-index={String(index)}
        data-question-family={item.question_family}
        data-cross-area={String(item.cross_field)}
        data-strong-nearby={String(item.supporting_path_count >= 20 || item.path_support_norm >= 0.65)}
        data-broader-project={String(item.mediator_count >= 10 || item.supporting_path_count >= 30)}
        data-search-text={`${item.public_pair_label} ${item.source_label} ${item.target_label}`.toLowerCase()}
      >
        <div class="opportunity-kicker">
          <span>Ranked question</span>
          {item.cross_field && <span>Cross-area</span>}
        </div>
        <h3>{item.public_pair_label}</h3>
        {buildGlossNotes(item) && <p class="mini-copy opportunity-label-note">{buildGlossNotes(item)}</p>}
        <p class="mini-copy">
          <strong>Nearby linking concepts:</strong> {item.supporting_path_count}
        </p>
        {item.representative_papers.length > 0 && (
          <div class="mini-copy opportunity-paper-preview">
            <strong>Papers to begin with:</strong>
            <ul class="opportunity-paper-list">
              {item.representative_papers.slice(0, 2).map((paper) => (
                <li>
                  <span>{paper.title}</span>
                  {paper.year > 0 && <span class="opportunity-paper-year">({paper.year})</span>}
                </li>
              ))}
            </ul>
          </div>
        )}
        <OpportunityEvidence
          mediatorLabels={item.top_mediator_labels}
          representativePapers={item.representative_papers}
          directLinkStatus={item.direct_link_status}
          commonContexts={item.common_contexts}
        />
        <a class="text-link" href={item.app_link}>Explore in app</a>
      </article>
    ))}
  </div>
  {enableFilters && initialVisibleCount > 0 && (
    <div class="opportunity-load-more" data-role="opportunity-load-more-shell" hidden>
      <button class="button-secondary" type="button" data-role="opportunity-load-more">
        Show more questions
      </button>
    </div>
  )}
  {enableFilters && (
    <p class="card-copy opportunity-empty-state" data-role="opportunity-filter-empty" hidden>
      No questions match the current search or filter combination. Try clearing a chip or editing the search.
    </p>
  )}
</section>

{enableFilters && (
  <script is:inline define:vars={{ rootId, initialVisibleCount }} type="module">
    const root = document.getElementById(rootId);
    if (!(root instanceof HTMLElement)) throw new Error("Opportunity cards root missing");

    const cards = Array.from(root.querySelectorAll('[data-role="structured-opportunity-card"]'));
    const chips = Array.from(root.querySelectorAll('[data-role="opportunity-filter-chip"]'));
    const searchInput = root.querySelector('[data-role="opportunity-search-input"]');
    const emptyState = root.querySelector('[data-role="opportunity-filter-empty"]');
    const loadMoreShell = root.querySelector('[data-role="opportunity-load-more-shell"]');
    const loadMoreButton = root.querySelector('[data-role="opportunity-load-more"]');
    const active = new Set();
    let query = "";
    let visibleLimit = Number(initialVisibleCount || 0);

    const filterToDataset = {
      "cross-area": "crossArea",
      "strong-nearby": "strongNearby",
      "broader-project": "broaderProject",
    };

    const applyFilters = () => {
      const hasActiveFilters = active.size > 0 || Boolean(query);
      const matchingCards = [];
      let visibleCount = 0;
      for (const card of cards) {
        const matchesFilters = Array.from(active).every((filterId) => card.dataset[filterToDataset[filterId]] === "true");
        const matchesSearch = !query || (card.dataset.searchText || "").includes(query);
        if (matchesFilters && matchesSearch) matchingCards.push(card);
        const visible = matchesFilters && matchesSearch;
        card.hidden = !visible;
      }

      const targetPair = window.location.hash ? window.location.hash.slice(1) : "";
      if (!hasActiveFilters && visibleLimit > 0 && targetPair) {
        const targetIndex = matchingCards.findIndex((matchingCard) => matchingCard.id === targetPair);
        if (targetIndex >= visibleLimit) {
          visibleLimit = targetIndex + 1;
        }
      }

      matchingCards.forEach((card, index) => {
        const visible = !visibleLimit || hasActiveFilters || index < visibleLimit;
        card.hidden = !visible;
        if (visible) visibleCount += 1;
      });

      if (emptyState instanceof HTMLElement) {
        emptyState.hidden = visibleCount > 0;
      }
      if (loadMoreShell instanceof HTMLElement) {
        const hasMore = !hasActiveFilters && visibleLimit > 0 && matchingCards.length > visibleLimit;
        loadMoreShell.hidden = !hasMore;
        if (hasMore && loadMoreButton instanceof HTMLButtonElement) {
          const remaining = matchingCards.length - visibleLimit;
          loadMoreButton.textContent = remaining > 18 ? "Show 18 more questions" : `Show ${remaining} more questions`;
        }
      }
    };

    for (const chip of chips) {
      chip.addEventListener("click", () => {
        const filterId = chip.dataset.filterId;
        if (!filterId) return;
        if (active.has(filterId)) {
          active.delete(filterId);
        } else {
          active.add(filterId);
        }
        chip.setAttribute("aria-pressed", String(active.has(filterId)));
        chip.classList.toggle("is-active", active.has(filterId));
        applyFilters();
      });
    }

    if (searchInput instanceof HTMLInputElement) {
      searchInput.addEventListener("input", () => {
        query = searchInput.value.trim().toLowerCase();
        applyFilters();
      });
    }

    if (loadMoreButton instanceof HTMLButtonElement) {
      loadMoreButton.addEventListener("click", () => {
        visibleLimit += 18;
        applyFilters();
      });
    }

    window.addEventListener("hashchange", applyFilters);
    applyFilters();
  </script>
)}
