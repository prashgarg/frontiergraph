---
import type { CuratedOpportunity } from "../lib/site-data";

interface Props {
  items: CuratedOpportunity[];
  title?: string;
  caption?: string;
  sectionId?: string;
  standalone?: boolean;
}

const {
  items,
  title,
  caption,
  sectionId = "curated-opportunities",
  standalone = true,
} = Astro.props;
---

<section class:list={[standalone && "section"]} data-role={sectionId}>
  {title && (
    <div class:list={["section-heading", !standalone && "section-heading-compact"]}>
      <div>
        <span class="eyebrow">Editorial selection</span>
        <h2>{title}</h2>
      </div>
      {caption && <p class="section-copy">{caption}</p>}
    </div>
  )}
  <div class="opportunity-cards">
    {items.map((item) => (
      <article class="opportunity-card curated-opportunity-card" data-role="curated-opportunity-card">
        <div class="opportunity-kicker">
          <span>Hand-curated example</span>
          <span>{item.direct_link_status}</span>
        </div>
        <h3>{item.headline}</h3>
        <p class="opportunity-pair">{item.source_label} → {item.target_label}</p>
        <p class="card-copy">{item.summary}</p>
        <p class="opportunity-context">
          <strong>Why it matters:</strong> {item.why_it_matters}
        </p>
        <p class="mini-copy">
          <strong>How to start:</strong> {item.how_to_start}
        </p>
        <div class="opportunity-summary-row">
          <span>Supported by {item.supporting_path_count} nearby concepts</span>
        </div>
        <p class="opportunity-context">
          Public context: {item.source_context_summary} on one side and {item.target_context_summary} on the other.
        </p>
        <a class="text-link" href={item.app_link}>Open in app</a>
      </article>
    ))}
  </div>
</section>
