---
import OpportunityEvidence from "./OpportunityEvidence.astro";
import {
  getPublicLabel,
  type CuratedQuestion,
} from "../lib/site-data";

interface Props {
  items: CuratedQuestion[];
  title?: string;
  caption?: string;
  sectionId?: string;
  standalone?: boolean;
  variant?: "home" | "questions";
}

const {
  items,
  title,
  caption,
  sectionId = "curated-opportunities",
  standalone = true,
  variant = "questions",
} = Astro.props;
---

<section class:list={[standalone && "section"]} data-role={sectionId}>
  {title && (
    <div class:list={["section-heading", !standalone && "section-heading-compact"]}>
      <div>
        <span class="eyebrow">{variant === "home" ? "Featured questions" : "Start here"}</span>
        <h2>{title}</h2>
      </div>
      {caption && <p class="section-copy">{caption}</p>}
    </div>
  )}
  <div class="opportunity-cards">
    {items.map((item) => (
      <article
        class:list={["opportunity-card", "curated-opportunity-card", variant === "home" && "curated-opportunity-card-home"]}
        data-role="curated-opportunity-card"
        id={variant === "questions" ? item.pair_key : undefined}
      >
        <div class="opportunity-kicker">
          <span>{variant === "home" ? "Featured question" : "Hand-curated question"}</span>
          {variant === "questions" && <span>{item.direct_link_status}</span>}
        </div>
        <h3>{item.question_title}</h3>
        <p class="card-copy">{item.short_why}</p>
        <p class="mini-copy">
          <strong>First next step:</strong> {item.first_next_step}
        </p>
        {variant === "questions" && (
          <>
            <p class="mini-copy">
              <strong>Best for:</strong> {item.who_its_for}
            </p>
            <div class="opportunity-summary-row">
              <span>{item.direct_link_status}</span>
              <span>{item.supporting_path_count} related ideas in the surrounding literature</span>
            </div>
            <OpportunityEvidence
              mediatorLabels={item.top_mediator_labels}
              representativePapers={item.representative_papers}
              directLinkStatus={item.direct_link_status}
              sourceLabel={getPublicLabel(item.source_id, item.source_label)}
              targetLabel={getPublicLabel(item.target_id, item.target_label)}
              sourceContextSummary={item.source_context_summary}
              targetContextSummary={item.target_context_summary}
            />
            <a class="text-link" href={item.app_link}>Open in workbench</a>
          </>
        )}
        {variant === "home" && <a class="text-link" href={`/questions/#${item.pair_key}`}>See this question</a>}
      </article>
    ))}
  </div>
</section>
