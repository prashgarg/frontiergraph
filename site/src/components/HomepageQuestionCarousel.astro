---
interface Slide {
  pairKey: string;
  visualStyle: "bridge" | "fan" | "stack" | "arc";
  questionTitle: string;
  sourceLabel: string;
  targetLabel: string;
  mediatorLabels: string[];
  why: string;
  how: string;
  questionHref: string;
  appHref: string;
}

interface Props {
  slides: Slide[];
}

const { slides } = Astro.props;
---

<section class="hero-panel homepage-proof-panel" data-role="homepage-carousel">
  <div class="homepage-proof-heading">
    <div>
      <span class="eyebrow">A few speculative questions</span>
      <h2>What this looks like in practice</h2>
    </div>
    <p class="mini-copy homepage-proof-note">
      These are speculative research suggestions. The point is to show the kind of question that may be worth reading or
      testing next, not to claim that the link is already established.
    </p>
  </div>

  <div class="homepage-proof-grid">
    {slides.map((slide) => (
      <article
        class={`homepage-proof-card homepage-proof-card-${slide.visualStyle}`}
        data-role="homepage-proof-card"
        data-style={slide.visualStyle}
      >
        <div class="proof-visual-shell">
          {slide.visualStyle === "bridge" && (
            <svg viewBox="0 0 320 188" class="proof-visual" aria-hidden="true">
              <line x1="84" y1="92" x2="236" y2="92" class="proof-line proof-line-suggested" />
              <line x1="88" y1="92" x2="136" y2="54" class="proof-line" />
              <line x1="184" y1="54" x2="232" y2="92" class="proof-line" />
              <line x1="88" y1="92" x2="160" y2="92" class="proof-line" />
              <line x1="160" y1="92" x2="232" y2="92" class="proof-line" />
              <line x1="88" y1="92" x2="136" y2="132" class="proof-line" />
              <line x1="184" y1="132" x2="232" y2="92" class="proof-line" />
              <circle cx="160" cy="92" r="18" class="proof-node proof-node-mediator" />
              <circle cx="136" cy="54" r="16" class="proof-node proof-node-mediator proof-node-soft" />
              <circle cx="136" cy="132" r="16" class="proof-node proof-node-mediator proof-node-soft" />
              <ellipse cx="64" cy="92" rx="34" ry="22" class="proof-node proof-node-source" />
              <ellipse cx="256" cy="92" rx="34" ry="22" class="proof-node proof-node-target" />
              <text x="64" y="88" text-anchor="middle" class="proof-label proof-label-strong">{slide.sourceLabel}</text>
              <text x="256" y="88" text-anchor="middle" class="proof-label proof-label-strong">{slide.targetLabel}</text>
            </svg>
          )}

          {slide.visualStyle === "fan" && (
            <svg viewBox="0 0 320 188" class="proof-visual" aria-hidden="true">
              <line x1="88" y1="132" x2="134" y2="120" class="proof-line" />
              <line x1="88" y1="132" x2="166" y2="96" class="proof-line" />
              <line x1="88" y1="132" x2="208" y2="70" class="proof-line" />
              <line x1="134" y1="120" x2="238" y2="58" class="proof-line" />
              <line x1="166" y1="96" x2="238" y2="58" class="proof-line" />
              <line x1="208" y1="70" x2="238" y2="58" class="proof-line" />
              <line x1="98" y1="128" x2="228" y2="62" class="proof-line proof-line-suggested" />
              <circle cx="134" cy="120" r="15" class="proof-node proof-node-mediator" />
              <circle cx="166" cy="96" r="17" class="proof-node proof-node-mediator" />
              <circle cx="208" cy="70" r="15" class="proof-node proof-node-mediator proof-node-soft" />
              <ellipse cx="70" cy="136" rx="38" ry="22" class="proof-node proof-node-source" />
              <ellipse cx="250" cy="54" rx="42" ry="22" class="proof-node proof-node-target" />
              <text x="70" y="132" text-anchor="middle" class="proof-label proof-label-strong">{slide.sourceLabel}</text>
              <text x="250" y="50" text-anchor="middle" class="proof-label proof-label-strong">{slide.targetLabel}</text>
            </svg>
          )}

          {slide.visualStyle === "stack" && (
            <svg viewBox="0 0 320 188" class="proof-visual" aria-hidden="true">
              <line x1="160" y1="50" x2="124" y2="82" class="proof-line" />
              <line x1="160" y1="50" x2="196" y2="94" class="proof-line" />
              <line x1="124" y1="82" x2="160" y2="120" class="proof-line" />
              <line x1="196" y1="94" x2="160" y2="120" class="proof-line" />
              <line x1="160" y1="120" x2="160" y2="146" class="proof-line" />
              <line x1="160" y1="52" x2="160" y2="146" class="proof-line proof-line-suggested" />
              <circle cx="124" cy="82" r="15" class="proof-node proof-node-mediator proof-node-soft" />
              <circle cx="196" cy="94" r="17" class="proof-node proof-node-mediator" />
              <circle cx="160" cy="120" r="16" class="proof-node proof-node-mediator" />
              <ellipse cx="160" cy="32" rx="46" ry="20" class="proof-node proof-node-source" />
              <ellipse cx="160" cy="158" rx="46" ry="20" class="proof-node proof-node-target" />
              <text x="160" y="28" text-anchor="middle" class="proof-label proof-label-strong">{slide.sourceLabel}</text>
              <text x="160" y="154" text-anchor="middle" class="proof-label proof-label-strong">{slide.targetLabel}</text>
            </svg>
          )}

          {slide.visualStyle === "arc" && (
            <svg viewBox="0 0 320 188" class="proof-visual" aria-hidden="true">
              <path d="M84 118 Q132 48 160 52" class="proof-line" />
              <path d="M160 52 Q190 56 236 118" class="proof-line" />
              <path d="M84 118 Q160 98 236 118" class="proof-line proof-line-suggested" />
              <path d="M84 118 Q130 88 144 90" class="proof-line" />
              <path d="M176 90 Q204 90 236 118" class="proof-line" />
              <circle cx="144" cy="90" r="15" class="proof-node proof-node-mediator proof-node-soft" />
              <circle cx="160" cy="52" r="17" class="proof-node proof-node-mediator" />
              <circle cx="176" cy="90" r="15" class="proof-node proof-node-mediator proof-node-soft" />
              <ellipse cx="62" cy="122" rx="34" ry="22" class="proof-node proof-node-source" />
              <ellipse cx="258" cy="122" rx="36" ry="22" class="proof-node proof-node-target" />
              <text x="62" y="118" text-anchor="middle" class="proof-label proof-label-strong">{slide.sourceLabel}</text>
              <text x="258" y="118" text-anchor="middle" class="proof-label proof-label-strong">{slide.targetLabel}</text>
            </svg>
          )}

          <div class="proof-mediator-shell">
            <span class="tiny-label">Linking ideas</span>
            <div class="proof-mediator-row">
              {slide.mediatorLabels.map((label) => (
                <span class="proof-mediator-chip">{label}</span>
              ))}
            </div>
          </div>
        </div>

        <div class="homepage-proof-copy">
          <span class="homepage-proof-tag">Speculative question</span>
          <h3>{slide.questionTitle}</h3>
          <p class="card-copy">
            <strong>Why it might matter:</strong> {slide.why}
          </p>
          <p class="mini-copy">
            <strong>One way to start:</strong> {slide.how}
          </p>
          <div class="button-row homepage-proof-actions">
            <a class="text-link" href={slide.questionHref}>See this question</a>
            <a class="text-link" href={slide.appHref}>Inspect evidence</a>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
