---
interface Slide {
  pairKey?: string;
  diagramVariant: "candidateDebt" | "directToPath" | "candidateMonetary";
  kindLabel: string;
  questionTitle: string;
  why: string;
  detailPrefix: string;
  detail: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref: string;
  secondaryLabel: string;
}

interface Props {
  slides: Slide[];
  compact?: boolean;
}

const { slides, compact = false } = Astro.props;
const rootId = `homepage-carousel-${Math.random().toString(36).slice(2, 10)}`;
---

<section
  class:list={["hero-panel", "homepage-carousel-panel", compact && "homepage-carousel-panel-compact"]}
  data-role="homepage-carousel"
  id={rootId}
>
  <div class="homepage-carousel-heading">
    <div>
      <span class="tiny-label">Featured example</span>
    </div>
    <div class="homepage-carousel-controls" aria-label="Example controls">
      <button class="button-tertiary homepage-carousel-button" type="button" data-role="carousel-prev" aria-label="Previous example">
        <span aria-hidden="true">‹</span>
      </button>
      <button class="button-tertiary homepage-carousel-button" type="button" data-role="carousel-next" aria-label="Next example">
        <span aria-hidden="true">›</span>
      </button>
    </div>
  </div>

  <div class="homepage-carousel-slides">
    {slides.map((slide, index) => (
      <article
        class="homepage-carousel-slide"
        data-role="homepage-carousel-slide"
        data-style={slide.diagramVariant}
        data-active={index === 0 ? "true" : "false"}
        aria-hidden={index === 0 ? "false" : "true"}
        hidden={index !== 0}
      >
        <div class={`homepage-carousel-visual-shell homepage-carousel-visual-shell-${slide.diagramVariant}`} data-style={slide.diagramVariant}>
          <svg viewBox="0 0 520 320" class="homepage-carousel-visual" aria-hidden="true">
            {slide.diagramVariant === "candidateDebt" && (
              <>
                <path d="M104 160 L214 100" class="homepage-carousel-line" />
                <path d="M104 160 L214 220" class="homepage-carousel-line" />
                <path d="M242 100 L406 160" class="homepage-carousel-line" />
                <path d="M242 220 L406 160" class="homepage-carousel-line" />
                <path d="M112 152 Q258 120 396 152" class="homepage-carousel-line homepage-carousel-line-candidate" />

                <text x="258" y="48" class="homepage-carousel-legend-label">Observed path</text>
                <path d="M204 58 L316 58" class="homepage-carousel-line homepage-carousel-line-legend" />
                <text x="258" y="78" class="homepage-carousel-legend-label">Missing direct link</text>
                <path d="M204 88 L316 88" class="homepage-carousel-line homepage-carousel-line-candidate homepage-carousel-line-legend" />

                <circle cx="84" cy="160" r="34" class="homepage-carousel-node homepage-carousel-node-source" />
                <circle cx="228" cy="100" r="25" class="homepage-carousel-node homepage-carousel-node-mediator" />
                <circle cx="228" cy="220" r="25" class="homepage-carousel-node homepage-carousel-node-mediator homepage-carousel-node-soft" />
                <circle cx="428" cy="160" r="38" class="homepage-carousel-node homepage-carousel-node-target" />

                <text x="84" y="234" text-anchor="middle" class="homepage-carousel-label homepage-carousel-label-end">public debt</text>
                <text x="228" y="62" text-anchor="middle" class="homepage-carousel-label homepage-carousel-label-mediator">public investment</text>
                <text x="228" y="266" text-anchor="middle" class="homepage-carousel-label homepage-carousel-label-mediator">energy pricing</text>
                <text x="428" y="234" text-anchor="middle" class="homepage-carousel-label homepage-carousel-label-end">CO2 emissions</text>
              </>
            )}

            {slide.diagramVariant === "directToPath" && (
              <>
                <path d="M112 160 L406 160" class="homepage-carousel-line homepage-carousel-line-strong" />
                <path d="M112 160 L228 96" class="homepage-carousel-line homepage-carousel-line-later" />
                <path d="M228 96 L406 160" class="homepage-carousel-line homepage-carousel-line-later" />
                <path d="M112 160 L228 224" class="homepage-carousel-line homepage-carousel-line-later" />
                <path d="M228 224 L406 160" class="homepage-carousel-line homepage-carousel-line-later" />

                <text x="258" y="48" class="homepage-carousel-legend-label">Direct claim first</text>
                <path d="M196 58 L320 58" class="homepage-carousel-line homepage-carousel-line-strong homepage-carousel-line-legend" />
                <text x="258" y="78" class="homepage-carousel-legend-label">Mechanisms later</text>
                <path d="M196 88 L320 88" class="homepage-carousel-line homepage-carousel-line-later homepage-carousel-line-legend" />

                <circle cx="84" cy="160" r="34" class="homepage-carousel-node homepage-carousel-node-source" />
                <circle cx="228" cy="96" r="24" class="homepage-carousel-node homepage-carousel-node-mediator" />
                <circle cx="228" cy="224" r="24" class="homepage-carousel-node homepage-carousel-node-mediator homepage-carousel-node-soft" />
                <circle cx="428" cy="160" r="38" class="homepage-carousel-node homepage-carousel-node-target" />

                <text x="84" y="234" text-anchor="middle" class="homepage-carousel-label homepage-carousel-label-end">education</text>
                <text x="228" y="60" text-anchor="middle" class="homepage-carousel-label homepage-carousel-label-mediator">skill premium</text>
                <text x="228" y="268" text-anchor="middle" class="homepage-carousel-label homepage-carousel-label-mediator">labour sorting</text>
                <text x="428" y="234" text-anchor="middle" class="homepage-carousel-label homepage-carousel-label-end">wage inequality</text>
              </>
            )}

            {slide.diagramVariant === "candidateMonetary" && (
              <>
                <path d="M98 160 L208 80" class="homepage-carousel-line" />
                <path d="M98 160 L228 160" class="homepage-carousel-line" />
                <path d="M98 160 L208 240" class="homepage-carousel-line" />
                <path d="M236 80 L414 160" class="homepage-carousel-line" />
                <path d="M256 160 L414 160" class="homepage-carousel-line homepage-carousel-line-strong" />
                <path d="M236 240 L414 160" class="homepage-carousel-line" />
                <path d="M104 152 Q254 108 400 152" class="homepage-carousel-line homepage-carousel-line-candidate" />

                <text x="258" y="48" class="homepage-carousel-legend-label">Three nearby channels</text>
                <path d="M200 58 L316 58" class="homepage-carousel-line homepage-carousel-line-legend" />
                <text x="258" y="78" class="homepage-carousel-legend-label">Candidate direct question</text>
                <path d="M200 88 L316 88" class="homepage-carousel-line homepage-carousel-line-candidate homepage-carousel-line-legend" />

                <circle cx="78" cy="160" r="32" class="homepage-carousel-node homepage-carousel-node-source" />
                <circle cx="222" cy="80" r="22" class="homepage-carousel-node homepage-carousel-node-mediator homepage-carousel-node-soft" />
                <circle cx="242" cy="160" r="24" class="homepage-carousel-node homepage-carousel-node-mediator" />
                <circle cx="222" cy="240" r="22" class="homepage-carousel-node homepage-carousel-node-mediator homepage-carousel-node-soft" />
                <circle cx="434" cy="160" r="38" class="homepage-carousel-node homepage-carousel-node-target" />

                <text x="78" y="232" text-anchor="middle" class="homepage-carousel-label homepage-carousel-label-end">monetary policy</text>
                <text x="222" y="42" text-anchor="middle" class="homepage-carousel-label homepage-carousel-label-mediator">durables demand</text>
                <text x="242" y="202" text-anchor="middle" class="homepage-carousel-label homepage-carousel-label-mediator">construction</text>
                <text x="222" y="286" text-anchor="middle" class="homepage-carousel-label homepage-carousel-label-mediator">industrial borrowing</text>
                <text x="434" y="232" text-anchor="middle" class="homepage-carousel-label homepage-carousel-label-end">energy consumption</text>
              </>
            )}
          </svg>
        </div>

        <div class="homepage-carousel-copy" data-style={slide.diagramVariant}>
          <span class="homepage-carousel-tag">{slide.kindLabel}</span>
          <h3>{slide.questionTitle}</h3>
          <p class="card-copy">{slide.why}</p>
          <p class="mini-copy">
            <strong>{slide.detailPrefix}</strong> {slide.detail}
          </p>
          <div class="button-row homepage-carousel-actions">
            <a class="text-link" href={slide.primaryHref}>{slide.primaryLabel}</a>
            <a class="text-link" href={slide.secondaryHref}>{slide.secondaryLabel}</a>
          </div>
        </div>
      </article>
    ))}
  </div>

  <div class="homepage-carousel-dots" role="tablist" aria-label="Example questions">
    {slides.map((slide, index) => (
      <button
        class="homepage-carousel-dot"
        type="button"
        role="tab"
        aria-selected={index === 0 ? "true" : "false"}
        aria-label={`Show example ${index + 1}: ${slide.questionTitle}`}
        data-role="carousel-dot"
        data-index={String(index)}
      />
    ))}
  </div>
</section>

<script is:inline define:vars={{ rootId }} type="module">
  const root = document.getElementById(rootId);
  if (!(root instanceof HTMLElement)) throw new Error("Homepage carousel root missing");

  const slides = Array.from(root.querySelectorAll('[data-role="homepage-carousel-slide"]'));
  const dots = Array.from(root.querySelectorAll('[data-role="carousel-dot"]'));
  const prev = root.querySelector('[data-role="carousel-prev"]');
  const next = root.querySelector('[data-role="carousel-next"]');
  let activeIndex = slides.findIndex((slide) => slide.getAttribute("data-active") === "true");
  if (activeIndex < 0) activeIndex = 0;
  let timer;

  const render = () => {
    slides.forEach((slide, index) => {
      const isActive = index === activeIndex;
      slide.setAttribute("data-active", String(isActive));
      slide.setAttribute("aria-hidden", String(!isActive));
      slide.toggleAttribute("hidden", !isActive);
    });
    dots.forEach((dot, index) => {
      dot.setAttribute("aria-selected", String(index === activeIndex));
      dot.classList.toggle("is-active", index === activeIndex);
    });
  };

  const stopTimer = () => {
    if (timer) {
      window.clearInterval(timer);
      timer = undefined;
    }
  };

  const startTimer = () => {
    stopTimer();
    timer = window.setInterval(() => {
      activeIndex = (activeIndex + 1) % slides.length;
      render();
    }, 7000);
  };

  prev?.addEventListener("click", () => {
    activeIndex = (activeIndex - 1 + slides.length) % slides.length;
    render();
    startTimer();
  });
  next?.addEventListener("click", () => {
    activeIndex = (activeIndex + 1) % slides.length;
    render();
    startTimer();
  });
  dots.forEach((dot, index) => {
    dot.addEventListener("click", () => {
      activeIndex = index;
      render();
      startTimer();
    });
  });

  root.addEventListener("mouseenter", stopTimer);
  root.addEventListener("mouseleave", startTimer);
  root.addEventListener("focusin", stopTimer);
  root.addEventListener("focusout", startTimer);

  render();
  if (slides.length > 1) startTimer();
</script>
