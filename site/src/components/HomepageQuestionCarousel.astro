---
interface Slide {
  pairKey: string;
  visualStyle: "bridge" | "fan" | "stack" | "arc";
  questionTitle: string;
  sourceLabel: string;
  targetLabel: string;
  mediatorLabels: string[];
  why: string;
  how: string;
  questionHref: string;
  appHref: string;
}

interface Props {
  slides: Slide[];
}

const { slides } = Astro.props;
const rootId = `homepage-carousel-${Math.random().toString(36).slice(2, 10)}`;

const splitNodeLabel = (label: string) => {
  const words = label.split(" ").filter(Boolean);
  if (words.length <= 2) return [label];
  const midpoint = Math.ceil(words.length / 2);
  return [words.slice(0, midpoint).join(" "), words.slice(midpoint).join(" ")];
};
---

<section class="hero-panel homepage-carousel-panel" data-role="homepage-carousel" id={rootId}>
  <div class="homepage-carousel-heading">
    <div>
      <span class="eyebrow">A few speculative questions</span>
      <h2>What this looks like in practice</h2>
      <p class="mini-copy homepage-carousel-note">
        These are speculative research suggestions. The point is to show the kind of question that may be worth reading
        or testing next, not to claim that the link is already established.
      </p>
    </div>
    <div class="homepage-carousel-controls" aria-label="Example controls">
      <button class="button-tertiary homepage-carousel-button" type="button" data-role="carousel-prev" aria-label="Previous example">
        <span aria-hidden="true">‹</span>
      </button>
      <button class="button-tertiary homepage-carousel-button" type="button" data-role="carousel-next" aria-label="Next example">
        <span aria-hidden="true">›</span>
      </button>
    </div>
  </div>

  <div class="homepage-carousel-slides">
    {slides.map((slide, index) => (
      <article
        class="homepage-carousel-slide"
        data-role="homepage-carousel-slide"
        data-style={slide.visualStyle}
        data-active={index === 0 ? "true" : "false"}
        aria-hidden={index === 0 ? "false" : "true"}
        hidden={index !== 0}
      >
        <div class={`homepage-carousel-visual-shell homepage-carousel-visual-shell-${slide.visualStyle}`} data-style={slide.visualStyle}>
          <svg viewBox="0 0 420 252" class="homepage-carousel-visual" aria-hidden="true">
            <line x1="120" y1="126" x2="300" y2="126" class="homepage-carousel-line homepage-carousel-line-suggested" />
            <line x1="118" y1="126" x2="182" y2="78" class="homepage-carousel-line" />
            <line x1="182" y1="78" x2="302" y2="126" class="homepage-carousel-line" />
            <line x1="118" y1="126" x2="222" y2="126" class="homepage-carousel-line homepage-carousel-line-strong" />
            <line x1="222" y1="126" x2="302" y2="126" class="homepage-carousel-line homepage-carousel-line-strong" />
            <line x1="118" y1="126" x2="182" y2="174" class="homepage-carousel-line" />
            <line x1="182" y1="174" x2="302" y2="126" class="homepage-carousel-line" />
            <circle cx="182" cy="78" r="17" class="homepage-carousel-node homepage-carousel-node-mediator homepage-carousel-node-soft" />
            <circle cx="222" cy="126" r="19" class="homepage-carousel-node homepage-carousel-node-mediator" />
            <circle cx="182" cy="174" r="17" class="homepage-carousel-node homepage-carousel-node-mediator homepage-carousel-node-soft" />
            <ellipse cx="78" cy="126" rx="42" ry="28" class="homepage-carousel-node homepage-carousel-node-source" />
            <ellipse cx="344" cy="126" rx="48" ry="28" class="homepage-carousel-node homepage-carousel-node-target" />
            <text x="78" y="121" text-anchor="middle" class="homepage-carousel-label homepage-carousel-label-strong">
              {splitNodeLabel(slide.sourceLabel).map((line, lineIndex) => (
                <tspan x="78" dy={lineIndex === 0 ? 0 : 13}>{line}</tspan>
              ))}
            </text>
            <text x="344" y="121" text-anchor="middle" class="homepage-carousel-label homepage-carousel-label-strong">
              {splitNodeLabel(slide.targetLabel).map((line, lineIndex) => (
                <tspan x="344" dy={lineIndex === 0 ? 0 : 13}>{line}</tspan>
              ))}
            </text>
          </svg>

          <div class="homepage-carousel-mediator-shell">
            <span class="tiny-label">Linking ideas</span>
            <div class="homepage-carousel-mediator-row">
              {slide.mediatorLabels.map((label) => (
                <span class="homepage-carousel-mediator-chip">{label}</span>
              ))}
            </div>
          </div>
        </div>

        <div class="homepage-carousel-copy" data-style={slide.visualStyle}>
          <span class="homepage-carousel-tag">Speculative question</span>
          <h3>{slide.questionTitle}</h3>
          <p class="card-copy">
            <strong>Why it might matter:</strong> {slide.why}
          </p>
          <p class="mini-copy">
            <strong>One way to start:</strong> {slide.how}
          </p>
          <div class="button-row homepage-carousel-actions">
            <a class="text-link" href={slide.questionHref}>See this question</a>
            <a class="text-link" href={slide.appHref}>Inspect evidence</a>
          </div>
        </div>
      </article>
    ))}
  </div>

  <div class="homepage-carousel-dots" role="tablist" aria-label="Example questions">
    {slides.map((slide, index) => (
      <button
        class="homepage-carousel-dot"
        type="button"
        role="tab"
        aria-selected={index === 0 ? "true" : "false"}
        aria-label={`Show example ${index + 1}: ${slide.questionTitle}`}
        data-role="carousel-dot"
        data-index={String(index)}
      />
    ))}
  </div>
</section>

<script is:inline define:vars={{ rootId }} type="module">
  const root = document.getElementById(rootId);
  if (!(root instanceof HTMLElement)) throw new Error("Homepage carousel root missing");

  const slides = Array.from(root.querySelectorAll('[data-role="homepage-carousel-slide"]'));
  const dots = Array.from(root.querySelectorAll('[data-role="carousel-dot"]'));
  const prev = root.querySelector('[data-role="carousel-prev"]');
  const next = root.querySelector('[data-role="carousel-next"]');
  let activeIndex = slides.findIndex((slide) => slide.getAttribute("data-active") === "true");
  if (activeIndex < 0) activeIndex = 0;
  let timer;

  const render = () => {
    slides.forEach((slide, index) => {
      const isActive = index === activeIndex;
      slide.setAttribute("data-active", String(isActive));
      slide.setAttribute("aria-hidden", String(!isActive));
      slide.toggleAttribute("hidden", !isActive);
    });
    dots.forEach((dot, index) => {
      dot.setAttribute("aria-selected", String(index === activeIndex));
      dot.classList.toggle("is-active", index === activeIndex);
    });
  };

  const stopTimer = () => {
    if (timer) {
      window.clearInterval(timer);
      timer = undefined;
    }
  };

  const startTimer = () => {
    stopTimer();
    timer = window.setInterval(() => {
      activeIndex = (activeIndex + 1) % slides.length;
      render();
    }, 7000);
  };

  prev?.addEventListener("click", () => {
    activeIndex = (activeIndex - 1 + slides.length) % slides.length;
    render();
    startTimer();
  });
  next?.addEventListener("click", () => {
    activeIndex = (activeIndex + 1) % slides.length;
    render();
    startTimer();
  });
  dots.forEach((dot, index) => {
    dot.addEventListener("click", () => {
      activeIndex = index;
      render();
      startTimer();
    });
  });

  root.addEventListener("mouseenter", stopTimer);
  root.addEventListener("mouseleave", startTimer);
  root.addEventListener("focusin", stopTimer);
  root.addEventListener("focusout", startTimer);

  render();
  startTimer();
</script>
