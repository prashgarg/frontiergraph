---
interface Props {
  graphPath: string;
  conceptIndexPath: string;
  neighborhoodsIndexPath: string;
  opportunitiesIndexPath: string;
  centralConceptsPath: string;
}

const {
  graphPath,
  conceptIndexPath,
  neighborhoodsIndexPath,
  opportunitiesIndexPath,
  centralConceptsPath,
} = Astro.props;

const rootId = `graph-workbench-${Math.random().toString(36).slice(2, 10)}`;
---

<section
  id={rootId}
  class="graph-workbench"
  data-graph-path={graphPath}
  data-concept-index-path={conceptIndexPath}
  data-neighborhoods-index-path={neighborhoodsIndexPath}
  data-opportunities-index-path={opportunitiesIndexPath}
  data-central-concepts-path={centralConceptsPath}
>
  <div class="graph-toolbar">
    <div>
      <h2>Start with one topic.</h2>
      <p class="card-copy">
        Search for a topic, read the nearby neighborhood, and widen to the full map only when you need more context.
      </p>
    </div>
    <label class="search-shell">
      <span>Search topic</span>
      <input type="search" placeholder="Search labels or aliases" data-role="search-input" />
      <div class="search-results" data-role="search-results"></div>
    </label>
  </div>

  <div class="graph-jumpbar">
    <span class="tiny-label">Starting topics</span>
    <div class="central-list central-list-inline" data-role="central-list"></div>
  </div>

  <div class="graph-stage">
    <div class="graph-panel graph-panel-secondary">
      <div class="graph-controls">
        <div class="graph-status-shell">
          <div class="graph-status" data-role="hover-card" aria-live="polite">
            Search or click a topic. Start with the local neighborhood, then widen only when you need the full map.
          </div>
        </div>
        <div class="graph-control-row">
          <button class="button-secondary" type="button" data-role="toggle-map-mode">Show full map</button>
          <button class="button-tertiary" type="button" data-role="reset-view">Reset view</button>
        </div>
      </div>
      <svg class="graph-canvas" data-role="graph-canvas" viewBox="0 0 1120 860" aria-label="Literature map"></svg>
      <div class="graph-help-row">
        <span class="mini-copy">Wheel or pinch to zoom. Drag the background to pan. Reset view returns to the default local frame.</span>
      </div>
    </div>

    <aside class="graph-inspector">
      <section class="sidebar-card inspector-card">
        <div class="inspector-head">
          <h3>Selected topic</h3>
        </div>
        <div data-role="selected-concept">
          <p class="card-copy">
            Select a topic to turn the map into a local reading. The summary stays here while nearby topics and questions update below.
          </p>
        </div>
        <details class="inspector-detail" open>
          <summary>Nearby topics</summary>
          <div data-role="selected-neighborhood">
            <p class="card-copy">Incoming, outgoing, and nearby summaries will appear here.</p>
          </div>
        </details>
        <details class="inspector-detail" open>
          <summary>Why it matters</summary>
          <div data-role="selection-list-view">
            <p class="card-copy">A short reading summary of the current topic will appear here.</p>
          </div>
        </details>
        <details class="inspector-detail">
          <summary>Questions touching this topic</summary>
          <div data-role="selected-opportunities">
            <p class="card-copy">The strongest released questions touching the selected topic will appear here.</p>
          </div>
        </details>
      </section>
    </aside>
  </div>
</section>

<script is:inline define:vars={{ rootId }} type="module">
  const root = document.getElementById(rootId);
  if (!(root instanceof HTMLElement)) throw new Error("Graph workbench root missing");

  const GRAPH_WIDTH = 1120;
  const GRAPH_HEIGHT = 860;
  const MIN_SCALE = 0.55;
  const MAX_SCALE = 4;
  const FOCUSED_NEIGHBOR_LIMIT = 8;
  const FOCUSED_LABEL_LIMIT = 4;
  const LAYOUT_MIN_X = -0.24;
  const LAYOUT_MAX_X = 1.24;
  const LAYOUT_MIN_Y = -0.2;
  const LAYOUT_MAX_Y = 1.2;
  const PREFERRED_DEFAULT_LABELS = ["public debt", "inflation", "monetary policy", "education", "economic growth"];

  const graphPath = root.dataset.graphPath;
  const conceptIndexPath = root.dataset.conceptIndexPath;
  const neighborhoodsIndexPath = root.dataset.neighborhoodsIndexPath;
  const opportunitiesIndexPath = root.dataset.opportunitiesIndexPath;
  const centralConceptsPath = root.dataset.centralConceptsPath;

  const searchInput = root.querySelector('[data-role="search-input"]');
  const searchResults = root.querySelector('[data-role="search-results"]');
  const hoverCard = root.querySelector('[data-role="hover-card"]');
  const canvas = root.querySelector('[data-role="graph-canvas"]');
  const selectedConcept = root.querySelector('[data-role="selected-concept"]');
  const selectedNeighborhood = root.querySelector('[data-role="selected-neighborhood"]');
  const selectionListView = root.querySelector('[data-role="selection-list-view"]');
  const selectedOpportunities = root.querySelector('[data-role="selected-opportunities"]');
  const centralList = root.querySelector('[data-role="central-list"]');
  const resetView = root.querySelector('[data-role="reset-view"]');
  const toggleMapMode = root.querySelector('[data-role="toggle-map-mode"]');

  const shardCache = new Map();
  let selectedId = null;
  let defaultConceptId = null;
  let graph = null;
  let concepts = [];
  let conceptMap = new Map();
  let neighborhoodIndex = {};
  let opportunitiesIndex = {};
  let centralConcepts = [];
  let currentNeighborhood = null;
  let currentOpportunities = [];
  let layoutMode = false;
  let mapMode = "focused";
  let interaction = null;
  let viewState = { scale: 1, translateX: 0, translateY: 0 };

  const escapeHtml = (value) =>
    String(value)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");

  const formatNumber = (value) => new Intl.NumberFormat("en-US").format(value);
  const safeNumber = (value) => {
    const numeric = Number(value);
    return Number.isFinite(numeric) ? numeric : 0;
  };
  const listText = (values, fallback) => {
    const cleaned = Array.isArray(values)
      ? values
          .map((value) => {
            if (typeof value === "string") return value;
            if (value && typeof value === "object" && "value" in value) return value.value;
            return "";
          })
          .filter((value) => {
            const normalized = String(value ?? "").trim().toLowerCase();
            return normalized && !["na", "n/a", "nan", "null", "undefined", "none"].includes(normalized);
          })
      : [];
    return cleaned.length ? cleaned.join(", ") : fallback;
  };
  const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
  const isInBackbone = (conceptId) => Boolean(graph?.nodeMap?.has(conceptId));
  const conceptTitle = (concept) => concept?.plain_label || concept?.label || "";
  const conceptSubtitle = (concept) => {
    const value = String(concept?.subtitle ?? "").trim();
    return value && !["na", "n/a", "nan", "null", "undefined", "none"].includes(value.toLowerCase()) ? value : "";
  };
  const conceptLabelNote = (conceptId) => {
    const concept = conceptMap.get(conceptId);
    if (!concept) return "";
    const subtitle = conceptSubtitle(concept);
    return subtitle ? `${conceptTitle(concept)}: ${subtitle}.` : "";
  };

  const fetchJson = async (path) => {
    if (shardCache.has(path)) return shardCache.get(path);
    const response = await fetch(path);
    const payload = await response.json();
    shardCache.set(path, payload);
    return payload;
  };

  const updateLayoutModeButton = () => {
    return;
  };

  const updateMapModeButton = () => {
    if (!(toggleMapMode instanceof HTMLButtonElement)) return;
    const fullMap = mapMode === "global";
    toggleMapMode.textContent = fullMap ? "Return to focused view" : "Show full map";
    toggleMapMode.classList.toggle("is-active", fullMap);
  };

  const setViewportTransform = () => {
    const viewport = canvas?.querySelector('[data-role="graph-viewport"]');
    if (!(viewport instanceof SVGGElement)) return;
    viewport.setAttribute(
      "transform",
      `translate(${viewState.translateX} ${viewState.translateY}) scale(${viewState.scale})`,
    );
  };

  const screenToCanvasPoint = (clientX, clientY) => {
    const rect = canvas.getBoundingClientRect();
    const x = ((clientX - rect.left) / rect.width) * GRAPH_WIDTH;
    const y = ((clientY - rect.top) / rect.height) * GRAPH_HEIGHT;
    return {
      x,
      y,
      graphX: (x - viewState.translateX) / viewState.scale,
      graphY: (y - viewState.translateY) / viewState.scale,
    };
  };

  const zoomAtPoint = (factor, clientX, clientY) => {
    const { x, y, graphX, graphY } = screenToCanvasPoint(clientX, clientY);
    const nextScale = clamp(viewState.scale * factor, MIN_SCALE, MAX_SCALE);
    viewState = {
      scale: nextScale,
      translateX: x - graphX * nextScale,
      translateY: y - graphY * nextScale,
    };
    setViewportTransform();
  };

  const resetViewport = () => {
    viewState = { scale: 1, translateX: 0, translateY: 0 };
    setViewportTransform();
  };

  const getFocusedNeighborIds = (conceptId) => {
    if (!graph || !conceptId || !isInBackbone(conceptId)) return [];
    const touchingEdges = graph.edges
      .filter((edge) => edge.source === conceptId || edge.target === conceptId)
      .sort((left, right) => safeNumber(right.support_count) - safeNumber(left.support_count));
    const neighborIds = [];
    const seen = new Set([conceptId]);
    for (const edge of touchingEdges) {
      const otherId = edge.source === conceptId ? edge.target : edge.source;
      if (seen.has(otherId)) continue;
      seen.add(otherId);
      neighborIds.push(otherId);
      if (neighborIds.length >= FOCUSED_NEIGHBOR_LIMIT) break;
    }
    return neighborIds;
  };

  const getVisibleGraphState = () => {
    const selectedActive = Boolean(selectedId) && isInBackbone(selectedId);
    const allNeighbors = new Set();

    if (selectedActive) {
      for (const edge of graph.edges) {
        if (edge.source === selectedId) allNeighbors.add(edge.target);
        if (edge.target === selectedId) allNeighbors.add(edge.source);
      }
    }

    if (mapMode === "global" || !selectedActive) {
      return {
        focusedActive: false,
        nodes: graph.nodes,
        edges: graph.edges,
        selectedNeighbors: allNeighbors,
        labelNeighbors: new Set(),
      };
    }

    const focusedNeighborIds = getFocusedNeighborIds(selectedId);
    const visibleIds = new Set([selectedId, ...focusedNeighborIds]);
    const visibleEdges = graph.edges.filter((edge) => visibleIds.has(edge.source) && visibleIds.has(edge.target));
    const visibleNodes = graph.nodes.filter((node) => visibleIds.has(node.id));
    return {
      focusedActive: true,
      nodes: visibleNodes,
      edges: visibleEdges,
      selectedNeighbors: new Set(focusedNeighborIds),
      labelNeighbors: new Set(focusedNeighborIds.slice(0, FOCUSED_LABEL_LIMIT)),
    };
  };

  const fitViewToNodeIds = (nodeIds) => {
    if (!graph || !nodeIds.length) {
      resetViewport();
      return;
    }
    const nodes = nodeIds
      .map((nodeId) => graph.nodeMap.get(nodeId))
      .filter(Boolean);
    if (!nodes.length) {
      resetViewport();
      return;
    }
    const xs = nodes.map((node) => node.x * GRAPH_WIDTH);
    const ys = nodes.map((node) => node.y * GRAPH_HEIGHT);
    const minX = Math.min(...xs);
    const maxX = Math.max(...xs);
    const minY = Math.min(...ys);
    const maxY = Math.max(...ys);
    const padding = 120;
    const spanX = Math.max(maxX - minX, 150);
    const spanY = Math.max(maxY - minY, 150);
    const nextScale = clamp(
      Math.min((GRAPH_WIDTH - padding * 2) / spanX, (GRAPH_HEIGHT - padding * 2) / spanY),
      MIN_SCALE,
      MAX_SCALE,
    );
    const centerX = (minX + maxX) / 2;
    const centerY = (minY + maxY) / 2;
    viewState = {
      scale: nextScale,
      translateX: GRAPH_WIDTH / 2 - centerX * nextScale,
      translateY: GRAPH_HEIGHT / 2 - centerY * nextScale,
    };
    setViewportTransform();
  };

  const startPan = (eventTarget, clientX, clientY) => {
    if (eventTarget instanceof Element && eventTarget.closest("[data-node-id]")) return;
    interaction = {
      type: "pan",
      startX: clientX,
      startY: clientY,
      translateX: viewState.translateX,
      translateY: viewState.translateY,
    };
  };

  const startNodeDrag = (nodeId) => {
    interaction = {
      type: "drag-node",
      nodeId,
    };
  };

  const moveInteraction = (clientX, clientY) => {
    if (!interaction || !graph) return;
    if (interaction.type === "pan") {
      viewState = {
        ...viewState,
        translateX: interaction.translateX + (clientX - interaction.startX),
        translateY: interaction.translateY + (clientY - interaction.startY),
      };
      setViewportTransform();
      return;
    }
    if (interaction.type === "drag-node" && interaction.nodeId && layoutMode) {
      const point = screenToCanvasPoint(clientX, clientY);
      const node = graph.nodeMap.get(interaction.nodeId);
      if (!node) return;
      node.x = clamp(point.graphX / GRAPH_WIDTH, LAYOUT_MIN_X, LAYOUT_MAX_X);
      node.y = clamp(point.graphY / GRAPH_HEIGHT, LAYOUT_MIN_Y, LAYOUT_MAX_Y);
      renderGraph();
      restoreStatus();
    }
  };

  const focusViewOnConcept = (conceptId) => {
    if (!isInBackbone(conceptId)) return;
    const node = graph.nodeMap.get(conceptId);
    const nextScale = Math.max(viewState.scale, 1.15);
    viewState = {
      scale: nextScale,
      translateX: GRAPH_WIDTH / 2 - node.x * GRAPH_WIDTH * nextScale,
      translateY: GRAPH_HEIGHT / 2 - node.y * GRAPH_HEIGHT * nextScale,
    };
    setViewportTransform();
  };

  const setDefaultViewport = () => {
    if (!graph) return;
    if (mapMode === "focused" && selectedId && isInBackbone(selectedId)) {
      const visibleState = getVisibleGraphState();
      fitViewToNodeIds(visibleState.nodes.map((node) => node.id));
      return;
    }
    resetViewport();
  };

  const restoreStatus = () => {
    if (!hoverCard) return;
    if (selectedId) {
      const concept = conceptMap.get(selectedId);
      if (concept) {
        const visibilityCopy = isInBackbone(selectedId)
          ? mapMode === "focused"
            ? "Focused topic view."
            : "Visible in the full literature map."
          : "Outside the public map snapshot, but still available in search and summary views.";
        hoverCard.innerHTML = `
          <strong>${escapeHtml(conceptTitle(concept))}</strong><br />
          ${conceptSubtitle(concept) ? `${escapeHtml(conceptSubtitle(concept))}<br />` : ""}
          ${formatNumber(safeNumber(concept.distinct_paper_support))} papers · ${formatNumber(safeNumber(concept.instance_support))} node instances · ${formatNumber(safeNumber(concept.neighbor_count))} nearby concepts · ${escapeHtml(visibilityCopy)}
        `;
        return;
      }
    }
    hoverCard.textContent = "Search or click a topic. Start with the local neighborhood, then widen only when you need the full map.";
  };

  const renderCentralList = () => {
    centralList.innerHTML = centralConcepts
      .slice(0, 6)
      .map(
        (concept) => `
          <button class="list-link" data-concept-id="${escapeHtml(concept.concept_id)}">
            <span>${escapeHtml(conceptTitle(concept))}</span>
            <span>${formatNumber(safeNumber(concept.distinct_paper_support))} papers</span>
          </button>
        `,
      )
      .join("");
    for (const button of centralList.querySelectorAll("[data-concept-id]")) {
      button.addEventListener("click", () => selectConcept(button.dataset.conceptId));
    }
  };

  const renderListView = () => {
    const concept = selectedId ? conceptMap.get(selectedId) : null;
    if (!concept) {
      selectionListView.innerHTML = `<p class="card-copy">A short reading summary of the current topic will appear here.</p>`;
      return;
    }
    const topNeighbors = (currentNeighborhood?.top_neighbors || []).slice(0, 5);
    const nearbyOpportunities = currentOpportunities.slice(0, 3);
    selectionListView.innerHTML = `
      <div class="neighbor-group">
        <h4>Why it matters</h4>
        <p class="card-copy">
          ${escapeHtml(conceptTitle(concept))} has ${formatNumber(safeNumber(concept.in_degree))} incoming observed links,
          ${formatNumber(safeNumber(concept.out_degree))} outgoing observed links,
          and ${formatNumber(safeNumber(concept.neighbor_count))} nearby concepts in the current public map.
        </p>
      </div>
      <div class="neighbor-group">
        <h4>Read next</h4>
        <div class="selection-button-stack">
          ${topNeighbors.length
            ? topNeighbors
                .map(
                  (item) => `
                    <button class="list-link list-link-tight" type="button" data-neighbor-id="${escapeHtml(item.concept_id)}">
                      <span>${escapeHtml(conceptTitle(conceptMap.get(item.concept_id)) || item.label)}</span>
                      <span>${formatNumber(safeNumber(item.support_count))} papers</span>
                    </button>
                  `,
                )
                .join("")
            : `<p class="mini-copy">No nearby topic summary is available in the current public sample.</p>`}
        </div>
      </div>
      <div class="neighbor-group">
        <h4>Questions touching this topic</h4>
        <div class="selection-opportunity-stack">
          ${nearbyOpportunities.length
            ? nearbyOpportunities
                .map(
                  (item) => `
                    <article class="mini-opportunity">
                      <strong>${escapeHtml(item.public_pair_label)}</strong>
                      ${conceptLabelNote(item.source_id) || conceptLabelNote(item.target_id) ? `<div class="mini-copy opportunity-label-note">${escapeHtml([conceptLabelNote(item.source_id), conceptLabelNote(item.target_id)].filter(Boolean).join(" "))}</div>` : ""}
                      <div class="mini-copy">${escapeHtml(item.direct_link_status)} · ${formatNumber(safeNumber(item.supporting_path_count))} nearby linking concepts in the released graph</div>
                    </article>
                `,
                )
                .join("")
            : `<p class="mini-copy">No public research question touching this topic is available in the current sample.</p>`}
        </div>
      </div>
    `;
    for (const button of selectionListView.querySelectorAll("[data-neighbor-id]")) {
      button.addEventListener("click", () => selectConcept(button.dataset.neighborId));
    }
  };

  const renderGraph = () => {
    const nodeMarkup = [];
    const edgeMarkup = [];
    const visibleState = getVisibleGraphState();
    const selectedActive = Boolean(selectedId) && isInBackbone(selectedId);
    const { focusedActive, nodes: visibleNodes, edges: visibleEdges, selectedNeighbors, labelNeighbors } = visibleState;

    for (const edge of visibleEdges) {
      const source = graph.nodeMap.get(edge.source);
      const target = graph.nodeMap.get(edge.target);
      const isSelected = selectedActive && (edge.source === selectedId || edge.target === selectedId);
      const isDimmed = mapMode === "global" && selectedActive && !isSelected;
      edgeMarkup.push(
        `<line class="graph-edge${isSelected ? " is-selected" : ""}${isDimmed ? " is-dimmed" : ""}" style="--edge-strength:${edge.strength || 0.3};" data-edge-id="${escapeHtml(edge.id)}" x1="${source.x * GRAPH_WIDTH}" y1="${source.y * GRAPH_HEIGHT}" x2="${target.x * GRAPH_WIDTH}" y2="${target.y * GRAPH_HEIGHT}"></line>`,
      );
    }

    for (const node of visibleNodes) {
      const isSelected = node.id === selectedId;
      const isNeighbor = selectedNeighbors.has(node.id);
      const isDimmed = mapMode === "global" && selectedActive && !isSelected && !isNeighbor;
      const radius = Math.max(2.8, Math.min(24, 2.8 + Math.log10(safeNumber(node.weighted_degree) + 1) * 4.4));
      const showLabel = focusedActive
        ? isSelected || labelNeighbors.has(node.id)
        : node.show_label ||
          isSelected ||
          (isNeighbor && selectedNeighbors.size <= FOCUSED_NEIGHBOR_LIMIT) ||
          (isNeighbor && safeNumber(node.weighted_degree) >= 65);
      const labelY = node.y * GRAPH_HEIGHT - (radius + (isSelected ? 16 : 8));
      nodeMarkup.push(
        `<g class="graph-node-group${isSelected ? " is-selected" : ""}${isNeighbor ? " is-neighbor" : ""}${isDimmed ? " is-dimmed" : ""}" data-node-id="${escapeHtml(node.id)}">
          <circle class="graph-node bucket-${escapeHtml(node.bucket_group || "mixed")}" cx="${node.x * GRAPH_WIDTH}" cy="${node.y * GRAPH_HEIGHT}" r="${radius}"></circle>
          ${showLabel ? `<text class="graph-label${isSelected ? " is-selected" : ""}${isNeighbor ? " is-neighbor" : ""}" x="${node.x * GRAPH_WIDTH}" y="${labelY}">${escapeHtml(node.plain_label || node.label)}</text>` : ""}
        </g>`,
      );
    }

    canvas.innerHTML = `
      <g data-role="graph-viewport">
        <rect class="graph-pan-target" x="-900" y="-900" width="3200" height="2800"></rect>
        <g class="graph-edge-layer">${edgeMarkup.join("")}</g>
        <g class="graph-node-layer">${nodeMarkup.join("")}</g>
      </g>
    `;

    for (const nodeElement of canvas.querySelectorAll("[data-node-id]")) {
      const dragHandle = nodeElement.querySelector("circle");
      nodeElement.addEventListener("mouseenter", () => {
        const node = graph.nodeMap.get(nodeElement.dataset.nodeId);
        hoverCard.innerHTML = `
          <strong>${escapeHtml(node.plain_label || node.label)}</strong><br />
          ${node.subtitle ? `${escapeHtml(node.subtitle)}<br />` : ""}
          ${formatNumber(safeNumber(node.distinct_paper_support))} papers · ${formatNumber(safeNumber(node.instance_support))} mapped node mentions · ${formatNumber(safeNumber(node.neighbor_count))} nearby concepts · ${escapeHtml(listText(node.top_countries, "No dominant study setting in the current public sample"))}
        `;
      });
      nodeElement.addEventListener("mouseleave", restoreStatus);
      const beginDrag = (event) => {
        if (!layoutMode) return;
        event.preventDefault();
        event.stopPropagation();
        startNodeDrag(nodeElement.dataset.nodeId);
      };
      dragHandle?.addEventListener("pointerdown", beginDrag);
      dragHandle?.addEventListener("mousedown", beginDrag);
      nodeElement.addEventListener("click", (event) => {
        event.stopPropagation();
        if (layoutMode) return;
        selectConcept(nodeElement.dataset.nodeId);
      });
    }

    for (const edgeElement of canvas.querySelectorAll("[data-edge-id]")) {
      edgeElement.addEventListener("mouseenter", () => {
        const edge = graph.edgeMap.get(edgeElement.dataset.edgeId);
        hoverCard.innerHTML = `
          <strong>${escapeHtml(graph.nodeMap.get(edge.source).label)} to ${escapeHtml(graph.nodeMap.get(edge.target).label)}</strong><br />
          ${formatNumber(safeNumber(edge.support_count))} papers · ${escapeHtml(listText(edge.dominant_countries, "No dominant study setting in the current public sample"))}
        `;
      });
      edgeElement.addEventListener("mouseleave", restoreStatus);
    }

    setViewportTransform();
  };

  const renderSelectedConcept = (concept) => {
    const visibilityCopy = isInBackbone(concept.concept_id)
      ? "Visible in the current map view."
      : "Not drawn in the current snapshot, but still available in search and local detail.";
    selectedConcept.innerHTML = `
      <span class="eyebrow">Selected topic</span>
      <div class="selected-title-row">
        <h4>${escapeHtml(conceptTitle(concept))}</h4>
      </div>
      ${conceptSubtitle(concept) ? `<p class="mini-copy opportunity-label-note">${escapeHtml(conceptSubtitle(concept))}</p>` : ""}
      <p class="card-copy">${formatNumber(safeNumber(concept.distinct_paper_support))} papers, ${formatNumber(safeNumber(concept.instance_support))} mapped node mentions, and ${formatNumber(safeNumber(concept.neighbor_count))} nearby concepts in the released map.</p>
      <div class="pill-row inspector-pills">
        <span class="field-pill">${formatNumber(safeNumber(concept.in_degree))} incoming observed links</span>
        <span class="field-pill">${formatNumber(safeNumber(concept.out_degree))} outgoing observed links</span>
      </div>
      <p class="mini-copy"><strong>Why it matters:</strong> ${escapeHtml(listText((concept.top_countries || []).slice(0, 3), "No dominant study setting in the current public sample"))}</p>
      <p class="mini-copy">${escapeHtml(visibilityCopy)}</p>
      <div class="button-row">
        <a class="button-secondary" href="${escapeHtml(concept.app_link)}">Explore in app</a>
      </div>
    `;
  };

  const renderNeighborhood = async (conceptId) => {
    currentNeighborhood = null;
    const shardPath = neighborhoodIndex[conceptId];
    if (!shardPath) {
      selectedNeighborhood.innerHTML = `<p class="card-copy">No precomputed surrounding-literature summary is available for this topic in the current public sample.</p>`;
      renderListView();
      return;
    }
    const shard = await fetchJson(shardPath);
    const neighborhood = shard[conceptId];
    currentNeighborhood = neighborhood || null;
    if (!neighborhood) {
      selectedNeighborhood.innerHTML = `<p class="card-copy">No surrounding-literature entry was found for this topic in the current public sample.</p>`;
      renderListView();
      return;
    }

    const renderItems = (items) =>
      items
        .slice(0, 6)
        .map(
          (item) => {
            const concept = conceptMap.get(item.concept_id);
            const label = concept ? conceptTitle(concept) : item.label;
            return `
            <li>
              <button class="list-link list-link-tight" type="button" data-neighbor-id="${escapeHtml(item.concept_id)}">
                <span>${escapeHtml(label)}</span>
                <span>${formatNumber(safeNumber(item.support_count))} papers</span>
              </button>
            </li>
          `;
          },
        )
        .join("");

    selectedNeighborhood.innerHTML = `
      <div class="neighbor-group">
        <h4>Incoming</h4>
        <ul class="neighbor-list">${renderItems(neighborhood.incoming || [])}</ul>
      </div>
      <div class="neighbor-group">
        <h4>Outgoing</h4>
        <ul class="neighbor-list">${renderItems(neighborhood.outgoing || [])}</ul>
      </div>
      <div class="neighbor-group">
        <h4>Nearby topics</h4>
        <ul class="neighbor-list">${renderItems(neighborhood.top_neighbors || [])}</ul>
      </div>
    `;
    for (const button of selectedNeighborhood.querySelectorAll("[data-neighbor-id]")) {
      button.addEventListener("click", () => selectConcept(button.dataset.neighborId));
    }
    renderListView();
  };

  const renderOpportunities = async (conceptId) => {
    currentOpportunities = [];
    const shardPath = opportunitiesIndex[conceptId];
    if (!shardPath) {
      selectedOpportunities.innerHTML = `<p class="card-copy">No public research question touching this topic is available in the current public sample.</p>`;
      renderListView();
      return;
    }
    const shard = await fetchJson(shardPath);
    const opportunities = shard[conceptId] || [];
    currentOpportunities = opportunities;
    if (!opportunities.length) {
      selectedOpportunities.innerHTML = `<p class="card-copy">No public research question touching this topic is available in the current public sample.</p>`;
      renderListView();
      return;
    }
    selectedOpportunities.innerHTML = opportunities
      .slice(0, 5)
      .map(
        (item) => `
          <article class="mini-opportunity">
            <strong>${escapeHtml(item.public_pair_label)}</strong>
            ${conceptLabelNote(item.source_id) || conceptLabelNote(item.target_id) ? `<div class="mini-copy opportunity-label-note">${escapeHtml([conceptLabelNote(item.source_id), conceptLabelNote(item.target_id)].filter(Boolean).join(" "))}</div>` : ""}
            <div class="mini-copy">${escapeHtml(item.direct_link_status)} · ${formatNumber(safeNumber(item.supporting_path_count))} nearby linking concepts in the released graph</div>
            <div class="mini-copy">Common contexts: ${escapeHtml(item.source_context_summary)} on one side and ${escapeHtml(item.target_context_summary)} on the other.</div>
            <a class="text-link" href="${escapeHtml(item.app_link)}">Explore in app</a>
          </article>
        `,
      )
      .join("");
    renderListView();
  };

  const selectConcept = async (conceptId) => {
    if (!conceptId) return;
    selectedId = conceptId;
    const concept = conceptMap.get(conceptId);
    if (!concept) return;
    renderGraph();
    renderSelectedConcept(concept);
    restoreStatus();
    if (isInBackbone(conceptId)) {
      if (mapMode === "focused") {
        setDefaultViewport();
      } else {
        focusViewOnConcept(conceptId);
      }
    }
    await Promise.all([renderNeighborhood(conceptId), renderOpportunities(conceptId)]);
  };

  const runSearch = (query) => {
    const normalized = query.trim().toLowerCase();
    if (!normalized) {
      searchResults.innerHTML = "";
      return;
    }
    const matches = concepts
      .filter((concept) => concept.search_terms.some((term) => term.includes(normalized)))
      .sort((a, b) => b.weighted_degree - a.weighted_degree)
      .slice(0, 8);
    searchResults.innerHTML = matches
      .map(
        (concept) => `
          <button class="search-hit" data-concept-id="${escapeHtml(concept.concept_id)}">
            <strong>${escapeHtml(conceptTitle(concept))}</strong>
            <span>${formatNumber(safeNumber(concept.distinct_paper_support))} papers</span>
          </button>
        `,
      )
      .join("");
    for (const button of searchResults.querySelectorAll("[data-concept-id]")) {
      button.addEventListener("click", () => {
        searchResults.innerHTML = "";
        if (searchInput instanceof HTMLInputElement) searchInput.value = "";
        selectConcept(button.dataset.conceptId);
      });
    }
  };

  const restoreInitialLayout = () => {
    for (const node of graph.nodes) {
      const initial = graph.initialPositions.get(node.id);
      if (!initial) continue;
      node.x = initial.x;
      node.y = initial.y;
    }
    renderGraph();
    setDefaultViewport();
    if (selectedId) restoreStatus();
  };

  const bootstrap = async () => {
    const [graphPayload, conceptPayload, neighborhoodsPayload, opportunitiesPayload, centralPayload] = await Promise.all([
      fetchJson(graphPath),
      fetchJson(conceptIndexPath),
      fetchJson(neighborhoodsIndexPath),
      fetchJson(opportunitiesIndexPath),
      fetchJson(centralConceptsPath),
    ]);
    graph = {
      nodes: graphPayload.nodes.map((node) => ({ ...node })),
      edges: graphPayload.edges,
      nodeMap: new Map(graphPayload.nodes.map((node) => [node.id, { ...node }])),
      edgeMap: new Map(graphPayload.edges.map((edge) => [edge.id, edge])),
      initialPositions: new Map(graphPayload.nodes.map((node) => [node.id, { x: node.x, y: node.y }])),
    };
    graph.nodes = Array.from(graph.nodeMap.values());
    concepts = conceptPayload;
    conceptMap = new Map(concepts.map((concept) => [concept.concept_id, concept]));
    neighborhoodIndex = neighborhoodsPayload;
    opportunitiesIndex = opportunitiesPayload;
    centralConcepts = centralPayload;
    const preferredDefault =
      PREFERRED_DEFAULT_LABELS.map((preferredLabel) =>
        concepts.find((concept) => String(concept.plain_label || concept.label || "").trim().toLowerCase() === preferredLabel),
      ).find(Boolean)?.concept_id || null;
    defaultConceptId = preferredDefault || centralConcepts[0]?.concept_id || concepts[0]?.concept_id || null;
    renderCentralList();
    updateLayoutModeButton();
    updateMapModeButton();
    const params = new URLSearchParams(window.location.search);
    const query = params.get("q");
    const exact = query
      ? concepts.find((concept) => concept.label.toLowerCase() === query.toLowerCase())
      : null;
    if (exact) {
      await selectConcept(exact.concept_id);
    } else if (defaultConceptId) {
      await selectConcept(defaultConceptId);
    } else {
      renderGraph();
      setDefaultViewport();
      restoreStatus();
    }
  };

  if (searchInput instanceof HTMLInputElement) {
    searchInput.addEventListener("input", (event) => runSearch(event.target.value));
  }
  if (resetView instanceof HTMLButtonElement) {
    resetView.addEventListener("click", setDefaultViewport);
  }
  if (toggleMapMode instanceof HTMLButtonElement) {
    toggleMapMode.addEventListener("click", () => {
      mapMode = mapMode === "focused" ? "global" : "focused";
      updateMapModeButton();
      renderGraph();
      setDefaultViewport();
      restoreStatus();
    });
  }

  canvas.addEventListener("wheel", (event) => {
    event.preventDefault();
    const factor = event.deltaY > 0 ? 1 / 1.08 : 1.08;
    zoomAtPoint(factor, event.clientX, event.clientY);
  }, { passive: false });

  canvas.addEventListener("pointerdown", (event) => {
    startPan(event.target, event.clientX, event.clientY);
  });
  canvas.addEventListener("mousedown", (event) => {
    startPan(event.target, event.clientX, event.clientY);
  });

  window.addEventListener("pointermove", (event) => {
    moveInteraction(event.clientX, event.clientY);
  });
  window.addEventListener("mousemove", (event) => {
    moveInteraction(event.clientX, event.clientY);
  });

  window.addEventListener("pointerup", () => {
    interaction = null;
  });
  window.addEventListener("mouseup", () => {
    interaction = null;
  });

  bootstrap().catch((error) => {
    hoverCard.textContent = "Literature map data failed to load.";
    console.error(error);
  });
</script>
