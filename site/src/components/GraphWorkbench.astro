---
interface Props {
  graphPath: string;
  conceptIndexPath: string;
  neighborhoodsIndexPath: string;
  opportunitiesIndexPath: string;
  centralConceptsPath: string;
  contextLabel?: string;
}

const {
  graphPath,
  conceptIndexPath,
  neighborhoodsIndexPath,
  opportunitiesIndexPath,
  centralConceptsPath,
  contextLabel = "current map",
} = Astro.props;

const rootId = `graph-workbench-${Math.random().toString(36).slice(2, 10)}`;
---

<section
  id={rootId}
  class="graph-workbench"
  data-graph-path={graphPath}
  data-concept-index-path={conceptIndexPath}
  data-neighborhoods-index-path={neighborhoodsIndexPath}
  data-opportunities-index-path={opportunitiesIndexPath}
  data-central-concepts-path={centralConceptsPath}
>
  <div class="graph-toolbar">
    <div class="graph-toolbar-copy">
      <h2>Choose a topic and start with the questions around it.</h2>
      <p class="card-copy">
        Choose one topic, then read the strongest nearby questions. Each question is grounded in nearby paths, intermediate topics, and papers.
      </p>
      <label class="search-shell graph-search-shell">
        <span>Search topic</span>
        <input type="search" placeholder="Search labels or aliases" data-role="search-input" />
        <div class="search-results" data-role="search-results"></div>
      </label>
    </div>
  </div>

  <div class="graph-jumpbar">
    <span class="tiny-label">Try one of these</span>
    <div class="central-list central-list-inline" data-role="central-list"></div>
  </div>

  <div class="graph-stage">
    <div class="graph-active-shell" data-role="graph-active" hidden>
      <section class="sidebar-card inspector-card graph-topic-strip" data-role="selected-concept">
        <p class="card-copy">Selected-topic context will appear here.</p>
      </section>

      <div class="graph-master-detail">
        <aside class="graph-chooser-rail">
          <section class="sidebar-card inspector-card graph-question-shell">
            <div class="inspector-head">
              <h3>Questions touching this topic</h3>
              <p class="mini-copy">Choose one. The right side shows why it surfaced, which intermediate topics already connect it, and where to start reading.</p>
            </div>
            <div data-role="selected-opportunities">
              <p class="card-copy">The strongest question candidates touching the selected topic will appear here.</p>
            </div>
          </section>

          <section class="sidebar-card inspector-card graph-neighborhood-shell">
            <div class="inspector-head">
              <h3>Nearby topics</h3>
            </div>
            <div data-role="selected-neighborhood">
              <p class="card-copy">Nearby topics will appear here once you select a topic.</p>
            </div>
          </section>
        </aside>

        <div class="graph-detail-workspace">
          <section class="sidebar-card inspector-card graph-question-focus">
            <div class="inspector-head">
              <h3>Selected question</h3>
            </div>
            <div data-role="selected-question">
              <p class="card-copy">Choose a topic, then choose a question to see the strongest paths and starter papers here.</p>
            </div>
          </section>

          <details class="graph-context-disclosure">
            <summary>Show local graph</summary>
            <p class="mini-copy graph-context-note">Open this when you want the local neighborhood around the selected question.</p>
            <section class="graph-panel graph-panel-secondary graph-context-panel">
              <div class="graph-controls">
                <div class="graph-status-shell">
                  <div class="graph-status" data-role="hover-card" aria-live="polite">
                    Choose a question first, then open the graph when you want local context around it.
                  </div>
                </div>
                <div class="graph-control-row">
                  <button class="button-secondary" type="button" data-role="toggle-map-mode">Show full map</button>
                  <button class="button-tertiary" type="button" data-role="reset-view">Reset view</button>
                </div>
              </div>
              <div class="graph-canvas-shell">
                <svg class="graph-canvas" data-role="graph-canvas" viewBox="0 0 1120 860" aria-label="Literature map"></svg>
                <div class="graph-tooltip" data-role="graph-tooltip" hidden></div>
              </div>
              <div class="graph-help-row">
                <span class="mini-copy">Use the graph to inspect the local neighborhood around the selected question or switch topic.</span>
              </div>
            </section>
          </details>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ rootId, contextLabel }} type="module">
  const root = document.getElementById(rootId);
  if (!(root instanceof HTMLElement)) throw new Error("Graph workbench root missing");

  const GRAPH_WIDTH = 1120;
  const GRAPH_HEIGHT = 860;
  const MIN_SCALE = 0.55;
  const MAX_SCALE = 4;
  const FOCUSED_NEIGHBOR_LIMIT = 8;
  const FOCUSED_LABEL_LIMIT = 4;
  const TOP_QUESTION_LIMIT = 4;
  const LAYOUT_MIN_X = -0.24;
  const LAYOUT_MAX_X = 1.24;
  const LAYOUT_MIN_Y = -0.2;
  const LAYOUT_MAX_Y = 1.2;

  const graphPath = root.dataset.graphPath;
  const conceptIndexPath = root.dataset.conceptIndexPath;
  const neighborhoodsIndexPath = root.dataset.neighborhoodsIndexPath;
  const opportunitiesIndexPath = root.dataset.opportunitiesIndexPath;
  const centralConceptsPath = root.dataset.centralConceptsPath;

  const STARTING_TOPIC_LABELS = [
    "public debt",
    "inflation",
    "monetary policy",
    "education",
    "urbanization",
    "trade openness",
    "financial development",
    "economic growth",
  ];
  const searchInput = root.querySelector('[data-role="search-input"]');
  const searchResults = root.querySelector('[data-role="search-results"]');
  const hoverCard = root.querySelector('[data-role="hover-card"]');
  const graphTooltip = root.querySelector('[data-role="graph-tooltip"]');
  const canvas = root.querySelector('[data-role="graph-canvas"]');
  const activeShell = root.querySelector('[data-role="graph-active"]');
  const selectedConcept = root.querySelector('[data-role="selected-concept"]');
  const selectedNeighborhood = root.querySelector('[data-role="selected-neighborhood"]');
  const selectedQuestion = root.querySelector('[data-role="selected-question"]');
  const selectedOpportunities = root.querySelector('[data-role="selected-opportunities"]');
  const centralList = root.querySelector('[data-role="central-list"]');
  const resetView = root.querySelector('[data-role="reset-view"]');
  const toggleMapMode = root.querySelector('[data-role="toggle-map-mode"]');

  const shardCache = new Map();
  let selectedId = null;
  let graph = null;
  let concepts = [];
  let conceptMap = new Map();
  let neighborhoodIndex = {};
  let opportunitiesIndex = {};
  let centralConcepts = [];
  let currentNeighborhood = null;
  let currentOpportunities = [];
  let activeQuestionPairKey = null;
  let layoutMode = false;
  let mapMode = "focused";
  let interaction = null;
  let viewState = { scale: 1, translateX: 0, translateY: 0 };

  const escapeHtml = (value) =>
    String(value)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");

  const formatNumber = (value) => new Intl.NumberFormat("en-US").format(value);
  const safeNumber = (value) => {
    const numeric = Number(value);
    return Number.isFinite(numeric) ? numeric : 0;
  };
  const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
  const isInBackbone = (conceptId) => Boolean(graph?.nodeMap?.has(conceptId));
  const conceptTitle = (concept) => concept?.plain_label || concept?.label || "";
  const conceptSubtitle = (concept) => {
    const value = String(concept?.subtitle ?? "").trim();
    return value && !["na", "n/a", "nan", "null", "undefined", "none"].includes(value.toLowerCase()) ? value : "";
  };
  const questionSideLabel = (item, side) => {
    if (!item) return "";
    if (side === "source") {
      return item?.source_display_label || item?.source_label || conceptLabel(item?.source_id, "");
    }
    return item?.target_display_label || item?.target_label || conceptLabel(item?.target_id, "");
  };
  const conceptLabel = (conceptId, fallback = "") => {
    const concept = conceptMap.get(conceptId);
    return concept ? conceptTitle(concept) : fallback;
  };
  const topicIsClimateHeavy = (concept) =>
    /\b(climate|carbon|co2|emissions?|pollution|environment(?:al)?|ecological|energy|oil|gas|electricity|renewable)\b/i.test(
      `${conceptTitle(concept)} ${conceptSubtitle(concept)}`,
    );
  const normalizeLabel = (value) => String(value || "").trim().toLowerCase();
  const estimateChipWidth = (label) => clamp(78 + String(label || "").length * 6.4, 86, 248);
  const conciseQuestionReason = (item) => {
    const pathCount = safeNumber(item.supporting_path_count);
    const mediatorCount = safeNumber(item.mediator_count);
    if (pathCount > 0 && mediatorCount > 0) {
      return `${formatNumber(pathCount)} nearby paths and ${formatNumber(mediatorCount)} intermediate topics already connect these two sides in the ${contextLabel}.`;
    }
    if (pathCount > 0) {
      return `${formatNumber(pathCount)} nearby paths already connect these two sides in the ${contextLabel}.`;
    }
    if (mediatorCount > 0) {
      return `${formatNumber(mediatorCount)} intermediate topics already connect these two sides in the ${contextLabel}.`;
    }
    return `Nearby paths and papers already bring these two sides close together in the ${contextLabel}.`;
  };
  const staticGuideText =
    "Choose a question first. Open the graph only when you want local context around it.";
  const questionTitle = (item) => {
    const source = questionSideLabel(item, "source");
    const target = questionSideLabel(item, "target");
    if (source && target) return `How do ${source} and ${target} connect?`;
    return item?.public_pair_label || "Candidate question";
  };
  const questionProjectShapeLabel = (item) => {
    const moveText = String(item?.recommended_move || "").toLowerCase();
    if (/\b(bridge|review|synthesis|seminar|pilot)\b/.test(moveText)) return "Broader project";
    if (safeNumber(item?.mediator_count) >= 6 || safeNumber(item?.supporting_path_count) >= 8 || safeNumber(item?.motif_count) >= 5) {
      return "Broader project";
    }
    return "Focused question";
  };
  const questionCounterpartId = (item, selectedConceptId) => {
    if (!item || !selectedConceptId) return null;
    if (item.source_id === selectedConceptId) return item.target_id;
    if (item.target_id === selectedConceptId) return item.source_id;
    return null;
  };
  const genericTopicPenalty = (concept) => {
    if (!concept) return 0;
    const haystack = `${conceptTitle(concept)} ${conceptSubtitle(concept)}`.toLowerCase();
    let penalty = Math.log10(safeNumber(concept.weighted_degree) + 1) * 2.4;
    if (
      /\b(economic growth|economic development|development|investment|consumption|employment|productivity|trade openness|trade|education|inflation|public debt|monetary policy|financial development|behavioral economics|institutions?)\b/.test(
        haystack,
      )
    ) {
      penalty += 3.6;
    }
    if (haystack.split(/\s+/).filter(Boolean).length <= 2) {
      penalty += 1.2;
    }
    return penalty;
  };
  const questionPriorityScore = (item, selectedConceptId) => {
    const counterpart = conceptMap.get(questionCounterpartId(item, selectedConceptId));
    const baseScore = safeNumber(item.score);
    const specificityBonus = safeNumber(item.public_specificity_score) * 0.65;
    const pathScore = Math.min(safeNumber(item.supporting_path_count), 12) * 2.8;
    const mediatorScore = Math.min(safeNumber(item.mediator_count), 8) * 1.45;
    const motifScore = Math.min(safeNumber(item.motif_count), 8) * 0.8;
    const crossBonus = safeNumber(item.cross_field) ? 1.4 : 0;
    const exactPenalty = Math.min(safeNumber(item.cooc_count), 3) * 1.35;
    const counterpartPenalty = genericTopicPenalty(counterpart);
    return baseScore + specificityBonus + pathScore + mediatorScore + motifScore + crossBonus - exactPenalty - counterpartPenalty;
  };
  const currentQuestion = () =>
    activeQuestionPairKey ? currentOpportunities.find((item) => item.pair_key === activeQuestionPairKey) || null : null;
  const resolveMediatorConceptId = (label) => {
    const needle = normalizeLabel(label);
    if (!needle) return null;
    const exact = concepts.find((concept) => normalizeLabel(concept.plain_label || concept.label) === needle);
    return exact?.concept_id || null;
  };
  const escapeAttr = (value) => escapeHtml(value ?? "");
  const buildFocusedPositionMap = (neighborIds, { counterpartId = null, mediatorIds = [] } = {}) => {
    const positionMap = new Map();
    const centerX = GRAPH_WIDTH * 0.5;
    const centerY = GRAPH_HEIGHT * 0.5;
    const pathMode = Boolean(counterpartId) || mediatorIds.length > 0;
    if (pathMode) {
      const selectedX = GRAPH_WIDTH * 0.24;
      const counterpartX = GRAPH_WIDTH * 0.78;
      positionMap.set(selectedId, { x: selectedX, y: centerY, angle: Math.PI });
      if (counterpartId) {
        positionMap.set(counterpartId, { x: counterpartX, y: centerY, angle: 0 });
      }
      const mediatorAnchors =
        mediatorIds.length <= 1
          ? [{ x: GRAPH_WIDTH * 0.52, y: centerY, angle: -Math.PI / 2 }]
          : mediatorIds.length === 2
            ? [
                { x: GRAPH_WIDTH * 0.5, y: centerY - 110, angle: -Math.PI / 2 },
                { x: GRAPH_WIDTH * 0.5, y: centerY + 110, angle: Math.PI / 2 },
              ]
            : [
                { x: GRAPH_WIDTH * 0.48, y: centerY - 122, angle: -Math.PI / 2 },
                { x: GRAPH_WIDTH * 0.55, y: centerY, angle: 0 },
                { x: GRAPH_WIDTH * 0.48, y: centerY + 122, angle: Math.PI / 2 },
              ];
      mediatorIds.forEach((neighborId, index) => {
        const anchor = mediatorAnchors[index] || mediatorAnchors[mediatorAnchors.length - 1];
        positionMap.set(neighborId, anchor);
      });
      const remaining = neighborIds.filter((neighborId) => !positionMap.has(neighborId));
      if (remaining.length) {
        const radiusX = 210;
        const radiusY = 170;
        const step = (Math.PI * 2) / remaining.length;
        remaining.forEach((neighborId, index) => {
          const angle = -Math.PI / 2 + step * index;
          positionMap.set(neighborId, {
            x: centerX + Math.cos(angle) * radiusX,
            y: centerY + Math.sin(angle) * radiusY,
            angle,
          });
        });
      }
      return positionMap;
    }

    positionMap.set(selectedId, { x: centerX, y: centerY, angle: -Math.PI / 2 });
    if (!neighborIds.length) return positionMap;

    const radiusX = neighborIds.length <= 4 ? 240 : 300;
    const radiusY = neighborIds.length <= 4 ? 158 : 214;
    const step = (Math.PI * 2) / neighborIds.length;
    neighborIds.forEach((neighborId, index) => {
      const angle = -Math.PI / 2 + step * index;
      positionMap.set(neighborId, {
        x: centerX + Math.cos(angle) * radiusX,
        y: centerY + Math.sin(angle) * radiusY,
        angle,
      });
    });
    return positionMap;
  };
  const nodeRenderState = (node, renderPositionMap) => {
    const focusedPosition = renderPositionMap?.get(node.id);
    if (focusedPosition) return focusedPosition;
    return {
      x: node.x * GRAPH_WIDTH,
      y: node.y * GRAPH_HEIGHT,
      angle: -Math.PI / 2,
    };
  };

  const fetchJson = async (path) => {
    if (shardCache.has(path)) return shardCache.get(path);
    const response = await fetch(path);
    const payload = await response.json();
    shardCache.set(path, payload);
    return payload;
  };

  const moveTooltip = (event) => {
    if (!(graphTooltip instanceof HTMLElement) || graphTooltip.hidden) return;
    const shell = graphTooltip.parentElement;
    if (!(shell instanceof HTMLElement)) return;
    const shellRect = shell.getBoundingClientRect();
    const maxLeft = shell.clientWidth - graphTooltip.offsetWidth - 12;
    const maxTop = shell.clientHeight - graphTooltip.offsetHeight - 12;
    const left = clamp(event.clientX - shellRect.left + 14, 12, Math.max(12, maxLeft));
    const top = clamp(event.clientY - shellRect.top + 14, 12, Math.max(12, maxTop));
    graphTooltip.style.left = `${left}px`;
    graphTooltip.style.top = `${top}px`;
  };

  const showTooltip = (event, html) => {
    if (!(graphTooltip instanceof HTMLElement)) return;
    graphTooltip.innerHTML = html;
    graphTooltip.hidden = false;
    moveTooltip(event);
  };

  const hideTooltip = () => {
    if (!(graphTooltip instanceof HTMLElement)) return;
    graphTooltip.hidden = true;
  };

  const updateLayoutModeButton = () => {
    return;
  };

  const updateMapModeButton = () => {
    if (!(toggleMapMode instanceof HTMLButtonElement)) return;
    const fullMap = mapMode === "global";
    toggleMapMode.textContent = fullMap ? "Return to focused view" : "Show full map";
    toggleMapMode.classList.toggle("is-active", fullMap);
  };

  const setViewportTransform = () => {
    const viewport = canvas?.querySelector('[data-role="graph-viewport"]');
    if (!(viewport instanceof SVGGElement)) return;
    viewport.setAttribute(
      "transform",
      `translate(${viewState.translateX} ${viewState.translateY}) scale(${viewState.scale})`,
    );
  };

  const screenToCanvasPoint = (clientX, clientY) => {
    const rect = canvas.getBoundingClientRect();
    const x = ((clientX - rect.left) / rect.width) * GRAPH_WIDTH;
    const y = ((clientY - rect.top) / rect.height) * GRAPH_HEIGHT;
    return {
      x,
      y,
      graphX: (x - viewState.translateX) / viewState.scale,
      graphY: (y - viewState.translateY) / viewState.scale,
    };
  };

  const zoomAtPoint = (factor, clientX, clientY) => {
    const { x, y, graphX, graphY } = screenToCanvasPoint(clientX, clientY);
    const nextScale = clamp(viewState.scale * factor, MIN_SCALE, MAX_SCALE);
    viewState = {
      scale: nextScale,
      translateX: x - graphX * nextScale,
      translateY: y - graphY * nextScale,
    };
    setViewportTransform();
  };

  const resetViewport = () => {
    viewState = { scale: 1, translateX: 0, translateY: 0 };
    setViewportTransform();
  };

  const getFocusedNeighborIds = (conceptId) => {
    if (!graph || !conceptId || !isInBackbone(conceptId)) return [];
    const touchingEdges = graph.edges
      .filter((edge) => edge.source === conceptId || edge.target === conceptId)
      .sort((left, right) => safeNumber(right.support_count) - safeNumber(left.support_count));
    const neighborIds = [];
    const seen = new Set([conceptId]);
    for (const edge of touchingEdges) {
      const otherId = edge.source === conceptId ? edge.target : edge.source;
      if (seen.has(otherId)) continue;
      seen.add(otherId);
      neighborIds.push(otherId);
      if (neighborIds.length >= FOCUSED_NEIGHBOR_LIMIT) break;
    }
    return neighborIds;
  };

  const getVisibleGraphState = () => {
    const selectedActive = Boolean(selectedId) && isInBackbone(selectedId);
    const activeQuestion = currentQuestion();
    const questionCounterpartId = activeQuestion
      ? activeQuestion.source_id === selectedId
        ? activeQuestion.target_id
        : activeQuestion.target_id === selectedId
          ? activeQuestion.source_id
          : null
      : null;
    const mediatorIds = activeQuestion
      ? ((activeQuestion.top_mediator_display_labels && activeQuestion.top_mediator_display_labels.length
          ? activeQuestion.top_mediator_display_labels
          : activeQuestion.top_mediator_labels) || [])
          .map((label) => resolveMediatorConceptId(label))
          .filter((conceptId) => conceptId && isInBackbone(conceptId))
          .slice(0, 3)
      : [];
    const allNeighbors = new Set();

    if (selectedActive) {
      for (const edge of graph.edges) {
        if (edge.source === selectedId) allNeighbors.add(edge.target);
        if (edge.target === selectedId) allNeighbors.add(edge.source);
      }
    }

    if (mapMode === "global" || !selectedActive) {
      return {
        focusedActive: false,
        nodes: graph.nodes,
        edges: graph.edges,
        selectedNeighbors: allNeighbors,
        labelNeighbors: new Set(),
        renderPositionMap: null,
      };
    }

    const focusedNeighborIds = [];
    const pushFocusedNeighbor = (conceptId) => {
      if (!conceptId || conceptId === selectedId) return;
      if (focusedNeighborIds.includes(conceptId)) return;
      focusedNeighborIds.push(conceptId);
    };
    pushFocusedNeighbor(questionCounterpartId);
    mediatorIds.forEach(pushFocusedNeighbor);
    getFocusedNeighborIds(selectedId).forEach(pushFocusedNeighbor);
    const visibleIds = new Set([selectedId, ...focusedNeighborIds]);
    const visibleEdges = graph.edges.filter((edge) => visibleIds.has(edge.source) && visibleIds.has(edge.target));
    const visibleNodes = graph.nodes.filter((node) => visibleIds.has(node.id));
    return {
      focusedActive: true,
      nodes: visibleNodes,
      edges: visibleEdges,
      selectedNeighbors: new Set(focusedNeighborIds),
      labelNeighbors: new Set(focusedNeighborIds),
      renderPositionMap: buildFocusedPositionMap(focusedNeighborIds, {
        counterpartId: questionCounterpartId,
        mediatorIds,
      }),
    };
  };

  const fitViewToNodeIds = (nodeIds) => {
    if (!graph || !nodeIds.length) {
      resetViewport();
      return;
    }
    const nodes = nodeIds
      .map((nodeId) => graph.nodeMap.get(nodeId))
      .filter(Boolean);
    if (!nodes.length) {
      resetViewport();
      return;
    }
    const xs = nodes.map((node) => node.x * GRAPH_WIDTH);
    const ys = nodes.map((node) => node.y * GRAPH_HEIGHT);
    const minX = Math.min(...xs);
    const maxX = Math.max(...xs);
    const minY = Math.min(...ys);
    const maxY = Math.max(...ys);
    const padding = 120;
    const spanX = Math.max(maxX - minX, 150);
    const spanY = Math.max(maxY - minY, 150);
    const nextScale = clamp(
      Math.min((GRAPH_WIDTH - padding * 2) / spanX, (GRAPH_HEIGHT - padding * 2) / spanY),
      MIN_SCALE,
      MAX_SCALE,
    );
    const centerX = (minX + maxX) / 2;
    const centerY = (minY + maxY) / 2;
    viewState = {
      scale: nextScale,
      translateX: GRAPH_WIDTH / 2 - centerX * nextScale,
      translateY: GRAPH_HEIGHT / 2 - centerY * nextScale,
    };
    setViewportTransform();
  };

  const startPan = (eventTarget, clientX, clientY) => {
    if (eventTarget instanceof Element && eventTarget.closest("[data-node-id]")) return;
    hideTooltip();
    interaction = {
      type: "pan",
      startX: clientX,
      startY: clientY,
      translateX: viewState.translateX,
      translateY: viewState.translateY,
    };
  };

  const startNodeDrag = (nodeId) => {
    interaction = {
      type: "drag-node",
      nodeId,
    };
  };

  const moveInteraction = (clientX, clientY) => {
    if (!interaction || !graph) return;
    if (interaction.type === "pan") {
      viewState = {
        ...viewState,
        translateX: interaction.translateX + (clientX - interaction.startX),
        translateY: interaction.translateY + (clientY - interaction.startY),
      };
      setViewportTransform();
      return;
    }
    if (interaction.type === "drag-node" && interaction.nodeId && layoutMode) {
      const point = screenToCanvasPoint(clientX, clientY);
      const node = graph.nodeMap.get(interaction.nodeId);
      if (!node) return;
      node.x = clamp(point.graphX / GRAPH_WIDTH, LAYOUT_MIN_X, LAYOUT_MAX_X);
      node.y = clamp(point.graphY / GRAPH_HEIGHT, LAYOUT_MIN_Y, LAYOUT_MAX_Y);
      renderGraph();
      restoreStatus();
    }
  };

  const focusViewOnConcept = (conceptId) => {
    if (!isInBackbone(conceptId)) return;
    const node = graph.nodeMap.get(conceptId);
    const nextScale = Math.max(viewState.scale, 1.15);
    viewState = {
      scale: nextScale,
      translateX: GRAPH_WIDTH / 2 - node.x * GRAPH_WIDTH * nextScale,
      translateY: GRAPH_HEIGHT / 2 - node.y * GRAPH_HEIGHT * nextScale,
    };
    setViewportTransform();
  };

  const setDefaultViewport = () => {
    if (!graph) return;
    if (mapMode === "focused" && selectedId && isInBackbone(selectedId)) {
      resetViewport();
      return;
    }
    resetViewport();
  };

  const restoreStatus = () => {
    if (!hoverCard) return;
    hoverCard.textContent = staticGuideText;
  };

  const updateSelectionState = () => {
    const hasSelection = Boolean(selectedId && conceptMap.get(selectedId));
    root.classList.toggle("is-topic-selected", hasSelection);
    if (activeShell instanceof HTMLElement) {
      activeShell.hidden = !hasSelection;
    }
  };

  const renderCentralList = () => {
    const chosen = new Set();
    const visibleConcepts = [];
    const manualStartingConcepts = STARTING_TOPIC_LABELS.map((label) =>
      concepts.find((concept) => String(concept.plain_label || concept.label || "").trim().toLowerCase() === label),
    ).filter(Boolean);
    for (const concept of manualStartingConcepts) {
      if (chosen.has(concept.concept_id)) continue;
      chosen.add(concept.concept_id);
      visibleConcepts.push(concept);
      if (visibleConcepts.length >= 8) break;
    }
    for (const concept of centralConcepts) {
      if (chosen.has(concept.concept_id) || topicIsClimateHeavy(concept)) continue;
      chosen.add(concept.concept_id);
      visibleConcepts.push(concept);
      if (visibleConcepts.length >= 8) break;
    }
    centralList.innerHTML = visibleConcepts
      .map(
        (concept) => `
          <button class="list-link" data-concept-id="${escapeHtml(concept.concept_id)}">
            <span>${escapeHtml(conceptTitle(concept))}</span>
            <span>${formatNumber(safeNumber(concept.distinct_paper_support))} papers</span>
          </button>
        `,
      )
      .join("");
    for (const button of centralList.querySelectorAll("[data-concept-id]")) {
      button.addEventListener("click", () => selectConcept(button.dataset.conceptId));
    }
  };

  const renderQuestionDetail = () => {
    const concept = selectedId ? conceptMap.get(selectedId) : null;
    if (!concept || !(selectedQuestion instanceof HTMLElement)) {
      return;
    }
    const question = currentQuestion();
    if (!question) {
      const fallbackItems = (currentNeighborhood?.top_neighbors || []).slice(0, 3);
      selectedQuestion.innerHTML = fallbackItems.length
        ? `
          <p class="card-copy">This topic does not currently have a surfaced question in the ${contextLabel}, but nearby paths still suggest plausible next moves.</p>
          <div class="graph-prompt-stack">
            ${fallbackItems
              .map(
                (item) => `
                  <article class="graph-prompt-card">
                    <span class="tiny-label">Possible question</span>
                    <strong>${escapeHtml(`What links ${conceptTitle(concept)} and ${conceptLabel(item.concept_id, item.label)}?`)}</strong>
                    <p class="mini-copy">${formatNumber(safeNumber(item.support_count))} local papers already connect these topics through nearby paths.</p>
                    <button class="list-link list-link-tight" type="button" data-neighbor-id="${escapeAttr(item.concept_id)}">
                      <span>Open neighboring topic</span>
                      <span>${escapeHtml(conceptLabel(item.concept_id, item.label))}</span>
                    </button>
                  </article>
                `,
              )
              .join("")}
          </div>
        `
        : `<p class="card-copy">Choose a topic with visible question candidates to see path-based detail here.</p>`;
      for (const button of selectedQuestion.querySelectorAll("[data-neighbor-id]")) {
        button.addEventListener("click", () => selectConcept(button.dataset.neighborId));
      }
      return;
    }

    const mediatorLabels = Array.isArray(question.top_mediator_display_labels) && question.top_mediator_display_labels.length
      ? question.top_mediator_display_labels.filter(Boolean).slice(0, 3)
      : Array.isArray(question.top_mediator_labels)
        ? question.top_mediator_labels.filter(Boolean).slice(0, 3)
        : [];
    const sourceLabel = questionSideLabel(question, "source");
    const targetLabel = questionSideLabel(question, "target");
    const pathStrips = mediatorLabels.length
      ? mediatorLabels
          .map((label, index) => {
            const mediatorId = resolveMediatorConceptId(label);
            const control = mediatorId
              ? `<button class="button-tertiary path-strip-action" type="button" data-mediator-id="${escapeAttr(mediatorId)}">Open topic</button>`
              : "";
            return `
              <article class="path-strip-card">
                <span class="tiny-label">Path ${index + 1}</span>
                <div class="path-strip">
                  <span class="path-node-chip is-anchor">${escapeHtml(sourceLabel)}</span>
                  <span class="path-strip-arrow" aria-hidden="true">→</span>
                  <span class="path-node-chip is-mediator">${escapeHtml(label)}</span>
                  <span class="path-strip-arrow" aria-hidden="true">→</span>
                  <span class="path-node-chip is-anchor">${escapeHtml(targetLabel)}</span>
                </div>
                ${control}
              </article>
            `;
          })
          .join("")
      : `<p class="mini-copy">No named intermediate topics were exported for this question in the ${contextLabel}.</p>`;

    const papers = Array.isArray(question.representative_papers) ? question.representative_papers.slice(0, 3) : [];
    selectedQuestion.innerHTML = `
      <article class="graph-question-focus-card">
        <h4>${escapeHtml(questionTitle(question))}</h4>
        <p class="card-copy focus-summary"><strong>Why this surfaced:</strong> ${escapeHtml(conciseQuestionReason(question))}</p>
        <div class="graph-question-meta">
          <span>${formatNumber(safeNumber(question.supporting_path_count))} supporting paths</span>
          <span>${formatNumber(safeNumber(question.mediator_count))} intermediate topics</span>
          <span>${escapeHtml(questionProjectShapeLabel(question))}</span>
        </div>
        <p class="mini-copy focus-step"><strong>What to inspect first:</strong> ${escapeHtml(question.recommended_move || "Start with the nearby literature and pin down the concrete empirical setting.")}</p>
        <div class="graph-question-actions">
          <a class="button-secondary" href="${escapeAttr(question.app_link)}">Open in app for papers and export</a>
        </div>
      </article>
      <div class="graph-question-subgrid">
        <section class="question-detail-panel">
          <h4>Supporting paths</h4>
          <p class="mini-copy">These are the clearest short routes already linking the two sides through nearby topics and papers.</p>
          <div class="path-strip-stack">${pathStrips}</div>
        </section>
        <details class="question-detail-disclosure">
          <summary>Show starter papers${papers.length ? ` (${papers.length})` : ""}</summary>
          <p class="mini-copy">Open this when you want a concrete place to begin reading around this question.</p>
          ${
            papers.length
              ? `<ul class="question-paper-list">
                  ${papers
                    .map(
                      (paper) => `
                        <li>
                          <strong>${escapeHtml(paper.title || "Untitled paper")}</strong>
                          <span>${paper.year ? escapeHtml(String(paper.year)) : "Year unknown"}</span>
                        </li>
                      `,
                    )
                    .join("")}
                </ul>`
              : `<p class="mini-copy">No starter-paper preview was exported for this question in the ${contextLabel}.</p>`
          }
        </details>
      </div>
    `;
    for (const button of selectedQuestion.querySelectorAll("[data-mediator-id]")) {
      button.addEventListener("click", () => selectConcept(button.dataset.mediatorId));
    }
  };

  const renderGraph = () => {
    const nodeMarkup = [];
    const edgeMarkup = [];
    const visibleState = getVisibleGraphState();
    const selectedActive = Boolean(selectedId) && isInBackbone(selectedId);
    const activeQuestion = currentQuestion();
    const questionCounterpartId = activeQuestion
      ? activeQuestion.source_id === selectedId
        ? activeQuestion.target_id
        : activeQuestion.target_id === selectedId
          ? activeQuestion.source_id
          : null
      : null;
    const {
      focusedActive,
      nodes: visibleNodes,
      edges: visibleEdges,
      selectedNeighbors,
      labelNeighbors,
      renderPositionMap,
    } = visibleState;

    for (const edge of visibleEdges) {
      const source = graph.nodeMap.get(edge.source);
      const target = graph.nodeMap.get(edge.target);
      const sourceRender = nodeRenderState(source, renderPositionMap);
      const targetRender = nodeRenderState(target, renderPositionMap);
      const isSelected = selectedActive && (edge.source === selectedId || edge.target === selectedId);
      const isDimmed = mapMode === "global" && selectedActive && !isSelected;
      edgeMarkup.push(
        `<line class="graph-edge${isSelected ? " is-selected" : ""}${isDimmed ? " is-dimmed" : ""}${focusedActive ? " is-focused" : ""}" style="--edge-strength:${edge.strength || 0.3};" data-edge-id="${escapeHtml(edge.id)}" x1="${sourceRender.x}" y1="${sourceRender.y}" x2="${targetRender.x}" y2="${targetRender.y}"></line>`,
      );
    }

    for (const node of visibleNodes) {
      const isSelected = node.id === selectedId;
      const isQuestionTarget = Boolean(questionCounterpartId) && node.id === questionCounterpartId;
      const isNeighbor = selectedNeighbors.has(node.id);
      const isDimmed = mapMode === "global" && selectedActive && !isSelected && !isNeighbor && !isQuestionTarget;
      const renderState = nodeRenderState(node, renderPositionMap);
      const radius = focusedActive
        ? isSelected
          ? 26
          : isQuestionTarget
            ? 22
            : Math.max(12, Math.min(20, 11.5 + Math.log10(safeNumber(node.weighted_degree) + 1) * 2.4))
        : Math.max(2.8, Math.min(24, 2.8 + Math.log10(safeNumber(node.weighted_degree) + 1) * 4.4));
      const showLabel = focusedActive
        ? isSelected || isQuestionTarget || labelNeighbors.has(node.id)
        : node.show_label ||
          isSelected ||
          isQuestionTarget ||
          (isNeighbor && selectedNeighbors.size <= FOCUSED_NEIGHBOR_LIMIT) ||
          (isNeighbor && safeNumber(node.weighted_degree) >= 65);
      const label = node.plain_label || node.label;
      const labelWidth = estimateChipWidth(label);
      const labelAbove = focusedActive ? Math.sin(renderState.angle) <= 0 : true;
      const labelY = focusedActive
        ? renderState.y + (labelAbove ? -(radius + 18) : radius + 28)
        : renderState.y - (radius + (isSelected ? 16 : 8));
      const chipY = labelAbove ? labelY - 20 : labelY - 18;
      nodeMarkup.push(
        `<g class="graph-node-group${isSelected ? " is-selected" : ""}${isQuestionTarget ? " is-question-target" : ""}${isNeighbor ? " is-neighbor" : ""}${isDimmed ? " is-dimmed" : ""}" data-node-id="${escapeHtml(node.id)}">
          ${focusedActive ? `<circle class="graph-node-halo${isSelected ? " is-selected" : ""}${isQuestionTarget ? " is-question-target" : ""}${isNeighbor ? " is-neighbor" : ""}" cx="${renderState.x}" cy="${renderState.y}" r="${radius + (isSelected ? 10 : isQuestionTarget ? 8 : 7)}"></circle>` : ""}
          <circle class="graph-node" cx="${renderState.x}" cy="${renderState.y}" r="${radius}"></circle>
          ${
            showLabel
              ? focusedActive
                ? `<g class="graph-label-chip${isSelected ? " is-selected" : ""}${isQuestionTarget ? " is-question-target" : ""}${isNeighbor ? " is-neighbor" : ""}">
                    <rect x="${renderState.x - labelWidth / 2}" y="${chipY}" width="${labelWidth}" height="28" rx="14" ry="14"></rect>
                    <text class="graph-label graph-label-chip-text${isSelected ? " is-selected" : ""}${isQuestionTarget ? " is-question-target" : ""}${isNeighbor ? " is-neighbor" : ""}" x="${renderState.x}" y="${labelY}">${escapeHtml(label)}</text>
                  </g>`
                : `<text class="graph-label${isSelected ? " is-selected" : ""}${isQuestionTarget ? " is-question-target" : ""}${isNeighbor ? " is-neighbor" : ""}" x="${renderState.x}" y="${labelY}">${escapeHtml(label)}</text>`
              : ""
          }
        </g>`,
      );
    }

    canvas.innerHTML = `
      <g data-role="graph-viewport">
        <rect class="graph-pan-target" x="-900" y="-900" width="3200" height="2800"></rect>
        <g class="graph-edge-layer">${edgeMarkup.join("")}</g>
        <g class="graph-node-layer">${nodeMarkup.join("")}</g>
      </g>
    `;

    for (const nodeElement of canvas.querySelectorAll("[data-node-id]")) {
      const dragHandle = nodeElement.querySelector("circle");
      nodeElement.addEventListener("mouseenter", (event) => {
        const node = graph.nodeMap.get(nodeElement.dataset.nodeId);
        showTooltip(event, `
          <strong>${escapeHtml(node.plain_label || node.label)}</strong><br />
          ${node.subtitle ? `${escapeHtml(node.subtitle)}<br />` : ""}
          <span class="tooltip-action">Click to move to this topic.</span>
        `);
      });
      nodeElement.addEventListener("mousemove", moveTooltip);
      nodeElement.addEventListener("mouseleave", hideTooltip);
      const beginDrag = (event) => {
        if (!layoutMode) return;
        event.preventDefault();
        event.stopPropagation();
        startNodeDrag(nodeElement.dataset.nodeId);
      };
      dragHandle?.addEventListener("pointerdown", beginDrag);
      dragHandle?.addEventListener("mousedown", beginDrag);
      nodeElement.addEventListener("click", (event) => {
        event.stopPropagation();
        if (layoutMode) return;
        selectConcept(nodeElement.dataset.nodeId);
      });
    }

    for (const edgeElement of canvas.querySelectorAll("[data-edge-id]")) {
      edgeElement.addEventListener("mouseenter", (event) => {
        const edge = graph.edgeMap.get(edgeElement.dataset.edgeId);
        showTooltip(event, `
          <strong>${escapeHtml(conceptLabel(edge.source, graph.nodeMap.get(edge.source).label))} to ${escapeHtml(conceptLabel(edge.target, graph.nodeMap.get(edge.target).label))}</strong><br />
          ${formatNumber(safeNumber(edge.support_count))} papers mention this nearby directed relation.
        `);
      });
      edgeElement.addEventListener("mousemove", moveTooltip);
      edgeElement.addEventListener("mouseleave", hideTooltip);
    }

    setViewportTransform();
  };

  const renderSelectedConcept = (concept) => {
    const questionCount = currentOpportunities.length;
    selectedConcept.innerHTML = `
      <div class="graph-topic-strip-main">
        <span class="tiny-label">Selected topic</span>
        <div class="selected-title-row">
          <h3>${escapeHtml(conceptTitle(concept))}</h3>
        </div>
        ${conceptSubtitle(concept) ? `<p class="mini-copy opportunity-label-note">${escapeHtml(conceptSubtitle(concept))}</p>` : ""}
      </div>
      <div class="graph-topic-strip-meta">
        <span class="graph-topic-stat">${formatNumber(safeNumber(concept.distinct_paper_support))} papers in the ${contextLabel}</span>
        <span class="graph-topic-stat">${formatNumber(questionCount)} question candidates touch this topic</span>
      </div>
      <div class="button-row graph-topic-strip-actions">
        <button class="button-secondary" type="button" data-role="change-topic">Change topic</button>
      </div>
    `;
    const changeTopicButton = selectedConcept.querySelector('[data-role="change-topic"]');
    if (changeTopicButton instanceof HTMLButtonElement && searchInput instanceof HTMLInputElement) {
      changeTopicButton.addEventListener("click", () => {
        searchInput.focus();
        searchInput.select();
      });
    }
  };

  const renderNeighborhood = async (conceptId) => {
    currentNeighborhood = null;
    const shardPath = neighborhoodIndex[conceptId];
    if (!shardPath) {
      selectedNeighborhood.innerHTML = `<p class="card-copy">No nearby topics were exported for this topic in the ${contextLabel}.</p>`;
      renderQuestionDetail();
      return;
    }
    const shard = await fetchJson(shardPath);
    const neighborhood = shard[conceptId];
    currentNeighborhood = neighborhood || null;
    if (!neighborhood) {
      selectedNeighborhood.innerHTML = `<p class="card-copy">No nearby-topic entry was found for this topic in the ${contextLabel}.</p>`;
      renderQuestionDetail();
      return;
    }

    const compactTopics = Array.from(
      new Map(
        [...(neighborhood.top_neighbors || []), ...(neighborhood.incoming || []), ...(neighborhood.outgoing || [])]
          .filter((item) => item?.concept_id && item.concept_id !== conceptId)
          .map((item) => [item.concept_id, item]),
      ).values(),
    ).slice(0, 6);

    selectedNeighborhood.innerHTML = compactTopics.length
      ? `
        <div class="graph-topic-chip-list">
          ${compactTopics
            .map((item) => {
              const concept = conceptMap.get(item.concept_id);
              const label = concept ? conceptTitle(concept) : item.label;
              return `
                <button class="topic-chip-button" type="button" data-neighbor-id="${escapeHtml(item.concept_id)}">
                  <span>${escapeHtml(label)}</span>
                  <small>${formatNumber(safeNumber(item.support_count))} papers</small>
                </button>
              `;
            })
            .join("")}
        </div>
      `
      : `<p class="card-copy">No nearby topics were exported for this topic in the ${contextLabel}.</p>`;
    for (const button of selectedNeighborhood.querySelectorAll("[data-neighbor-id]")) {
      button.addEventListener("click", () => selectConcept(button.dataset.neighborId));
    }
    renderQuestionDetail();
  };

  const renderOpportunities = async (conceptId) => {
    currentOpportunities = [];
    const shardPath = opportunitiesIndex[conceptId];
    if (!shardPath) {
      selectedOpportunities.innerHTML = `<p class="card-copy">No public question candidate touching this topic is available in the ${contextLabel}.</p>`;
      renderQuestionDetail();
      return;
    }
    const shard = await fetchJson(shardPath);
    const opportunities = (shard[conceptId] || []).slice().sort((left, right) => {
      const delta = questionPriorityScore(right, conceptId) - questionPriorityScore(left, conceptId);
      if (Math.abs(delta) > 1e-9) return delta;
      return safeNumber(right.score) - safeNumber(left.score);
    });
    currentOpportunities = opportunities;
    if (!currentOpportunities.length) {
      activeQuestionPairKey = null;
      selectedOpportunities.innerHTML = `<p class="card-copy">No public question candidate touching this topic is available in the ${contextLabel}.</p>`;
      renderQuestionDetail();
      return;
    }
    activeQuestionPairKey = opportunities.some((item) => item.pair_key === activeQuestionPairKey)
      ? activeQuestionPairKey
      : opportunities[0]?.pair_key || null;

    const paintOpportunities = () => {
      selectedOpportunities.innerHTML = opportunities
        .slice(0, TOP_QUESTION_LIMIT)
        .map(
          (item) => {
            const counterpartLabel = conceptLabel(questionCounterpartId(item, conceptId), "Other topic");
            return `
            <button class="graph-question-row${item.pair_key === activeQuestionPairKey ? " is-active" : ""}" type="button" data-select-pair="${escapeAttr(item.pair_key)}">
              <span class="tiny-label">${escapeHtml(item.slice_label || "Question candidate")}</span>
              <strong>${escapeHtml(questionTitle(item))}</strong>
              <div class="graph-question-meta graph-question-meta-tight">
                <span>Other side: ${escapeHtml(counterpartLabel)}</span>
                <span>${formatNumber(safeNumber(item.supporting_path_count))} supporting paths</span>
                <span>${escapeHtml(questionProjectShapeLabel(item))}</span>
              </div>
            </button>
          `;
          },
        )
        .join("");
      for (const button of selectedOpportunities.querySelectorAll("[data-select-pair]")) {
        button.addEventListener("click", () => {
          activeQuestionPairKey = button.dataset.selectPair;
          paintOpportunities();
          renderSelectedConcept(conceptMap.get(conceptId));
          renderQuestionDetail();
          renderGraph();
        });
      }
    };

    paintOpportunities();
    renderSelectedConcept(conceptMap.get(conceptId));
    renderQuestionDetail();
  };

  const selectConcept = async (conceptId) => {
    if (!conceptId) return;
    selectedId = conceptId;
    const concept = conceptMap.get(conceptId);
    if (!concept) return;
    updateSelectionState();
    currentNeighborhood = null;
    currentOpportunities = [];
    activeQuestionPairKey = null;
    selectedNeighborhood.innerHTML = `<p class="card-copy">Loading nearby topics...</p>`;
    selectedOpportunities.innerHTML = `<p class="card-copy">Loading question candidates touching this topic...</p>`;
    if (selectedQuestion instanceof HTMLElement) {
      selectedQuestion.innerHTML = `<p class="card-copy">Loading path-based question detail...</p>`;
    }
    renderGraph();
    renderSelectedConcept(concept);
    restoreStatus();
    if (isInBackbone(conceptId)) {
      if (mapMode === "focused") {
        setDefaultViewport();
      } else {
        focusViewOnConcept(conceptId);
      }
    }
    await Promise.all([renderNeighborhood(conceptId), renderOpportunities(conceptId)]);
    renderSelectedConcept(concept);
    hideTooltip();
  };

  const runSearch = (query) => {
    const normalized = query.trim().toLowerCase();
    if (!normalized) {
      searchResults.innerHTML = "";
      return;
    }
    const matches = concepts
      .filter((concept) => concept.search_terms.some((term) => term.includes(normalized)))
      .sort((a, b) => b.weighted_degree - a.weighted_degree)
      .slice(0, 8);
    searchResults.innerHTML = matches
      .map(
        (concept) => `
          <button class="search-hit" data-concept-id="${escapeHtml(concept.concept_id)}">
            <strong>${escapeHtml(conceptTitle(concept))}</strong>
            <span>${formatNumber(safeNumber(concept.distinct_paper_support))} papers</span>
          </button>
        `,
      )
      .join("");
    for (const button of searchResults.querySelectorAll("[data-concept-id]")) {
      button.addEventListener("click", () => {
        searchResults.innerHTML = "";
        if (searchInput instanceof HTMLInputElement) searchInput.value = "";
        selectConcept(button.dataset.conceptId);
      });
    }
  };

  const restoreInitialLayout = () => {
    for (const node of graph.nodes) {
      const initial = graph.initialPositions.get(node.id);
      if (!initial) continue;
      node.x = initial.x;
      node.y = initial.y;
    }
    renderGraph();
    setDefaultViewport();
    if (selectedId) restoreStatus();
  };

  const bootstrap = async () => {
    const [graphPayload, conceptPayload, neighborhoodsPayload, opportunitiesPayload, centralPayload] = await Promise.all([
      fetchJson(graphPath),
      fetchJson(conceptIndexPath),
      fetchJson(neighborhoodsIndexPath),
      fetchJson(opportunitiesIndexPath),
      fetchJson(centralConceptsPath),
    ]);
    graph = {
      nodes: graphPayload.nodes.map((node) => ({ ...node })),
      edges: graphPayload.edges,
      nodeMap: new Map(graphPayload.nodes.map((node) => [node.id, { ...node }])),
      edgeMap: new Map(graphPayload.edges.map((edge) => [edge.id, edge])),
      initialPositions: new Map(graphPayload.nodes.map((node) => [node.id, { x: node.x, y: node.y }])),
    };
    graph.nodes = Array.from(graph.nodeMap.values());
    concepts = conceptPayload;
    conceptMap = new Map(concepts.map((concept) => [concept.concept_id, concept]));
    neighborhoodIndex = neighborhoodsPayload;
    opportunitiesIndex = opportunitiesPayload;
    centralConcepts = centralPayload;
    renderCentralList();
    updateSelectionState();
    updateLayoutModeButton();
    updateMapModeButton();
    const params = new URLSearchParams(window.location.search);
    const query = params.get("q");
    const exact = query
      ? concepts.find((concept) => {
          const needle = query.toLowerCase();
          return (concept.plain_label || concept.label).toLowerCase() === needle || concept.label.toLowerCase() === needle;
        })
      : null;
    if (exact) {
      await selectConcept(exact.concept_id);
    } else {
      restoreStatus();
    }
  };

  if (searchInput instanceof HTMLInputElement) {
    searchInput.addEventListener("input", (event) => runSearch(event.target.value));
  }
  if (resetView instanceof HTMLButtonElement) {
    resetView.addEventListener("click", setDefaultViewport);
  }
  if (toggleMapMode instanceof HTMLButtonElement) {
    toggleMapMode.addEventListener("click", () => {
      mapMode = mapMode === "focused" ? "global" : "focused";
      updateMapModeButton();
      renderGraph();
      setDefaultViewport();
      restoreStatus();
    });
  }

  canvas.addEventListener("wheel", (event) => {
    event.preventDefault();
    const factor = event.deltaY > 0 ? 1 / 1.08 : 1.08;
    zoomAtPoint(factor, event.clientX, event.clientY);
  }, { passive: false });

  canvas.addEventListener("pointerdown", (event) => {
    startPan(event.target, event.clientX, event.clientY);
  });
  canvas.addEventListener("mousedown", (event) => {
    startPan(event.target, event.clientX, event.clientY);
  });

  window.addEventListener("pointermove", (event) => {
    moveInteraction(event.clientX, event.clientY);
  });
  window.addEventListener("mousemove", (event) => {
    moveInteraction(event.clientX, event.clientY);
  });

  window.addEventListener("pointerup", () => {
    interaction = null;
  });
  window.addEventListener("mouseup", () => {
    interaction = null;
  });

  bootstrap().catch((error) => {
    hoverCard.textContent = "Literature map data failed to load.";
    console.error(error);
  });
</script>
