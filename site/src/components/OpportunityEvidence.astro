---
import type { RepresentativePaper } from "../lib/site-data";

interface Props {
  mediatorLabels?: string[];
  representativePapers?: RepresentativePaper[];
  directLinkStatus: string;
  commonContexts?: string;
}

const {
  mediatorLabels = [],
  representativePapers = [],
  directLinkStatus,
  commonContexts = "",
} = Astro.props;

const uniqueMediatorLabels = Array.from(new Set(mediatorLabels.filter(Boolean)));
const visiblePapers = representativePapers.filter((paper) => paper.title).slice(0, 3);
---

<details class="opportunity-detail" data-role="opportunity-evidence">
  <summary>Why this question</summary>
  <div class="method-stack opportunity-evidence">
    {uniqueMediatorLabels.length > 0 && (
      <p class="mini-copy">
        <strong>Related ideas:</strong> {uniqueMediatorLabels.join(", ")}
      </p>
    )}
    {visiblePapers.length > 0 && (
      <div class="mini-copy opportunity-paper-block">
        <strong>Papers to start with:</strong>
        <ul class="opportunity-paper-list">
          {visiblePapers.map((paper) => (
            <li>
              <span>{paper.title}</span>
              {paper.year > 0 && <span class="opportunity-paper-year">({paper.year})</span>}
            </li>
          ))}
        </ul>
      </div>
    )}
    <p class="mini-copy">
      <strong>Papers on this exact question:</strong> {directLinkStatus}
    </p>
    {commonContexts && (
      <p class="mini-copy">
        <strong>Common contexts:</strong> {commonContexts}
      </p>
    )}
  </div>
</details>
