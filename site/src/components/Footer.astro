---
const year = new Date().getFullYear();

interface Props {
  navPrefix?: string;
}

const { navPrefix = "" } = Astro.props;
---

<footer class="site-footer">
  <div>
    <div class="footer-title">Frontier Graph</div>
    <p class="footer-copy">
      Questions, literature graph, paper, and public data from the Frontier Graph release.
    </p>
  </div>
  <div class="footer-links">
    <a href={navPrefix ? `${navPrefix}/questions/` : "/questions/"}>Questions</a>
    <a href={navPrefix ? `${navPrefix}/literature/` : "/literature/"}>Literature Graph</a>
    <a href={navPrefix ? `${navPrefix}/graph/` : "/graph/"}>Graph</a>
    <a href="/about/">About</a>
    <a href={navPrefix ? `${navPrefix}/paper/` : "/paper/"}>Paper</a>
    <a href={navPrefix ? `${navPrefix}/downloads/` : "/downloads/"}>Downloads</a>
    <a href="mailto:prashant.garg@imperial.ac.uk">Contact</a>
  </div>
  <div class="footer-meta">Copyright {year} Frontier Graph</div>
</footer>
