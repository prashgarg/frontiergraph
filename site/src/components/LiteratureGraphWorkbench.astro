      });
    }

    if (thirdRingIds.length) {
      const radiusX = 700;
      const radiusY = 470;
      const step = (Math.PI * 2) / thirdRingIds.length;
      thirdRingIds.forEach((neighborId, index) => {
        const angle = -Math.PI / 2 + step * index + Math.PI / Math.max(thirdRingIds.length, 6) / 2;
        positionMap.set(neighborId, {
          x: centerX + Math.cos(angle) * radiusX,
          y: centerY + Math.sin(angle) * radiusY,
          angle,
        });
      });
    }

    return positionMap;
  };

  const nodeRenderState = (node, renderPositionMap) => {
    const focusedPosition = renderPositionMap?.get(node.id);
    if (focusedPosition) return focusedPosition;
    return {
      x: node.x * GRAPH_WIDTH,
      y: node.y * GRAPH_HEIGHT,
      angle: -Math.PI / 2,
    };
  };

  const computeVisibleGraphState = ({
    rootId = rootConceptId,
    selectedConceptId = selectedId,
    mode = mapMode,
    depth = hopDepth,
    layers = layerState,
    includeQuestionState = true,
    neighborhood = null,
  } = {}) => {
    const selectedActive = Boolean(rootId);
    const rootBackbone = Boolean(rootId && isInBackbone(rootId));
    const { counterpartId, mediatorIds } = includeQuestionState
      ? getPathHighlightState(selectedConceptId)
      : { activeQuestion: null, counterpartId: null, mediatorIds: [] };

    if ((mode === "global" && rootBackbone) || !selectedActive) {
      return {
        focusedActive: false,
        nodes: graph.nodes,
        edges: graph.edges,
        firstRing: new Set(),
        secondRing: new Set(),
        thirdRing: new Set(),
        counterpartId,
        mediatorIds: new Set(mediatorIds),
        firstRingLabels: new Set(),
        renderPositionMap: null,
      };
    }

    const proxy = rootBackbone ? null : getProxyRootNeighbors(rootId, FIRST_RING_LIMIT, neighborhood);
    const firstRingIds = layers.stableAnchors
      ? rootBackbone
        ? getRankedNeighbors(rootId, FIRST_RING_LIMIT, new Set([rootId]))
        : proxy.neighborIds
      : [];
    const secondRingIds = depth > 1 && layers.bridgeTopics ? buildSecondRing(rootId, firstRingIds) : [];
    const thirdRingIds = depth > 1 && layers.fringeTopics ? buildThirdRing(rootId, firstRingIds, secondRingIds) : [];
    const visibleIds = new Set([rootId, ...firstRingIds, ...secondRingIds, ...thirdRingIds]);
    if (layers.questions && counterpartId) visibleIds.add(counterpartId);
    if (layers.paths) mediatorIds.forEach((conceptId) => visibleIds.add(conceptId));

    const firstRingSet = new Set(firstRingIds);
    const secondRingSet = new Set(secondRingIds);
    const thirdRingSet = new Set(thirdRingIds);
    const firstRingLabels = new Set(firstRingIds.slice(0, 8));
    const highlightSet = new Set([
      ...(layers.questions && counterpartId ? [counterpartId] : []),
      ...(layers.paths ? mediatorIds : []),
    ].filter(Boolean));

    const visibleBackboneEdges = graph.edges.filter((edge) => {
      if (!visibleIds.has(edge.source) || !visibleIds.has(edge.target)) return false;
      return (
        (rootBackbone && (edge.source === rootId || edge.target === rootId)) ||
        firstRingSet.has(edge.source) ||
        firstRingSet.has(edge.target) ||
        secondRingSet.has(edge.source) ||
        secondRingSet.has(edge.target) ||
        highlightSet.has(edge.source) ||
        highlightSet.has(edge.target)
      );
    });

    const proxyEdges = !rootBackbone
      ? firstRingIds.map((neighborId) => {
          const supportCount = proxy.supportByNeighbor.get(neighborId) || 0;
          return {
            id: `proxy-root-${rootId}-${neighborId}`,
            source: rootId,
            target: neighborId,
            support_count: supportCount,
            strength: clamp(0.22 + Math.log10(supportCount + 1) * 0.28, 0.22, 0.95),
            synthetic: true,
          };
        })
      : [];

    const visibleNodes = rootBackbone
      ? graph.nodes.filter((node) => visibleIds.has(node.id))
      : [
          buildSyntheticNode(rootId),
          ...graph.nodes.filter((node) => visibleIds.has(node.id) && node.id !== rootId),
        ].filter(Boolean);

    return {
      focusedActive: true,
      nodes: visibleNodes,
      edges: [...proxyEdges, ...visibleBackboneEdges],
      firstRing: firstRingSet,
      secondRing: secondRingSet,
      thirdRing: thirdRingSet,
      counterpartId,
      mediatorIds: new Set(mediatorIds),
      firstRingLabels,
      renderPositionMap: buildLocalPositionMap(rootId, firstRingIds, secondRingIds, thirdRingIds),
    };
  };

  const getVisibleGraphState = () => computeVisibleGraphState();

  const setViewportTransform = () => {
    const viewport = canvas?.querySelector('[data-role="graph-viewport"]');
    if (!(viewport instanceof SVGGElement)) return;
    viewport.setAttribute(
      "transform",
      `translate(${viewState.translateX} ${viewState.translateY}) scale(${viewState.scale})`,
    );
  };

  const screenToCanvasPoint = (clientX, clientY) => {
    const rect = canvas.getBoundingClientRect();
    const x = ((clientX - rect.left) / rect.width) * GRAPH_WIDTH;
    const y = ((clientY - rect.top) / rect.height) * GRAPH_HEIGHT;
    return {
      x,
      y,
      graphX: (x - viewState.translateX) / viewState.scale,
      graphY: (y - viewState.translateY) / viewState.scale,
    };
  };

  const zoomAtPoint = (factor, clientX, clientY) => {
    const { x, y, graphX, graphY } = screenToCanvasPoint(clientX, clientY);
    const nextScale = clamp(viewState.scale * factor, MIN_SCALE, MAX_SCALE);
    viewState = {
      scale: nextScale,
      translateX: x - graphX * nextScale,
      translateY: y - graphY * nextScale,
    };
    setViewportTransform();
  };

  const zoomAroundCanvasCenter = (factor) => {
    const rect = canvas.getBoundingClientRect();
    zoomAtPoint(factor, rect.left + rect.width / 2, rect.top + rect.height / 2);
  };

  const resetViewportTransform = () => {
    viewState = {
      scale: DEFAULT_GLOBAL_SCALE,
      translateX: (GRAPH_WIDTH * (1 - DEFAULT_GLOBAL_SCALE)) / 2,
      translateY: (GRAPH_HEIGHT * (1 - DEFAULT_GLOBAL_SCALE)) / 2,
    };
    setViewportTransform();
  };

  const fitViewToNodeIds = (nodeIds, padding = 100, zoomOutFactor = 0.98) => {
    if (!graph || !nodeIds.length) {
      resetViewportTransform();
      return;
    }
    const visibleState = getVisibleGraphState();
    const visibleNodeMap = new Map(visibleState.nodes.map((node) => [node.id, node]));
    const nodes = nodeIds
      .map((nodeId) => visibleNodeMap.get(nodeId) || graph.nodeMap.get(nodeId) || (nodeId === rootConceptId ? buildSyntheticNode(nodeId) : null))
      .filter(Boolean);
    if (!nodes.length) {
      resetViewportTransform();
      return;
    }
    const xs = nodes.map((node) => nodeRenderState(node, visibleState.renderPositionMap).x);
    const ys = nodes.map((node) => nodeRenderState(node, visibleState.renderPositionMap).y);
    const minX = Math.min(...xs);
    const maxX = Math.max(...xs);
    const minY = Math.min(...ys);
    const maxY = Math.max(...ys);
    const spanX = Math.max(maxX - minX, 150);
    const spanY = Math.max(maxY - minY, 150);
    const nextScale = clamp(
      Math.min((GRAPH_WIDTH - padding * 2) / spanX, (GRAPH_HEIGHT - padding * 2) / spanY) * zoomOutFactor,
      MIN_SCALE,
      MAX_SCALE,
    );
    const centerX = (minX + maxX) / 2;
    const centerY = (minY + maxY) / 2;
    viewState = {
      scale: nextScale,
      translateX: GRAPH_WIDTH / 2 - centerX * nextScale,
      translateY: GRAPH_HEIGHT / 2 - centerY * nextScale,
    };
    setViewportTransform();
  };

  const setDefaultViewport = () => {
    if (!graph) return;
    if (mapMode === "local" && rootConceptId) {
      fitViewToNodeIds(getVisibleGraphState().nodes.map((node) => node.id), 100, 0.98);
      return;
    }
    resetViewportTransform();
  };

  const moveTooltip = (event) => {
    if (!(graphTooltip instanceof HTMLElement) || graphTooltip.hidden) return;
    const shell = graphTooltip.parentElement;
    if (!(shell instanceof HTMLElement)) return;
    const shellRect = shell.getBoundingClientRect();
    const maxLeft = shell.clientWidth - graphTooltip.offsetWidth - 12;
    const maxTop = shell.clientHeight - graphTooltip.offsetHeight - 12;
    const left = clamp(event.clientX - shellRect.left + 14, 12, Math.max(12, maxLeft));
    const top = clamp(event.clientY - shellRect.top + 14, 12, Math.max(12, maxTop));
    graphTooltip.style.left = `${left}px`;
    graphTooltip.style.top = `${top}px`;
  };

  const showTooltip = (event, html) => {
    if (!(graphTooltip instanceof HTMLElement)) return;
    graphTooltip.innerHTML = html;
    graphTooltip.hidden = false;
    moveTooltip(event);
  };

  const hideTooltip = () => {
    if (!(graphTooltip instanceof HTMLElement)) return;
    graphTooltip.hidden = true;
  };

  const updateDepthButtons = () => {
    if (depthOneButton instanceof HTMLButtonElement) depthOneButton.classList.toggle("is-active", hopDepth === 1);
    if (depthTwoButton instanceof HTMLButtonElement) depthTwoButton.classList.toggle("is-active", hopDepth === 2);
  };

  const updateMapModeButton = () => {
    if (!(toggleMapMode instanceof HTMLButtonElement)) return;
    if (rootConceptId && !rootIsInBackbone()) {
      toggleMapMode.textContent = "Backbone unavailable";
      toggleMapMode.classList.remove("is-active");
      toggleMapMode.disabled = true;
      return;
    }
    const showGlobal = mapMode === "global";
    toggleMapMode.textContent = showGlobal ? "Return to local map" : "Show backbone";
    toggleMapMode.classList.toggle("is-active", showGlobal);
    toggleMapMode.disabled = false;
  };

  const setPanelTab = (nextTab) => {
    panelTab = nextTab;
    for (const button of panelTabButtons) {
      const isActive = button.dataset.tab === nextTab;
      button.classList.toggle("is-active", isActive);
      button.setAttribute("aria-selected", isActive ? "true" : "false");
    }
    for (const section of panelSections) {
      section.hidden = section.dataset.panel !== nextTab;
    }
  };

  const updatePanelTabLabels = () => {
    const selectedEdge = currentVisibleEdge();
    const paperCount = selectedEdge ? safeNumber(selectedEdge.support_count) : 0;
    for (const button of panelTabButtons) {
      const tab = button.dataset.tab || "";
      if (tab === "papers") {
        button.textContent = selectedEdge && paperCount ? `Papers (${formatNumber(paperCount)})` : "Papers";
      } else if (tab === "paths") {
        button.textContent = "Paths";
      } else {
        button.textContent = "Overview";
      }
    }
  };

  const restoreStatus = () => {
    if (!(hoverCard instanceof HTMLElement)) return;
    const concept = rootConceptId ? conceptMap.get(rootConceptId) : null;
    const inspectedConcept = selectedId ? conceptMap.get(selectedId) : null;
    const activeQuestion = currentQuestion();
    const selectedEdge = currentVisibleEdge();
    if (selectedEdge) {
      hoverCard.textContent = `Inspecting edge: ${edgeTitle(selectedEdge)}`;
      return;
    }
    if (activeQuestion) {
      hoverCard.textContent = `Viewing nearby route touching ${questionSideLabel(activeQuestion, "source")} and ${questionSideLabel(activeQuestion, "target")}.`;
      return;
    }
    if (concept) {
      if (!rootIsInBackbone()) {
        hoverCard.textContent = `Proxy local map for unstable topic: ${conceptTitle(concept)}.`;
        return;
      }
      if (inspectedConcept && inspectedConcept.concept_id !== rootConceptId) {
        hoverCard.textContent = `Inspecting ${conceptTitle(inspectedConcept)} inside a ${hopDepth}-hop map rooted in ${conceptTitle(concept)}.`;
        return;
      }
      hoverCard.textContent = mapMode === "global"
        ? `Backbone view around ${conceptTitle(concept)}. Double-click a node to return to a local map there.`
        : `Local ${hopDepth}-hop map around ${conceptTitle(concept)}.`;
      return;
    }
    hoverCard.textContent = "Choose a topic to open its local literature map.";
  };

  const renderCentralList = () => {
    if (!(centralList instanceof HTMLElement)) return;
    const chosen = new Set();
    const contextNeighborhood =
      currentNeighborhood ||
      (rootConceptId && selectedId !== rootConceptId ? rootNeighborhood : null);
    const pivotCandidates = contextNeighborhood
      ? getNeighborhoodItems(contextNeighborhood)
          .filter((item) => item?.concept_id && item.concept_id !== rootConceptId)
          .sort((left, right) => safeNumber(right.support_count) - safeNumber(left.support_count))
          .slice(0, 6)
      : [];
    const recentRoots = navHistory
      .slice()
      .reverse()
      .map((entry) => entry.rootConceptId)
      .filter(Boolean)
      .filter((conceptId, index, list) => list.indexOf(conceptId) === index)
      .filter((conceptId) => conceptId !== rootConceptId)
      .slice(0, 4)
      .map((conceptId) => conceptMap.get(conceptId))
      .filter(Boolean);
    const manualStartingConcepts = STARTING_TOPIC_LABELS.map((label) =>
      concepts.find((concept) => String(concept.plain_label || concept.label || "").trim().toLowerCase() === label),
    ).filter(Boolean);
    const defaultConcepts = [...manualStartingConcepts, ...centralConcepts]
      .filter(Boolean)
      .filter((concept) => concept.concept_id !== rootConceptId)
      .filter((concept, index, list) => list.findIndex((item) => item.concept_id === concept.concept_id) === index)
      .slice(0, 8);

    const renderSection = (title, rows) => {
      if (!rows.length) return "";
      return `
        <div class="literature-suggestion-section">
          <span class="tiny-label">${escapeHtml(title)}</span>
          <div class="literature-suggestion-buttons">
            ${rows.join("")}
          </div>
        </div>
      `;
    };

    const pivotButtons = pivotCandidates
      .map((item) => {
        if (chosen.has(item.concept_id)) return "";
        chosen.add(item.concept_id);
        const concept = conceptMap.get(item.concept_id);
        const label = concept ? conceptTitle(concept) : item.label;
        return `
          <button class="list-link" data-concept-id="${escapeHtml(item.concept_id)}">
            <span>${escapeHtml(label)}</span>
            <span>${formatNumber(safeNumber(item.support_count))} papers</span>
          </button>
        `;
      })
      .filter(Boolean);
    const recentButtons = recentRoots
      .map((concept) => {
        if (!concept || chosen.has(concept.concept_id)) return "";
        chosen.add(concept.concept_id);
        return `
          <button class="list-link" data-concept-id="${escapeHtml(concept.concept_id)}">
            <span>${escapeHtml(conceptTitle(concept))}</span>
            <span>Recent root</span>
          </button>
        `;
      })
      .filter(Boolean);
    const defaultButtons = defaultConcepts
      .map((concept) => {
        if (!concept || chosen.has(concept.concept_id)) return "";
        chosen.add(concept.concept_id);
        return `
          <button class="list-link" data-concept-id="${escapeHtml(concept.concept_id)}">
            <span>${escapeHtml(conceptTitle(concept))}</span>
            <span>${formatNumber(safeNumber(concept.distinct_paper_support))} papers</span>
          </button>
        `;
      })
      .filter(Boolean);

    centralList.innerHTML = [
      renderSection(pivotButtons.length ? "Pivot from here" : "", pivotButtons),
      renderSection(recentButtons.length ? "Recent roots" : "", recentButtons),
      renderSection("Start over", defaultButtons),
    ].join("");
    for (const button of centralList.querySelectorAll("[data-concept-id]")) {
      button.addEventListener("click", () => selectConcept(button.dataset.conceptId, { rebuildMap: true, switchToOverview: true }));
    }
  };

  const renderSearchResults = (matches) => {
    if (!(searchResults instanceof HTMLElement)) return;
    if (!matches.length) {
      searchResults.innerHTML = `<div class="search-hit search-hit-empty"><span>No close matches in the current literature index.</span></div>`;
      return;
    }
    searchResults.innerHTML = matches
      .map((entity) => {
        const scopeType = scopeTypeForEntity(entity);
        const primaryConceptId = entityPrimaryConceptId(entity);
        const paperCount = entityDistinctPaperSupport(entity);
        const metaBits = [
          entity.badge || "",
          scopeType ? humanizeScopeType(scopeType) : "",
          paperCount ? `${formatNumber(paperCount)} papers` : "",
        ].filter(Boolean);
        return `
          <button class="search-hit search-hit-rich" type="button" data-entity-id="${escapeAttr(entity.id || primaryConceptId)}">
            <div class="search-hit-copy">
              <strong>${escapeHtml(entityLabel(entity) || conceptLabel(primaryConceptId, ""))}</strong>
              ${entity.subtitle ? `<small>${escapeHtml(entity.subtitle)}</small>` : ""}
              <div class="search-hit-meta">
                ${metaBits.map((bit, index) => `<span class="search-hit-pill${index === 0 ? " is-badge" : ""}">${escapeHtml(bit)}</span>`).join("")}
              </div>
            </div>
            <span class="search-hit-action">${scopeType ? "Add" : "Open"}</span>
          </button>
        `;
      })
      .join("");
  };

  const clearSearchUi = () => {
    if (searchResults instanceof HTMLElement) searchResults.innerHTML = "";
    if (searchInput instanceof HTMLInputElement) searchInput.value = "";
  };

  const nearbyTopicItems = () =>
    Array.from(
      new Map(
        [...(currentNeighborhood?.top_neighbors || []), ...(currentNeighborhood?.incoming || []), ...(currentNeighborhood?.outgoing || [])]
          .filter((item) => item?.concept_id && item.concept_id !== selectedId)
          .map((item) => [item.concept_id, item]),
      ).values(),
    );

  const paperPreviewItems = () => {
    const selectedEdge = currentVisibleEdge();
    if (selectedEdge) {
      const summary = edgePairSummary(selectedEdge);
      return [
        ...((summary?.x_to_y?.examples || [])),
        ...((summary?.y_to_x?.examples || [])),
        ...((summary?.undirected?.examples || [])),
        ...((selectedEdge.examples || [])),
      ]
        .filter((item) => item?.title)
        .slice(0, 8);
    }

    const seedQuestions = currentQuestion() ? [currentQuestion()] : currentOpportunities.slice(0, 3);
    const dedupedPapers = [];
    const seen = new Set();
    for (const item of seedQuestions) {
      for (const paper of Array.isArray(item.representative_papers) ? item.representative_papers : []) {
        const key = `${paper.title || ""}::${paper.year || ""}`;
        if (!paper?.title || seen.has(key)) continue;
        seen.add(key);
        dedupedPapers.push({ ...paper });
        if (dedupedPapers.length >= 8) break;
      }
      if (dedupedPapers.length >= 8) break;
    }
    return dedupedPapers;
  };

  const openDetailSheet = (kind) => {
    if (!(detailSheet instanceof HTMLDialogElement)) return;
    detailSheetState = { open: true, kind };
    renderDetailSheet();
    if (!detailSheet.open) detailSheet.showModal();
  };

  const closeDetailSheet = () => {
    detailSheetState = { open: false, kind: null };
    if (detailSheet instanceof HTMLDialogElement && detailSheet.open) detailSheet.close();
  };

  const renderDetailSheet = () => {
    if (!(detailSheetTitle instanceof HTMLElement) || !(detailSheetBody instanceof HTMLElement)) return;
    if (!detailSheetState.kind) {
      detailSheetTitle.textContent = "Full list";
      detailSheetBody.innerHTML = `<p class="card-copy">More detail will appear here.</p>`;
      return;
    }

    if (detailSheetState.kind === "topics") {
      const items = nearbyTopicItems();
      detailSheetTitle.textContent = "Nearby topics";
      detailSheetBody.innerHTML = items.length
        ? `
          <div class="literature-detail-list">
            ${items
              .map((item) => {
                const neighbor = conceptMap.get(item.concept_id);
                const label = neighbor ? conceptTitle(neighbor) : item.label;
                return `
                  <button class="literature-detail-row" type="button" data-sheet-neighbor-id="${escapeAttr(item.concept_id)}">
                    <div>
                      <strong>${escapeHtml(label)}</strong>
                      <small>${escapeHtml(neighbor?.subtitle || "")}</small>
                    </div>
                    <span>${formatNumber(safeNumber(item.support_count))} papers</span>
                  </button>
                `;
              })
              .join("")}
          </div>
        `
        : `<p class="card-copy">No nearby topics were exported for this selection.</p>`;
      for (const button of detailSheetBody.querySelectorAll("[data-sheet-neighbor-id]")) {
        button.addEventListener("click", () => {
          closeDetailSheet();
          selectConcept(button.dataset.sheetNeighborId, { rebuildMap: true, switchToOverview: true });
        });
      }
      return;
    }

    if (detailSheetState.kind === "paths") {
      const selectedEdge = currentVisibleEdge();
      if (selectedEdge) {
        const summary = edgePairSummary(selectedEdge);
        const exampleTexts = [
          ...((summary?.x_to_y?.examples || []).map((item) => item.claim_text || item.evidence_text || item.title)),
          ...((summary?.y_to_x?.examples || []).map((item) => item.claim_text || item.evidence_text || item.title)),
          ...((summary?.undirected?.examples || []).map((item) => item.claim_text || item.evidence_text || item.title)),
          ...((selectedEdge.examples || []).map((item) => item.claim_text || item.evidence_text || item.title)),
        ].filter(Boolean);
        detailSheetTitle.textContent = "Edge evidence";
        detailSheetBody.innerHTML = exampleTexts.length
          ? `
            <div class="literature-detail-list">
              ${exampleTexts
                .map(
                  (text, index) => `
                    <article class="literature-paper-card">
                      <span class="tiny-label">Evidence ${index + 1}</span>
                      <p class="mini-copy">${escapeHtml(text)}</p>
                    </article>
                  `,
                )
                .join("")}
            </div>
          `
          : `<p class="card-copy">No example claims were exported for this edge.</p>`;
        return;
      }
      detailSheetTitle.textContent = "Nearby paths";
      detailSheetBody.innerHTML = currentOpportunities.length
        ? `
          <div class="literature-detail-list">
            ${currentOpportunities
              .map((item) => {
                const counterpartId =
                  item.source_id === selectedId ? item.target_id : item.target_id === selectedId ? item.source_id : null;
                return `
                  <button class="literature-detail-row" type="button" data-sheet-pair-key="${escapeAttr(item.pair_key)}">
                    <div>
                      <strong>${escapeHtml(questionTitle(item))}</strong>
                      <small>${escapeHtml(conciseQuestionReason(item))}</small>
                    </div>
                    <span>${formatNumber(safeNumber(item.supporting_path_count))} paths · ${escapeHtml(conceptLabel(counterpartId, "Other topic"))}</span>
                  </button>
                `;
              })
              .join("")}
          </div>
        `
        : `<p class="card-copy">No path candidates are available for this topic.</p>`;
      for (const button of detailSheetBody.querySelectorAll("[data-sheet-pair-key]")) {
        button.addEventListener("click", () => {
          activeQuestionPairKey = button.dataset.sheetPairKey || null;
          selectedEdgeId = null;
          setPanelTab("paths");
          closeDetailSheet();
          renderPaths();
          renderPapers();
          renderGraph();
          restoreStatus();
        });
      }
      return;
    }

    detailSheetTitle.textContent = "Anchor papers";
    const papers = paperPreviewItems();
    detailSheetBody.innerHTML = papers.length
      ? `
        <div class="literature-detail-list literature-detail-paper-list">
          ${papers.map((paper) => renderPaperRow(paper)).join("")}
        </div>
      `
      : `<p class="card-copy">No paper previews were exported for this selection.</p>`;
  };

  const renderSelectedConcept = (concept) => {
    if (!(selectedConcept instanceof HTMLElement)) return;
    const selectedEdge = currentVisibleEdge();
    if (selectedEdge) {
      selectedConcept.innerHTML = `
        <div class="literature-summary">
          <div class="literature-summary-copy">
            <span class="tiny-label">Selected edge</span>
            <h2>${escapeHtml(edgeTitle(selectedEdge))}</h2>
            <p class="mini-copy literature-root-note">${escapeHtml(edgeDirectionSummary(selectedEdge))} within the current local neighborhood.</p>
          </div>
          <div class="literature-summary-stats literature-summary-stats-edge">
            <span class="graph-topic-stat">${formatNumber(safeNumber(selectedEdge.support_count))} papers</span>
            <span class="graph-topic-stat">${escapeHtml(edgeDirectionBadge(selectedEdge))}</span>
            ${edgeSignBadge(selectedEdge) ? `<span class="graph-topic-stat">${escapeHtml(edgeSignBadge(selectedEdge).replace("Net sign", "reported sign"))}</span>` : ""}
            ${edgeRelationshipBadge(selectedEdge) ? `<span class="graph-topic-stat">${escapeHtml(edgeRelationshipBadge(selectedEdge))}</span>` : ""}
            ${edgeRoleBadge(selectedEdge) ? `<span class="graph-topic-stat">${escapeHtml(edgeRoleBadge(selectedEdge))}</span>` : ""}
          </div>
        </div>
      `;
      return;
    }
    const rootConcept = rootConceptId ? conceptMap.get(rootConceptId) : null;
    const isMapRoot = concept.concept_id === rootConceptId;
    const rootNotBackbone = Boolean(rootConceptId) && !rootIsInBackbone();
    selectedConcept.innerHTML = `
      <div class="literature-summary">
        <div class="literature-summary-copy">
          <span class="tiny-label">${isMapRoot ? "Selected topic" : "Inspected topic"}</span>
          <h2>${escapeHtml(conceptTitle(concept))}</h2>
          ${conceptSubtitle(concept) ? `<p class="mini-copy">${escapeHtml(conceptSubtitle(concept))}</p>` : ""}
          ${
            rootConcept && !isMapRoot
              ? `<p class="mini-copy literature-root-note">Rooted in <strong>${escapeHtml(conceptTitle(rootConcept))}</strong>.</p>`
              : ""
          }
          ${
            queryState?.label && queryState.label !== conceptTitle(rootConcept || concept)
              ? `<p class="mini-copy literature-root-note">Query: <strong>${escapeHtml(queryState.label)}</strong></p>`
              : ""
          }
          ${
            rootNotBackbone
              ? `<p class="mini-copy literature-root-note">This topic is searchable but not stable enough for a local graph view yet. Showing nearby supported topics up to ${hopDepth} hops away.</p>`
              : ""
          }
        </div>
        <div class="literature-summary-stats">
          <span class="graph-topic-stat">${formatNumber(safeNumber(concept.distinct_paper_support))} papers</span>
          <span class="graph-topic-stat">${formatNumber(currentOpportunities.length)} paths</span>
          <span class="graph-topic-stat">${hopDepth}-hop local map</span>
        </div>
        <div class="button-row literature-summary-actions">
          ${!isMapRoot ? `<button class="button-secondary" type="button" data-role="rebuild-map-here">Rebuild map here</button>` : ""}
          <button class="button-tertiary" type="button" data-role="change-topic">Change topic</button>
        </div>
      </div>
    `;
    const button = selectedConcept.querySelector('[data-role="change-topic"]');
    if (button instanceof HTMLButtonElement && searchInput instanceof HTMLInputElement) {
      button.addEventListener("click", () => {
        searchInput.focus();
        searchInput.select();
      });
    }
    const rebuildButton = selectedConcept.querySelector('[data-role="rebuild-map-here"]');
    if (rebuildButton instanceof HTMLButtonElement) {
      rebuildButton.addEventListener("click", () => {
        selectConcept(concept.concept_id, { rebuildMap: true, switchToOverview: false });
      });
    }
  };

  const renderOverview = () => {
    if (!(selectedNeighborhood instanceof HTMLElement)) return;
    const selectedEdge = currentVisibleEdge();
    if (selectedEdge) {
      const summary = edgePairSummary(selectedEdge);
      const dominantCountries = summary?.dominant_countries || selectedEdge.dominant_countries || [];
      const dominantUnits = summary?.dominant_units || selectedEdge.dominant_units || [];
      const dominantYears = summary?.dominant_years || selectedEdge.dominant_years || [];
      const sourceLabel = conceptLabel(selectedEdge.source, selectedEdge.source);
      const targetLabel = conceptLabel(selectedEdge.target, selectedEdge.target);
      const bucketStrip = (title, bucket) => {
        if (!bucket || !safeNumber(bucket.support_count)) return "";
        return `
          <article class="literature-edge-strip">
            <div class="literature-edge-strip-head">
              <strong>${escapeHtml(title)}</strong>
              <span class="graph-topic-stat graph-topic-stat-compact">${formatNumber(safeNumber(bucket.support_count))} papers</span>
            </div>
            <div class="literature-edge-pill-row">
              <span class="graph-topic-stat graph-topic-stat-compact">${escapeHtml(signBreakdownLabel(bucket))}</span>
              ${bucket?.net_sign !== null && bucket?.net_sign !== undefined ? `<span class="graph-topic-stat graph-topic-stat-compact">reported sign ${escapeHtml(formatNetSign(bucket.net_sign))}</span>` : ""}
              ${compactMixSummary(bucket?.method_mix, 2) ? `<span class="graph-topic-stat graph-topic-stat-compact">${escapeHtml(compactMixSummary(bucket.method_mix, 2))}</span>` : ""}
              ${compactMixSummary(bucket?.claim_status_mix, 2) ? `<span class="graph-topic-stat graph-topic-stat-compact">${escapeHtml(compactMixSummary(bucket.claim_status_mix, 2))}</span>` : ""}
            </div>
          </article>
        `;
      };
      const fallbackMixes = [
        compactMixSummary(selectedEdge.directionality_mix, 3),
        compactMixSummary(selectedEdge.relationship_type_mix, 3),
        compactMixSummary(selectedEdge.edge_role_mix, 3),
      ].filter(Boolean);
      selectedNeighborhood.innerHTML = `
        <div class="literature-panel-stack literature-panel-stack-edge">
          <section class="question-detail-panel literature-compact-panel">
            <h3>Relationship summary</h3>
            <p class="mini-copy literature-panel-note">${escapeHtml(edgeDirectionSummary(selectedEdge))}</p>
            ${
              summary
                ? `
                  <div class="literature-edge-strip-list">
                    ${bucketStrip(`${sourceLabel} → ${targetLabel}`, summary?.x_to_y)}
                    ${bucketStrip(`${targetLabel} → ${sourceLabel}`, summary?.y_to_x)}
                    ${bucketStrip(`${sourceLabel} ↔ ${targetLabel}`, summary?.undirected)}
                  </div>
                `
                : `
                  <div class="literature-edge-pill-row">
                    ${fallbackMixes.map((value) => `<span class="graph-topic-stat graph-topic-stat-compact">${escapeHtml(value)}</span>`).join("")}
                  </div>
                `
            }
            ${
              dominantCountries.length || dominantUnits.length || dominantYears.length
                ? `
                  <div class="literature-edge-context-row">
                    ${dominantCountries.length ? `<span class="graph-topic-stat graph-topic-stat-compact">Countries: ${escapeHtml(dominantCountries.slice(0, 3).map((item) => item.value || item).join(", "))}</span>` : ""}
                    ${dominantUnits.length ? `<span class="graph-topic-stat graph-topic-stat-compact">Units: ${escapeHtml(dominantUnits.slice(0, 3).map((item) => item.value || item).join(", "))}</span>` : ""}
                    ${dominantYears.length ? `<span class="graph-topic-stat graph-topic-stat-compact">Years: ${escapeHtml(dominantYears.slice(0, 3).map((item) => item.value || item).join(", "))}</span>` : ""}
                  </div>
                `
                : ""
            }
          </section>
        </div>
      `;
      return;
    }
    const concept = selectedId ? conceptMap.get(selectedId) : null;
    if (!concept) {
      selectedNeighborhood.innerHTML = `<p class="card-copy">Choose a topic to inspect this map.</p>`;
      return;
    }

    selectedNeighborhood.innerHTML = `
      <section class="question-detail-panel literature-compact-panel">
        <details class="literature-collapsible">
          <summary>About this view</summary>
          <div class="graph-question-meta">
            <span>${formatNumber(safeNumber(concept.weighted_degree))} weighted links</span>
            <span>${formatNumber(currentOpportunities.length)} nearby routes</span>
            <span>${mapMode === "global" ? "Backbone view" : "Local view"}</span>
          </div>
          ${layerState.context ? `
            <div class="graph-question-meta">
              ${(concept.top_countries || []).slice(0, 3).map((value) => `<span>${escapeHtml(value)}</span>`).join("")}
              ${(concept.top_units || []).slice(0, 3).map((value) => `<span>${escapeHtml(value)}</span>`).join("")}
            </div>
          ` : ""}
        </details>
      </section>
    `;
  };

  const renderPaths = () => {
    if (!(selectedQuestion instanceof HTMLElement) || !(selectedOpportunities instanceof HTMLElement)) return;
    const selectedEdge = currentVisibleEdge();
    if (selectedEdge) {
      const summary = edgePairSummary(selectedEdge);
      const exampleTexts = [
        ...((summary?.x_to_y?.examples || []).map((item) => item.claim_text || item.evidence_text || item.title)),
        ...((summary?.y_to_x?.examples || []).map((item) => item.claim_text || item.evidence_text || item.title)),
        ...((summary?.undirected?.examples || []).map((item) => item.claim_text || item.evidence_text || item.title)),
        ...((selectedEdge.examples || []).map((item) => item.claim_text || item.evidence_text || item.title)),
      ].filter(Boolean).slice(0, 6);
      selectedQuestion.innerHTML = `
        <article class="graph-question-focus-card literature-path-focus-card literature-compact-panel">
          <h3>Evidence preview</h3>
          <div class="graph-question-meta">
            <span>${formatNumber(safeNumber(selectedEdge.support_count))} supporting records</span>
            <span>${escapeHtml(edgeDirectionBadge(selectedEdge))}</span>
          </div>
        </article>
      `;
      selectedOpportunities.innerHTML = exampleTexts.length
        ? `
          <div class="literature-panel-stack">
            ${exampleTexts.slice(0, PANEL_PREVIEW_LIMIT).map((text) => `<article class="literature-paper-card"><p class="mini-copy">${escapeHtml(text)}</p></article>`).join("")}
            ${exampleTexts.length > PANEL_PREVIEW_LIMIT ? `<button class="button-tertiary literature-sheet-button" type="button" data-open-sheet="paths">Open full evidence</button>` : ""}
          </div>
        `
        : `<p class="card-copy">No example claims were exported for this edge.</p>`;
      for (const button of selectedOpportunities.querySelectorAll("[data-open-sheet]")) {
        button.addEventListener("click", () => openDetailSheet(button.dataset.openSheet));
      }
      return;
    }
    const concept = selectedId ? conceptMap.get(selectedId) : null;
    if (!concept) {
      selectedQuestion.innerHTML = `<p class="card-copy">Choose a topic to see the strongest nearby paths.</p>`;
      selectedOpportunities.innerHTML = "";
      return;
    }

    if (!currentOpportunities.length) {
      selectedQuestion.innerHTML = `<p class="card-copy">No nearby path candidates are available for this topic.</p>`;
      selectedOpportunities.innerHTML = "";
      return;
    }

    const activeQuestion = currentQuestion() || currentOpportunities[0];
    activeQuestionPairKey = activeQuestion?.pair_key || null;
    const mediatorLabels = Array.isArray(activeQuestion.top_mediator_display_labels) && activeQuestion.top_mediator_display_labels.length
      ? activeQuestion.top_mediator_display_labels.filter(Boolean).slice(0, 3)
      : Array.isArray(activeQuestion.top_mediator_labels)
        ? activeQuestion.top_mediator_labels.filter(Boolean).slice(0, 3)
        : [];

    selectedQuestion.innerHTML = `
      <article class="graph-question-focus-card literature-path-focus-card literature-compact-panel">
        <h3>${escapeHtml(questionTitle(activeQuestion))}</h3>
        <div class="graph-question-meta">
          <span>${formatNumber(safeNumber(activeQuestion.supporting_path_count))} paths</span>
          <span>${formatNumber(safeNumber(activeQuestion.mediator_count))} mediators</span>
          <span>${escapeHtml(questionProjectShapeLabel(activeQuestion))}</span>
        </div>
        <details class="literature-collapsible">
          <summary>Why this surfaced</summary>
          <p class="mini-copy">${escapeHtml(conciseQuestionReason(activeQuestion))}</p>
        </details>
        ${
          mediatorLabels.length
            ? `
              <details class="literature-collapsible">
                <summary>Show bridge topics</summary>
                <div class="graph-topic-chip-list">
                  ${mediatorLabels
                    .map((label) => {
                      const mediatorId = resolveMediatorConceptId(label);
                      return mediatorId
                        ? `
                          <button class="topic-chip-button" type="button" data-mediator-id="${escapeAttr(mediatorId)}">
                            <span>${escapeHtml(label)}</span>
                            <small>Open topic</small>
                          </button>
                        `
                        : `
                          <span class="graph-topic-stat">${escapeHtml(label)}</span>
                        `;
                    })
                    .join("")}
                </div>
              </details>
            `
            : ""
        }
        <div class="graph-question-actions">
          <a class="button-secondary" href="${escapeAttr(activeQuestion.app_link)}" target="_blank" rel="noopener noreferrer">Open Explorer</a>
        </div>
      </article>
    `;

    for (const button of selectedQuestion.querySelectorAll("[data-mediator-id]")) {
      button.addEventListener("click", () => selectConcept(button.dataset.mediatorId, { rebuildMap: false, switchToOverview: false }));
    }

    selectedOpportunities.innerHTML = `
      <div class="literature-panel-stack">
        <div class="inspector-head literature-compact-head">
          <h3>Candidate paths around this topic</h3>
        </div>
        ${currentOpportunities
          .slice(0, PANEL_PREVIEW_LIMIT)
          .map((item) => {
            const counterpartId =
              item.source_id === selectedId ? item.target_id : item.target_id === selectedId ? item.source_id : null;
            return `
              <button class="graph-question-row${item.pair_key === activeQuestionPairKey ? " is-active" : ""}" type="button" data-select-pair="${escapeAttr(item.pair_key)}">
                <span class="tiny-label">${escapeHtml(item.slice_label || "Path candidate")}</span>
                <strong>${escapeHtml(questionTitle(item))}</strong>
                <div class="graph-question-meta graph-question-meta-tight">
                  <span>Other side: ${escapeHtml(conceptLabel(counterpartId, "Other topic"))}</span>
                  <span>${formatNumber(safeNumber(item.supporting_path_count))} paths</span>
                  <span>${escapeHtml(questionProjectShapeLabel(item))}</span>
                </div>
              </button>
            `;
          })
          .join("")}
        ${currentOpportunities.length > PANEL_PREVIEW_LIMIT ? `<button class="button-tertiary literature-sheet-button" type="button" data-open-sheet="paths">Open full paths</button>` : ""}
      </div>
    `;

    for (const button of selectedOpportunities.querySelectorAll("[data-select-pair]")) {
      button.addEventListener("click", () => {
        selectedEdgeId = null;
        activeQuestionPairKey = button.dataset.selectPair;
        setPanelTab("paths");
        renderPaths();
        renderPapers();
        renderGraph();
        restoreStatus();
      });
    }
    for (const button of selectedOpportunities.querySelectorAll("[data-open-sheet]")) {
      button.addEventListener("click", () => openDetailSheet(button.dataset.openSheet));
    }
  };

  const renderPapers = () => {
    if (!(selectedPapers instanceof HTMLElement)) return;
    const selectedEdge = currentVisibleEdge();
    const papers = paperPreviewItems();
    if (selectedEdge) {
    selectedPapers.innerHTML = papers.length
      ? `
        <div class="literature-panel-stack">
          <div class="inspector-head literature-compact-head">
            <h3>Anchor papers</h3>
          </div>
          <div class="literature-paper-stack">
            ${papers.slice(0, PANEL_PREVIEW_LIMIT).map((paper) => renderPaperRow(paper)).join("")}
          </div>
            ${papers.length > PANEL_PREVIEW_LIMIT ? `<button class="button-tertiary literature-sheet-button" type="button" data-open-sheet="papers">Open full papers</button>` : ""}
          </div>
        `
        : `<p class="card-copy">No paper previews were exported for this edge.</p>`;
      for (const button of selectedPapers.querySelectorAll("[data-open-sheet]")) {
        button.addEventListener("click", () => openDetailSheet(button.dataset.openSheet));
      }
      return;
    }
    const concept = selectedId ? conceptMap.get(selectedId) : null;
    if (!concept) {
      selectedPapers.innerHTML = `<p class="card-copy">Choose a topic to see the anchor papers around it.</p>`;
      return;
    }

    selectedPapers.innerHTML = papers.length
      ? `
        <div class="literature-panel-stack">
          <div class="inspector-head literature-compact-head">
            <h3>Anchor papers</h3>
          </div>
          <div class="literature-paper-stack">
            ${papers.slice(0, PANEL_PREVIEW_LIMIT).map((paper) => renderPaperRow(paper)).join("")}
          </div>
          ${papers.length > PANEL_PREVIEW_LIMIT ? `<button class="button-tertiary literature-sheet-button" type="button" data-open-sheet="papers">Open full papers</button>` : ""}
        </div>
      `
      : `<p class="card-copy">No paper previews were exported for this topic.</p>`;
    for (const button of selectedPapers.querySelectorAll("[data-open-sheet]")) {
      button.addEventListener("click", () => openDetailSheet(button.dataset.openSheet));
    }
  };

  const lerp = (start, end, progress) => start + (end - start) * progress;
  const easeInOutCubic = (progress) =>
    progress < 0.5 ? 4 * progress * progress * progress : 1 - Math.pow(-2 * progress + 2, 3) / 2;

  const fitTransformForState = (visibleState, padding = 100, zoomOutFactor = 0.98) => {
    if (!graph || !visibleState?.nodes?.length) return null;
    const xs = visibleState.nodes.map((node) => nodeRenderState(node, visibleState.renderPositionMap).x);
    const ys = visibleState.nodes.map((node) => nodeRenderState(node, visibleState.renderPositionMap).y);
    const minX = Math.min(...xs);
    const maxX = Math.max(...xs);
    const minY = Math.min(...ys);
    const maxY = Math.max(...ys);
    const spanX = Math.max(maxX - minX, 150);
    const spanY = Math.max(maxY - minY, 150);
    const scale = clamp(
      Math.min((GRAPH_WIDTH - padding * 2) / spanX, (GRAPH_HEIGHT - padding * 2) / spanY) * zoomOutFactor,
      MIN_SCALE,
      MAX_SCALE,
    );
    const centerX = (minX + maxX) / 2;
    const centerY = (minY + maxY) / 2;
    return {
      scale,
      translateX: GRAPH_WIDTH / 2 - centerX * scale,
      translateY: GRAPH_HEIGHT / 2 - centerY * scale,
    };
  };

  const clearPendingNodeClick = () => {
    if (!pendingNodeClick) return;
    clearTimeout(pendingNodeClick.timerId);
    pendingNodeClick = null;
  };

  const beginPivotToConcept = (conceptId) => {
    if (!conceptId || conceptId === rootConceptId || pivotState?.locked) return;
    const fromState = getVisibleGraphState();
    const toState = computeVisibleGraphState({
      rootId: conceptId,
      selectedConceptId: conceptId,
      mode: "local",
      depth: hopDepth,
      layers: { ...layerState, fringeTopics: hopDepth > 1 ? layerState.fringeTopics : false },
      includeQuestionState: false,
    });
    const fromNodeMap = new Map(fromState.nodes.map((node) => [node.id, node]));
    const toNodeMap = new Map(toState.nodes.map((node) => [node.id, node]));
    const fromPositions = new Map(fromState.nodes.map((node) => [node.id, nodeRenderState(node, fromState.renderPositionMap)]));
    const toPositions = new Map(toState.nodes.map((node) => [node.id, nodeRenderState(node, toState.renderPositionMap)]));
    const sharedNodeIds = Array.from(toNodeMap.keys()).filter((nodeId) => fromNodeMap.has(nodeId));
    const enteringNodeIds = Array.from(toNodeMap.keys()).filter((nodeId) => !fromNodeMap.has(nodeId));
    const exitingNodeIds = Array.from(fromNodeMap.keys()).filter((nodeId) => !toNodeMap.has(nodeId));
    const originPosition = fromPositions.get(conceptId) || fromPositions.get(selectedId) || {
      x: GRAPH_WIDTH * 0.5,
      y: GRAPH_HEIGHT * 0.5,
      angle: -Math.PI / 2,
    };
    const targetView = fitTransformForState(toState, 100, 0.98) || { ...viewState };
    const startingView = { ...viewState };
    const frameState = {
      fromRootId: rootConceptId,
      toRootId: conceptId,
      startTime: 0,
      durationMs: PIVOT_DURATION_MS,
      sharedNodeIds,
      enteringNodeIds,
      exitingNodeIds,
      fromState,
      toState,
      fromNodeMap,
      toNodeMap,
      fromPositions,
      toPositions,
      originPosition,
      startingView,
      targetView,
      locked: true,
      progress: 0,
      frameId: 0,
    };
    pivotState = frameState;
    hideTooltip();
    restoreStatus();

    const step = (timestamp) => {
      if (!pivotState || pivotState !== frameState) return;
      if (!frameState.startTime) frameState.startTime = timestamp;
      const rawProgress = clamp((timestamp - frameState.startTime) / frameState.durationMs, 0, 1);
      frameState.progress = easeInOutCubic(rawProgress);
      const viewProgress = rawProgress < 0.35 ? 0 : easeInOutCubic((rawProgress - 0.35) / 0.65);
      viewState = {
        scale: lerp(frameState.startingView.scale, frameState.targetView.scale, viewProgress),
        translateX: lerp(frameState.startingView.translateX, frameState.targetView.translateX, viewProgress),
        translateY: lerp(frameState.startingView.translateY, frameState.targetView.translateY, viewProgress),
      };
      renderGraph();
      if (rawProgress < 1) {
        frameState.frameId = requestAnimationFrame(step);
        return;
      }
      viewState = { ...frameState.targetView };
      pivotState = null;
      selectConcept(conceptId, {
        rebuildMap: true,
        switchToOverview: true,
        preserveViewport: true,
        nextMapMode: "local",
        historyMode: "push",
      });
    };

    frameState.frameId = requestAnimationFrame(step);
  };

  const renderGraph = () => {
    if (!(canvas instanceof SVGSVGElement)) return;
    const nodeMarkup = [];
    const edgeMarkup = [];
    const liveVisibleState = getVisibleGraphState();
    let visibleState = liveVisibleState;
    let edgeOpacityMap = new Map();
    let enteringNodeIds = new Set();
    let exitingNodeIds = new Set();
    let renderRootId = rootConceptId;
    let renderSelectedId = selectedId;
    const renderMode = pivotState ? "local" : mapMode;

    if (pivotState) {
      const unionNodeMap = new Map([
        ...pivotState.fromState.nodes.map((node) => [node.id, node]),
        ...pivotState.toState.nodes.map((node) => [node.id, node]),
      ]);
      const unionEdgeMap = new Map([
        ...pivotState.fromState.edges.map((edge) => [edge.id, edge]),
        ...pivotState.toState.edges.map((edge) => [edge.id, edge]),
      ]);
      const progress = pivotState.progress || 0;
      const renderPositionMap = new Map();
      enteringNodeIds = new Set(pivotState.enteringNodeIds);
      exitingNodeIds = new Set(pivotState.exitingNodeIds);
      renderRootId = pivotState.toRootId;
      renderSelectedId = pivotState.toRootId;

      for (const nodeId of unionNodeMap.keys()) {
        const fromPosition = pivotState.fromPositions.get(nodeId) || pivotState.originPosition;
        const toPosition = pivotState.toPositions.get(nodeId) || fromPosition;
        const isEntering = enteringNodeIds.has(nodeId);
        const isExiting = exitingNodeIds.has(nodeId);
        const startPosition = isEntering ? pivotState.originPosition : fromPosition;
        const endPosition = isExiting ? fromPosition : toPosition;
        renderPositionMap.set(nodeId, {
          x: lerp(startPosition.x, endPosition.x, progress),
          y: lerp(startPosition.y, endPosition.y, progress),
          angle: lerp(startPosition.angle || -Math.PI / 2, endPosition.angle || -Math.PI / 2, progress),
          opacity: isEntering ? progress : isExiting ? 1 - progress : 1,
          scaleMultiplier: isEntering ? 0.62 + progress * 0.38 : isExiting ? 1 - progress * 0.26 : 1,
        });
      }

      const fromEdgeIds = new Set(pivotState.fromState.edges.map((edge) => edge.id));
      const toEdgeIds = new Set(pivotState.toState.edges.map((edge) => edge.id));
      edgeOpacityMap = new Map(
        Array.from(unionEdgeMap.keys()).map((edgeId) => [
          edgeId,
          fromEdgeIds.has(edgeId) && toEdgeIds.has(edgeId) ? 1 : toEdgeIds.has(edgeId) ? progress : 1 - progress,
        ]),
      );

      visibleState = {
        ...pivotState.toState,
        nodes: Array.from(unionNodeMap.values()),
        edges: Array.from(unionEdgeMap.values()),
        renderPositionMap,
      };
    }

    const selectedActive = Boolean(renderRootId);
    const {
      focusedActive,
      nodes: visibleNodes,
      edges: visibleEdges,
      firstRing,
      secondRing,
      thirdRing,
      counterpartId,
      mediatorIds,
      firstRingLabels,
      renderPositionMap,
    } = visibleState;
    const visibleNodeMap = new Map(visibleNodes.map((node) => [node.id, node]));
    const edgeLookup = new Map(visibleEdges.map((edge) => [edge.id, edge]));
    const maxVisibleSupport = Math.max(1, ...visibleEdges.map((edge) => safeNumber(edge.support_count)));
    const scopeFilteringActive = scopeState.some((item) => {
      const layerKey = scopeLayerKey(scopeTypeForEntity(item));
      return layerKey && layerState[layerKey];
    });

    for (const edge of visibleEdges) {
      const source = visibleNodeMap.get(edge.source) || graph.nodeMap.get(edge.source) || buildSyntheticNode(edge.source);
      const target = visibleNodeMap.get(edge.target) || graph.nodeMap.get(edge.target) || buildSyntheticNode(edge.target);
      if (!source || !target) continue;
      const sourceRender = nodeRenderState(source, renderPositionMap);
      const targetRender = nodeRenderState(target, renderPositionMap);
      const summary = edgePairSummary(edge);
      const dominantCountries = (summary?.dominant_countries || edge.dominant_countries || []).filter(Boolean);
      const dominantUnits = (summary?.dominant_units || edge.dominant_units || []).filter(Boolean);
      const dominantYears = (summary?.dominant_years || edge.dominant_years || []).filter(Boolean);
      const isSelectedEdge = !pivotState && selectedEdgeId === edge.id;
      const isRootEdge = selectedActive && (edge.source === renderRootId || edge.target === renderRootId);
      const isPathEdge =
        mediatorIds.has(edge.source) ||
        mediatorIds.has(edge.target) ||
        edge.source === counterpartId ||
        edge.target === counterpartId;
      const isQuestionRoute = Boolean(counterpartId) && (edge.source === counterpartId || edge.target === counterpartId);
      const scopeMatch = scopeFilteringActive ? edgeMatchesActiveScopeLayers(edge) : false;
      const isDimmed =
        (renderMode === "global" && selectedActive && !isRootEdge && !isPathEdge && !isSelectedEdge) ||
        (scopeFilteringActive && !scopeMatch && !isSelectedEdge && !isRootEdge);
      const shouldShowArrows = layerState.direction || isSelectedEdge || (layerState.paths && isPathEdge);
      const arrowMode = shouldShowArrows ? edgeArrowMode(edge) : "none";
      const hasContext = layerState.context && Boolean(dominantCountries.length || dominantUnits.length || dominantYears.length);
      const markerStart = arrowMode === "reverse" || arrowMode === "both" ? ` marker-start="url(#literature-arrow-start)"` : "";
      const markerEnd = arrowMode === "forward" || arrowMode === "both" ? ` marker-end="url(#literature-arrow-end)"` : "";
      const edgeSupport = scaleSupportCount(edge.support_count, maxVisibleSupport);
      const edgeStrength = clamp(Math.max(safeNumber(edge.strength) || 0, edgeSupport), 0.08, 1);
      edgeMarkup.push(
        `<line class="graph-edge${isRootEdge ? " is-selected" : ""}${isSelectedEdge ? " is-selected-edge" : ""}${isPathEdge ? " is-focused" : ""}${isQuestionRoute ? " is-question-route" : ""}${scopeMatch ? " is-scope-match" : ""}${hasContext ? " has-context" : ""}${layerState.direction && arrowMode !== "none" ? " is-directional" : ""}${isDimmed ? " is-dimmed" : ""}" style="--edge-strength:${edgeStrength}; --edge-support:${edgeSupport}; opacity:${edgeOpacityMap.get(edge.id) ?? 1};" data-edge-id="${escapeHtml(edge.id)}" x1="${sourceRender.x}" y1="${sourceRender.y}" x2="${targetRender.x}" y2="${targetRender.y}"${markerStart}${markerEnd}></line>`,
      );
    }

    for (const node of visibleNodes) {
      const isRoot = node.id === renderRootId;
      const isSelected = node.id === renderSelectedId && node.id !== renderRootId;
      const isQuestionTarget = Boolean(counterpartId) && node.id === counterpartId;
      const isMediator = mediatorIds.has(node.id);
      const isFirstRing = firstRing.has(node.id);
      const isSecondRing = secondRing.has(node.id);
      const isThirdRing = thirdRing.has(node.id);
      const isScopeMatch = scopeFilteringActive ? nodeMatchesActiveScopeLayers(node) : false;
      const context = nodeContext(node.id);
      const hasContext = layerState.context && Boolean(context.topCountries.length || context.topUnits.length);
      const isDimmed =
        (renderMode === "global" && selectedActive && !isRoot && !isSelected && !isQuestionTarget && !isMediator) ||
        (scopeFilteringActive && !isScopeMatch && !isRoot && !isSelected && !isQuestionTarget && !isMediator);
      const renderState = nodeRenderState(node, renderPositionMap);
      const baseRadius = focusedActive
        ? isRoot
          ? 26
          : isSelected
            ? 20
          : isQuestionTarget
            ? 21
            : isMediator
              ? 17
              : isFirstRing
                ? Math.max(13, Math.min(19, 11.5 + Math.log10(safeNumber(node.weighted_degree) + 1) * 2.2))
                : isSecondRing
                  ? Math.max(10, Math.min(14.5, 9.4 + Math.log10(safeNumber(node.weighted_degree) + 1) * 1.4))
                  : isThirdRing
                    ? 5.7
                    : Math.max(8.5, Math.min(12.5, 8.6 + Math.log10(safeNumber(node.weighted_degree) + 1) * 1.1))
        : Math.max(2.8, Math.min(24, 2.8 + Math.log10(safeNumber(node.weighted_degree) + 1) * 4.4));
      const radius = baseRadius * (renderState.scaleMultiplier || 1);
      const showLabel = focusedActive
        ? isRoot || isSelected || isQuestionTarget || isMediator || isScopeMatch || firstRingLabels.has(node.id)
        : node.show_label || isRoot || isSelected || isQuestionTarget;
      const label = node.plain_label || node.label;
      const labelWidth = estimateChipWidth(label);
      const labelAbove = focusedActive ? Math.sin(renderState.angle) <= 0 : true;
      const labelY = focusedActive
        ? renderState.y + (labelAbove ? -(radius + 18) : radius + 28)
        : renderState.y - (radius + (isRoot || isSelected ? 16 : 8));
      const chipY = labelAbove ? labelY - 20 : labelY - 18;
      nodeMarkup.push(
        `<g class="graph-node-group${isRoot ? " is-root" : ""}${isSelected ? " is-selected-node" : ""}${isQuestionTarget ? " is-question-target" : ""}${isMediator ? " is-mediator" : ""}${isFirstRing ? " is-neighbor" : ""}${isSecondRing ? " is-second-ring" : ""}${isThirdRing ? " is-third-ring" : ""}${isScopeMatch ? " is-scope-match" : ""}${hasContext ? " has-context" : ""}${enteringNodeIds.has(node.id) ? " is-entering" : ""}${exitingNodeIds.has(node.id) ? " is-exiting" : ""}${isDimmed ? " is-dimmed" : ""}" data-node-id="${escapeAttr(node.id)}" style="opacity:${renderState.opacity ?? 1};">
          ${focusedActive ? `<circle class="graph-node-halo${isRoot ? " is-root" : ""}${isSelected ? " is-selected-node" : ""}${isQuestionTarget ? " is-question-target" : ""}${isMediator ? " is-mediator" : ""}${isFirstRing ? " is-neighbor" : ""}${isSecondRing ? " is-second-ring" : ""}${isThirdRing ? " is-third-ring" : ""}${isScopeMatch ? " is-scope-match" : ""}${hasContext ? " has-context" : ""}" cx="${renderState.x}" cy="${renderState.y}" r="${radius + (isRoot ? 10 : isSelected ? 8 : isQuestionTarget ? 8 : isMediator ? 7 : isThirdRing ? 4 : 6)}"></circle>` : ""}
          <circle class="graph-node" cx="${renderState.x}" cy="${renderState.y}" r="${radius}"></circle>
          ${
            showLabel
              ? focusedActive
                ? `<g class="graph-label-chip${isRoot ? " is-root" : ""}${isSelected ? " is-selected-node" : ""}${isQuestionTarget ? " is-question-target" : ""}${isMediator ? " is-mediator" : ""}${isFirstRing ? " is-neighbor" : ""}${isSecondRing ? " is-second-ring" : ""}${isThirdRing ? " is-third-ring" : ""}${isScopeMatch ? " is-scope-match" : ""}${hasContext ? " has-context" : ""}">
                    <rect x="${renderState.x - labelWidth / 2}" y="${chipY}" width="${labelWidth}" height="28" rx="14" ry="14"></rect>
                    <text class="graph-label graph-label-chip-text${isRoot ? " is-root" : ""}${isSelected ? " is-selected-node" : ""}${isQuestionTarget ? " is-question-target" : ""}${isMediator ? " is-mediator" : ""}${isFirstRing ? " is-neighbor" : ""}${isSecondRing ? " is-second-ring" : ""}${isThirdRing ? " is-third-ring" : ""}${isScopeMatch ? " is-scope-match" : ""}${hasContext ? " has-context" : ""}" x="${renderState.x}" y="${labelY}">${escapeHtml(label)}</text>
                  </g>`
                : `<text class="graph-label${isRoot ? " is-root" : ""}${isSelected ? " is-selected-node" : ""}${isQuestionTarget ? " is-question-target" : ""}" x="${renderState.x}" y="${labelY}">${escapeHtml(label)}</text>`
              : ""
          }
        </g>`,
      );
    }

    canvas.innerHTML = `
      <defs>
        <marker id="literature-arrow-end" viewBox="0 0 12 12" refX="10" refY="6" markerWidth="8" markerHeight="8" orient="auto">
          <path d="M1 1 L11 6 L1 11 z" fill="rgba(31, 50, 72, 0.68)"></path>
        </marker>
        <marker id="literature-arrow-start" viewBox="0 0 12 12" refX="2" refY="6" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
          <path d="M1 1 L11 6 L1 11 z" fill="rgba(31, 50, 72, 0.68)"></path>
        </marker>
      </defs>
      <g data-role="graph-viewport">
        <rect class="graph-pan-target" x="-900" y="-900" width="3200" height="2800"></rect>
        <g class="graph-edge-layer">${edgeMarkup.join("")}</g>
        <g class="graph-node-layer">${nodeMarkup.join("")}</g>
      </g>
    `;

    for (const nodeElement of canvas.querySelectorAll("[data-node-id]")) {
      const dragHandle = nodeElement.querySelector("circle");
      nodeElement.addEventListener("mouseenter", (event) => {
        const node = visibleNodeMap.get(nodeElement.dataset.nodeId) || graph.nodeMap.get(nodeElement.dataset.nodeId) || buildSyntheticNode(nodeElement.dataset.nodeId);
        if (!node) return;
        const context = nodeContext(node.id);
        const backboneDetail = isInBackbone(node.id)
          ? `${formatNumber(context.weightedDegree)} weighted links in the backbone.`
          : "Searchable topic outside the released backbone.";
        const entityTags = [];
        if (context.entity?.badge) entityTags.push(context.entity.badge);
        if (context.entity?.entity_type && context.entity.entity_type !== "concept") {
          entityTags.push(humanizeScopeType(context.entity.entity_type));
        }
        showTooltip(event, `
          <strong>${escapeHtml(node.plain_label || node.label)}</strong><br />
          ${node.subtitle ? `${escapeHtml(node.subtitle)}<br />` : ""}
          <span>${formatNumber(context.paperSupport)} papers in this map.</span><br />
          <span>${formatNumber(context.neighborCount)} nearby links in this released view.</span><br />
          <span>${escapeHtml(backboneDetail)}</span><br />
          ${entityTags.length ? `<span>${escapeHtml(entityTags.join(" · "))}</span><br />` : ""}
          ${thirdRing.has(node.id) ? `<span>Outer-ring discovery topic.</span><br />` : ""}
          ${layerState.context && context.topCountries.length ? `<span>Countries: ${escapeHtml(context.topCountries.slice(0, 3).join(", "))}</span><br />` : ""}
          ${layerState.context && context.topUnits.length ? `<span>Units: ${escapeHtml(context.topUnits.slice(0, 3).join(", "))}</span><br />` : ""}
          <span class="tooltip-action">Click to inspect. Double-click to rebuild the map here.</span>
        `);
      });
      nodeElement.addEventListener("mousemove", moveTooltip);
      nodeElement.addEventListener("mouseleave", hideTooltip);
      dragHandle?.addEventListener("pointerdown", (event) => {
        event.preventDefault();
        event.stopPropagation();
      });
      nodeElement.addEventListener("click", (event) => {
        event.stopPropagation();
        if (pivotState?.locked) return;
        const nodeId = nodeElement.dataset.nodeId;
        if (!nodeId) return;
        const now = performance.now();
        if (pendingNodeClick && pendingNodeClick.nodeId === nodeId && now - pendingNodeClick.startedAt <= NODE_DOUBLE_CLICK_WINDOW_MS) {
          clearPendingNodeClick();
          beginPivotToConcept(nodeId);
          return;
        }
        clearPendingNodeClick();
        pendingNodeClick = {
          nodeId,
          startedAt: now,
          timerId: window.setTimeout(() => {
            pendingNodeClick = null;
            selectConcept(nodeId, { rebuildMap: false, switchToOverview: false });
          }, Math.max(NODE_SINGLE_CLICK_DELAY_MS, NODE_DOUBLE_CLICK_WINDOW_MS)),
        };
      });
    }

    for (const edgeElement of canvas.querySelectorAll("[data-edge-id]")) {
      edgeElement.addEventListener("pointerdown", (event) => {
        event.preventDefault();
        event.stopPropagation();
      });
      edgeElement.addEventListener("mousedown", (event) => {
        event.preventDefault();
        event.stopPropagation();
      });
      edgeElement.addEventListener("mouseenter", (event) => {
        const edge = edgeLookup.get(edgeElement.dataset.edgeId);
        if (!edge) return;
        const sourceNode = visibleNodeMap.get(edge.source) || graph.nodeMap.get(edge.source) || buildSyntheticNode(edge.source);
        const targetNode = visibleNodeMap.get(edge.target) || graph.nodeMap.get(edge.target) || buildSyntheticNode(edge.target);
        const summary = edgePairSummary(edge);
        const dominantCountries = (summary?.dominant_countries || []).slice(0, 2).map((item) => item.value || item).filter(Boolean);
        const dominantUnits = (summary?.dominant_units || []).slice(0, 2).map((item) => item.value || item).filter(Boolean);
        const dominantYears = (summary?.dominant_years || []).slice(0, 2).map((item) => item.value || item).filter(Boolean);
        showTooltip(event, `
          <strong>${escapeHtml(conceptLabel(edge.source, sourceNode?.label || ""))} ↔ ${escapeHtml(conceptLabel(edge.target, targetNode?.label || ""))}</strong><br />
          <span>${formatNumber(safeNumber(edge.support_count))} papers mention this nearby directed relation.</span><br />
          <span>${escapeHtml(edgeDirectionSummary(edge))}</span><br />
          ${edgeSignBadge(edge) ? `<span>${escapeHtml(edgeSignBadge(edge))}</span><br />` : ""}
          ${layerState.context && dominantCountries.length ? `<span>Countries: ${escapeHtml(dominantCountries.join(", "))}</span><br />` : ""}
          ${layerState.context && dominantUnits.length ? `<span>Units: ${escapeHtml(dominantUnits.join(", "))}</span><br />` : ""}
          ${layerState.context && dominantYears.length ? `<span>Years: ${escapeHtml(dominantYears.join(", "))}</span><br />` : ""}
          <span>${edge.synthetic ? "This is a proxy link from the searched topic into the released backbone." : `Local edge strength: ${safeNumber(edge.strength).toFixed(2)} on the current map.`}</span>
        `);
      });
      edgeElement.addEventListener("mousemove", moveTooltip);
      edgeElement.addEventListener("mouseleave", hideTooltip);
      edgeElement.addEventListener("click", (event) => {
        event.stopPropagation();
        if (pivotState?.locked) return;
        clearPendingNodeClick();
        const edge = edgeLookup.get(edgeElement.dataset.edgeId);
        if (edge?.synthetic) return;
        selectedEdgeId = edgeElement.dataset.edgeId || null;
        if (!selectedId) selectedId = renderRootId;
        renderAllPanels();
        renderGraph();
        restoreStatus();
      });
    }

    setViewportTransform();
  };

  const renderAllPanels = () => {
    const concept = selectedId ? conceptMap.get(selectedId) : null;
    if (!concept) return;
    updatePanelTabLabels();
    renderCentralList();
    renderSelectedConcept(concept);
    renderOverview();
    renderPaths();
    renderPapers();
    if (detailSheetState.open) renderDetailSheet();
  };

  const renderNeighborhood = async (conceptId) => {
    currentNeighborhood = null;
    const shardPath = neighborhoodIndex[conceptId];
    if (!shardPath) {
      if (conceptId === rootConceptId) rootNeighborhood = null;
      renderAllPanels();
      return;
    }
    const shard = await fetchJson(shardPath);
    currentNeighborhood = shard[conceptId] || null;
    if (conceptId === rootConceptId) rootNeighborhood = currentNeighborhood;
    renderAllPanels();
  };

  const renderOpportunities = async (conceptId) => {
    currentOpportunities = [];
    const shardPath = opportunitiesIndex[conceptId];
    if (!shardPath) {
      renderAllPanels();
      return;
    }
    const shard = await fetchJson(shardPath);
    const opportunities = (shard[conceptId] || []).slice().sort((left, right) => {
      const delta = questionPriorityScore(right, conceptId) - questionPriorityScore(left, conceptId);
      if (Math.abs(delta) > 1e-9) return delta;
      return safeNumber(right.score) - safeNumber(left.score);
    });
    currentOpportunities = opportunities;
    activeQuestionPairKey = opportunities[0]?.pair_key || null;
    renderAllPanels();
  };

  const selectConcept = async (
    conceptId,
    {
      rebuildMap = true,
      switchToOverview = rebuildMap,
      entity = null,
      anchorId = "",
      preserveViewport = false,
      historyMode = rebuildMap ? "push" : "none",
      nextMapMode = "",
      inspectedConceptId = "",
    } = {},
  ) => {
    if (!conceptId) return;
    const concept = conceptMap.get(conceptId);
    if (!concept) return;
    clearPendingNodeClick();
    closeDetailSheet();
    if (entity) {
      queryState = cloneEntityState(entity, conceptId);
    } else if (rebuildMap || !queryState?.label) {
      queryState = pseudoEntityForConcept(conceptId) || queryState;
    }
    if (rebuildMap || !rootConceptId) {
      rootConceptId = conceptId;
      anchorConceptId = anchorId || (isInBackbone(conceptId) ? conceptId : entityPrimaryConceptId(entity) || "");
      rootNeighborhood = null;
      if (nextMapMode) mapMode = nextMapMode;
      else if (!isInBackbone(conceptId)) mapMode = "local";
    }
    selectedId = inspectedConceptId || conceptId;
    selectedEdgeId = null;
    currentNeighborhood = null;
    currentOpportunities = [];
    activeQuestionPairKey = null;
    if (switchToOverview) {
      setPanelTab("overview");
    }
    if (selectedConcept instanceof HTMLElement) {
      selectedConcept.innerHTML = `<p class="card-copy">Loading topic context...</p>`;
    }
    if (selectedNeighborhood instanceof HTMLElement) {
      selectedNeighborhood.innerHTML = `<p class="card-copy">Loading nearby topics...</p>`;
    }
    if (selectedQuestion instanceof HTMLElement) {
      selectedQuestion.innerHTML = `<p class="card-copy">Loading nearby paths...</p>`;
    }
    if (selectedOpportunities instanceof HTMLElement) {
      selectedOpportunities.innerHTML = `<p class="card-copy">Loading path candidates...</p>`;
    }
    if (selectedPapers instanceof HTMLElement) {
      selectedPapers.innerHTML = `<p class="card-copy">Loading anchor papers...</p>`;
    }
    renderStateChips();
    renderLayersMenu();
    updateMapModeButton();
    renderGraph();
    restoreStatus();

    await Promise.all([renderNeighborhood(conceptId), renderOpportunities(conceptId)]);
    updateMapModeButton();
    renderStateChips();
    renderLayersMenu();
    renderGraph();
    if (rebuildMap && !preserveViewport) {
      setDefaultViewport();
    }
    restoreStatus();
    if (historyMode !== "none") commitNavigationState(historyMode);
    hideTooltip();
  };

  const selectEntity = async (entity, { switchToOverview = true, historyMode = "push" } = {}) => {
    if (!entity) return;
    const entityState = cloneEntityState(entity, entityPrimaryConceptId(entity));
    const scopeType = scopeTypeForEntity(entityState);
    if (scopeType && scopeType !== "concept") {
      addScopeChip(entityState);
      const conceptId = entityPrimaryConceptId(entityState);
      if (conceptId && conceptMap.has(conceptId)) {
        const stableAnchor = entityAnchorCandidates(entityState)
          .map((candidate) => candidate?.concept_id)
          .find((candidateId) => candidateId && isInBackbone(candidateId));
        await selectConcept(conceptId, {
          rebuildMap: true,
          switchToOverview,
          entity: entityState,
          anchorId: stableAnchor || (isInBackbone(conceptId) ? conceptId : ""),
          historyMode,
        });
      } else {
        renderLayersMenu();
        renderStateChips();
        renderGraph();
        renderAllPanels();
        restoreStatus();
        commitNavigationState("push");
        if (!rootConceptId) {
          const anchorId = entityPrimaryConceptId(entityState);
          if (anchorId) {
            await selectConcept(anchorId, { rebuildMap: true, switchToOverview, entity: pseudoEntityForConcept(anchorId), anchorId, historyMode });
          }
        }
      }
      hideTooltip();
      return;
    }
    const conceptId = entityState.concept_id || entityPrimaryConceptId(entityState);
    if (!conceptId) return;
    const stableAnchor = entityAnchorCandidates(entityState)
      .map((candidate) => candidate?.concept_id)
      .find((candidateId) => candidateId && isInBackbone(candidateId));
    await selectConcept(conceptId, {
      rebuildMap: true,
      switchToOverview,
      entity: entityState,
      anchorId: stableAnchor || (isInBackbone(conceptId) ? conceptId : ""),
      historyMode,
    });
  };

  const runSearch = (query) => {
    if (!(searchResults instanceof HTMLElement)) return [];
    const trimmed = query.trim();
    if (!trimmed) {
      searchResults.innerHTML = "";
      return [];
    }
    const matches = searchConcepts(trimmed);
    renderSearchResults(matches);
    for (const button of searchResults.querySelectorAll("[data-entity-id]")) {
      button.addEventListener("click", () => {
        const entity = matches.find((item) => String(item.id || entityPrimaryConceptId(item)) === button.dataset.entityId);
        clearSearchUi();
        if (entity) {
          selectEntity(entity, { switchToOverview: true });
        }
      });
    }
    return matches;
  };

  const startPan = (eventTarget, clientX, clientY) => {
    if (eventTarget instanceof Element && eventTarget.closest("[data-node-id]")) return;
    hideTooltip();
    interaction = {
      type: "pan",
      startX: clientX,
      startY: clientY,
      translateX: viewState.translateX,
      translateY: viewState.translateY,
    };
  };

  const moveInteraction = (clientX, clientY) => {
    if (!interaction) return;
    if (interaction.type === "pan") {
      viewState = {
        ...viewState,
        translateX: interaction.translateX + (clientX - interaction.startX),
        translateY: interaction.translateY + (clientY - interaction.startY),
      };
      setViewportTransform();
    }
  };

  const bootstrap = async () => {
    const [graphPayload, conceptPayload, literatureSearchPayload, neighborhoodsPayload, opportunitiesPayload, centralPayload] = await Promise.all([
      fetchJson(graphPath),
      fetchJson(conceptIndexPath),
      fetchJson(literatureSearchIndexPath),
      fetchJson(neighborhoodsIndexPath),
      fetchJson(opportunitiesIndexPath),
      fetchJson(centralConceptsPath),
    ]);
    graph = {
      nodes: graphPayload.nodes.map((node) => ({ ...node })),
      edges: graphPayload.edges,
      nodeMap: new Map(graphPayload.nodes.map((node) => [node.id, { ...node }])),
      edgeMap: new Map(graphPayload.edges.map((edge) => [edge.id, edge])),
    };
    graph.nodes = Array.from(graph.nodeMap.values());
    concepts = conceptPayload;
    literatureSearchIndex = Array.isArray(literatureSearchPayload) ? literatureSearchPayload : [];
    searchEntityByConceptId = new Map(
      literatureSearchIndex
        .filter((entity) => entity?.concept_id)
        .map((entity) => [entity.concept_id, entity]),
    );
    conceptMap = new Map(concepts.map((concept) => [concept.concept_id, concept]));
    neighborhoodIndex = neighborhoodsPayload;
    opportunitiesIndex = opportunitiesPayload;
    centralConcepts = centralPayload;
    buildAdjacency();
    renderCentralList();
    renderLayersMenu();
    renderStateChips();
    updateDepthButtons();
    updateMapModeButton();
    updateNavigationButtons();

    const params = new URLSearchParams(window.location.search);
    const query = params.get("q");
    const viewParam = params.get("view");
    const hopParam = safeNumber(params.get("hops"));
    mapMode = viewParam === "backbone" ? "global" : "local";
    hopDepth = hopParam === 1 ? 1 : DEFAULT_HOP_DEPTH;
    layerState = { ...layerState, fringeTopics: hopDepth > 1 };
    updateDepthButtons();
    renderLayersMenu();
    const selected = query ? searchConcepts(query)[0] : null;
    const defaultTopic =
      literatureSearchIndex.find((entity) => normalizeText(entityLabel(entity)) === normalizeText(DEFAULT_TOPIC_LABEL)) ||
      pseudoEntityForConcept(
        concepts.find((concept) => String(concept.plain_label || concept.label || "").trim().toLowerCase() === DEFAULT_TOPIC_LABEL)?.concept_id,
      ) ||
      pseudoEntityForConcept(centralConcepts[0]?.concept_id);
    const initialEntity = selected || defaultTopic || null;
    if (initialEntity) {
      await selectEntity(initialEntity, { switchToOverview: true, historyMode: "replace" });
    } else {
      restoreStatus();
    }
  };

  panelTabButtons.forEach((button) => {
    button.addEventListener("click", () => {
      closeDetailSheet();
      setPanelTab(button.dataset.tab || "overview");
    });
  });

  if (searchInput instanceof HTMLInputElement) {
    searchInput.addEventListener("input", (event) => runSearch(event.target.value));
    searchInput.addEventListener("keydown", (event) => {
      if (event.key !== "Enter") return;
      const matches = runSearch(searchInput.value);
      if (matches[0]) {
        clearSearchUi();
        selectEntity(matches[0], { switchToOverview: true });
      }
    });
  }

  if (depthOneButton instanceof HTMLButtonElement) {
    depthOneButton.addEventListener("click", () => {
      hopDepth = 1;
      layerState = { ...layerState, fringeTopics: false };
      closeDetailSheet();
      updateDepthButtons();
      renderLayersMenu();
      renderGraph();
      setDefaultViewport();
      renderAllPanels();
      restoreStatus();
      commitNavigationState("push");
    });
  }

  if (depthTwoButton instanceof HTMLButtonElement) {
    depthTwoButton.addEventListener("click", () => {
      hopDepth = 2;
      layerState = { ...layerState, fringeTopics: true };
      closeDetailSheet();
      updateDepthButtons();
      renderLayersMenu();
      renderGraph();
      setDefaultViewport();
      renderAllPanels();
      restoreStatus();
      commitNavigationState("push");
    });
  }

  if (navBackButton instanceof HTMLButtonElement) {
    navBackButton.addEventListener("click", () => {
      if (navHistoryIndex <= 0) return;
      window.history.back();
    });
  }

  if (navForwardButton instanceof HTMLButtonElement) {
    navForwardButton.addEventListener("click", () => {
      if (navHistoryIndex >= navHistory.length - 1) return;
      window.history.forward();
    });
  }

  if (toggleMapMode instanceof HTMLButtonElement) {
    toggleMapMode.addEventListener("click", () => {
      mapMode = mapMode === "local" ? "global" : "local";
      closeDetailSheet();
      updateMapModeButton();
      renderGraph();
      setDefaultViewport();
      restoreStatus();
      commitNavigationState("push");
    });
  }

  if (resetView instanceof HTMLButtonElement) {
    resetView.addEventListener("click", setDefaultViewport);
  }

  if (zoomOutButton instanceof HTMLButtonElement) {
    zoomOutButton.addEventListener("click", () => zoomAroundCanvasCenter(1 / 1.15));
  }

  if (zoomInButton instanceof HTMLButtonElement) {
    zoomInButton.addEventListener("click", () => zoomAroundCanvasCenter(1.15));
  }

  canvas.addEventListener("wheel", (event) => {
    event.preventDefault();
    const factor = event.deltaY > 0 ? 1 / 1.08 : 1.08;
    zoomAtPoint(factor, event.clientX, event.clientY);
  }, { passive: false });

  canvas.addEventListener("pointerdown", (event) => {
    startPan(event.target, event.clientX, event.clientY);
  });
  canvas.addEventListener("mousedown", (event) => {
    startPan(event.target, event.clientX, event.clientY);
  });
  canvas.addEventListener("click", (event) => {
    if (event.target instanceof Element && event.target.closest("[data-node-id], [data-edge-id]")) return;
    clearPendingNodeClick();
    if (selectedEdgeId) {
      selectedEdgeId = null;
      renderAllPanels();
      renderGraph();
      restoreStatus();
    }
  });

  window.addEventListener("pointermove", (event) => {
    moveInteraction(event.clientX, event.clientY);
  });
  window.addEventListener("mousemove", (event) => {
    moveInteraction(event.clientX, event.clientY);
  });

  window.addEventListener("pointerup", () => {
    interaction = null;
  });
  window.addEventListener("mouseup", () => {
    interaction = null;
  });

  window.addEventListener("resize", () => {
    if (pivotState?.locked) return;
    renderGraph();
    if (mapMode === "local" && rootConceptId) {
      setDefaultViewport();
    } else {
      setViewportTransform();
    }
  });

  window.addEventListener("popstate", (event) => {
    const state = event.state?.literatureNav;
    if (!state) return;
    if (Number.isFinite(event.state?.literatureNavIndex)) navHistoryIndex = event.state.literatureNavIndex;
    applyNavigationState(state).catch((error) => console.error(error));
  });

  detailSheetClose?.addEventListener("click", closeDetailSheet);
  detailSheet?.addEventListener("close", () => {
    detailSheetState = { open: false, kind: null };
  });
  detailSheet?.addEventListener("click", (event) => {
    if (event.target === detailSheet) closeDetailSheet();
  });

  bootstrap().catch((error) => {
    if (hoverCard instanceof HTMLElement) hoverCard.textContent = "Literature graph data failed to load.";
    console.error(error);
  });
</script>
