---
interface Props {
  graphPath: string;
  conceptIndexPath: string;
  literatureSearchIndexPath: string;
  neighborhoodsIndexPath: string;
  opportunitiesIndexPath: string;
  centralConceptsPath: string;
  contextLabel?: string;
}

const {
  graphPath,
  conceptIndexPath,
  literatureSearchIndexPath,
  neighborhoodsIndexPath,
  opportunitiesIndexPath,
  centralConceptsPath,
  contextLabel = "economics corpus",
} = Astro.props;

const rootId = `literature-graph-${Math.random().toString(36).slice(2, 10)}`;
---

<section
  id={rootId}
  class="literature-workbench"
  data-graph-path={graphPath}
  data-concept-index-path={conceptIndexPath}
  data-literature-search-index-path={literatureSearchIndexPath}
  data-neighborhoods-index-path={neighborhoodsIndexPath}
  data-opportunities-index-path={opportunitiesIndexPath}
  data-central-concepts-path={centralConceptsPath}
>
  <div class="literature-page-note">
    <span class="literature-construction-pill">Under Active Construction</span>
    <p class="mini-copy">
      This is the graph-first experimental surface. Click a topic to inspect it. Rebuild the map around that topic only when you choose to.
    </p>
  </div>

  <div class="literature-stage">
    <section class="graph-panel literature-map-card">
      <div class="sidebar-card inspector-card literature-search-panel">
        <label class="search-shell literature-search-shell">
          <span>Search topic</span>
          <input type="search" placeholder="Search topics or close variants" data-role="search-input" />
          <div class="search-results" data-role="search-results"></div>
        </label>

        <div class="literature-chip-stack">
          <div class="literature-chip-row" data-role="query-chip-row"></div>
          <div class="literature-chip-row" data-role="scope-chip-row"></div>
        </div>

        <details class="literature-suggested-shell" data-role="suggested-shell">
          <summary>Suggested Topics</summary>
          <div class="central-list central-list-inline" data-role="central-list"></div>
        </details>
      </div>

      <aside class="graph-panel literature-panel">
        <div class="literature-panel-header" data-role="selected-concept">
          <p class="card-copy">Choose a topic to inspect this map.</p>
        </div>

        <div class="literature-panel-tabs" role="tablist" aria-label="Literature graph panel">
          <button class="literature-tab-button is-active" type="button" data-role="panel-tab" data-tab="overview" aria-selected="true">Overview</button>
          <button class="literature-tab-button" type="button" data-role="panel-tab" data-tab="paths" aria-selected="false">Paths</button>
          <button class="literature-tab-button" type="button" data-role="panel-tab" data-tab="papers" aria-selected="false">Papers</button>
        </div>

        <section class="literature-panel-section" data-role="panel-section" data-panel="overview">
          <div data-role="selected-neighborhood">
            <p class="card-copy">Map context will appear here.</p>
          </div>
        </section>

        <section class="literature-panel-section" data-role="panel-section" data-panel="paths" hidden>
          <div data-role="selected-question">
            <p class="card-copy">Once you choose a topic, this panel will show the strongest nearby question-shaped paths and bridges.</p>
          </div>
          <div data-role="selected-opportunities">
            <p class="card-copy">Candidate paths will appear here.</p>
          </div>
        </section>

        <section class="literature-panel-section" data-role="panel-section" data-panel="papers" hidden>
          <div data-role="selected-papers">
            <p class="card-copy">Anchor papers will appear here once a topic is selected.</p>
          </div>
        </section>
      </aside>

      <dialog class="literature-detail-sheet" data-role="detail-sheet">
        <div class="literature-detail-sheet-shell">
          <div class="literature-detail-sheet-head">
            <div>
              <span class="tiny-label">Detail sheet</span>
              <h2 data-role="detail-sheet-title">Full list</h2>
            </div>
            <button class="feedback-close literature-detail-sheet-close" type="button" data-role="detail-sheet-close" aria-label="Close detail sheet">×</button>
          </div>
          <div class="literature-detail-sheet-body" data-role="detail-sheet-body">
            <p class="card-copy">More detail will appear here.</p>
          </div>
        </div>
      </dialog>

      <div class="literature-map-toolbar">
        <div class="literature-toggle-group" role="group" aria-label="Map depth">
          <button class="button-tertiary literature-toggle" type="button" data-role="nav-back">Back</button>
          <button class="button-tertiary literature-toggle" type="button" data-role="nav-forward">Forward</button>
          <button class="button-tertiary literature-toggle" type="button" data-role="depth-1">1 hop</button>
          <button class="button-secondary literature-toggle is-active" type="button" data-role="depth-2">2 hops</button>
          <button class="button-tertiary literature-toggle" type="button" data-role="toggle-map-mode">Show backbone</button>
          <details class="literature-layers-menu" data-role="layers-menu">
            <summary>Layers</summary>
            <div class="literature-layers-list" data-role="layers-list"></div>
          </details>
        </div>

        <div class="graph-control-row literature-map-actions">
          <button class="button-tertiary" type="button" data-role="zoom-out">Zoom out</button>
          <button class="button-tertiary" type="button" data-role="zoom-in">Zoom in</button>
          <button class="button-tertiary" type="button" data-role="reset-view">Reset view</button>
        </div>
      </div>

      <div class="graph-status literature-status" data-role="hover-card" aria-live="polite">
        Choose a topic to open its local literature map.
      </div>

      <div class="graph-canvas-shell literature-canvas-shell">
        <svg class="graph-canvas literature-canvas" data-role="graph-canvas" viewBox="0 0 1360 980" aria-label="Literature graph"></svg>
        <div class="graph-tooltip" data-role="graph-tooltip" hidden></div>
      </div>
    </section>
  </div>
</section>

<script is:inline define:vars={{ rootId, contextLabel }} type="module">
  const root = document.getElementById(rootId);
  if (!(root instanceof HTMLElement)) throw new Error("Literature graph root missing");

  const GRAPH_WIDTH = 1360;
  const GRAPH_HEIGHT = 980;
  const MIN_SCALE = 0.55;
  const MAX_SCALE = 4;
  const DEFAULT_GLOBAL_SCALE = 0.9;
  const DEFAULT_TOPIC_LABEL = "trade openness";
  const FIRST_RING_LIMIT = 14;
  const SECOND_RING_LIMIT = 28;
  const THIRD_RING_LIMIT = 12;
  const TOP_PATH_LIMIT = 6;
  const DEFAULT_HOP_DEPTH = 2;
  const PANEL_PREVIEW_LIMIT = 3;
  const NODE_SINGLE_CLICK_DELAY_MS = 180;
  const NODE_DOUBLE_CLICK_WINDOW_MS = 220;
  const PIVOT_DURATION_MS = 420;

  const graphPath = root.dataset.graphPath;
  const conceptIndexPath = root.dataset.conceptIndexPath;
  const literatureSearchIndexPath = root.dataset.literatureSearchIndexPath;
  const neighborhoodsIndexPath = root.dataset.neighborhoodsIndexPath;
  const opportunitiesIndexPath = root.dataset.opportunitiesIndexPath;
  const centralConceptsPath = root.dataset.centralConceptsPath;

  const STARTING_TOPIC_LABELS = [
    "trade openness",
    "public debt",
    "inflation",
    "education",
    "financial development",
    "urbanization",
    "economic growth",
    "monetary policy",
  ];

  const searchPanel = root.querySelector(".literature-search-panel");
  const inspectorPanel = root.querySelector(".literature-panel");
  const mapToolbar = root.querySelector(".literature-map-toolbar");
  const pageNote = root.querySelector(".literature-page-note");
  const searchInput = root.querySelector('[data-role="search-input"]');
  const searchResults = root.querySelector('[data-role="search-results"]');
  const centralList = root.querySelector('[data-role="central-list"]');
  const queryChipRow = root.querySelector('[data-role="query-chip-row"]');
  const scopeChipRow = root.querySelector('[data-role="scope-chip-row"]');
  const hoverCard = root.querySelector('[data-role="hover-card"]');
  const canvas = root.querySelector('[data-role="graph-canvas"]');
  const graphTooltip = root.querySelector('[data-role="graph-tooltip"]');
  const selectedConcept = root.querySelector('[data-role="selected-concept"]');
  const selectedNeighborhood = root.querySelector('[data-role="selected-neighborhood"]');
  const selectedQuestion = root.querySelector('[data-role="selected-question"]');
  const selectedOpportunities = root.querySelector('[data-role="selected-opportunities"]');
  const selectedPapers = root.querySelector('[data-role="selected-papers"]');
  const panelTabButtons = Array.from(root.querySelectorAll('[data-role="panel-tab"]'));
  const panelSections = Array.from(root.querySelectorAll('[data-role="panel-section"]'));
  const detailSheet = root.querySelector('[data-role="detail-sheet"]');
  const detailSheetTitle = root.querySelector('[data-role="detail-sheet-title"]');
  const detailSheetBody = root.querySelector('[data-role="detail-sheet-body"]');
  const detailSheetClose = root.querySelector('[data-role="detail-sheet-close"]');
  const depthOneButton = root.querySelector('[data-role="depth-1"]');
  const depthTwoButton = root.querySelector('[data-role="depth-2"]');
  const navBackButton = root.querySelector('[data-role="nav-back"]');
  const navForwardButton = root.querySelector('[data-role="nav-forward"]');
  const toggleMapMode = root.querySelector('[data-role="toggle-map-mode"]');
  const layersList = root.querySelector('[data-role="layers-list"]');
  const resetView = root.querySelector('[data-role="reset-view"]');
  const zoomOutButton = root.querySelector('[data-role="zoom-out"]');
  const zoomInButton = root.querySelector('[data-role="zoom-in"]');

  const shardCache = new Map();
  let rootConceptId = null;
  let selectedId = null;
  let graph = null;
  let concepts = [];
  let literatureSearchIndex = [];
  let searchEntityByConceptId = new Map();
  let conceptMap = new Map();
  let neighborhoodIndex = {};
  let opportunitiesIndex = {};
  let centralConcepts = [];
  let adjacency = new Map();
  let rootNeighborhood = null;
  let currentNeighborhood = null;
  let currentOpportunities = [];
  let activeQuestionPairKey = null;
  let anchorConceptId = null;
  let queryState = { id: "", label: "", badge: "", entityType: "concept", stability: "", conceptId: "" };
  let scopeState = [];
  let selectedEdgeId = null;
  let mapMode = "local";
  let hopDepth = DEFAULT_HOP_DEPTH;
  let panelTab = "overview";
  let interaction = null;
  let viewState = { scale: 1, translateX: 0, translateY: 0 };
  let detailSheetState = { open: false, kind: null };
  let pivotState = null;
  let pendingNodeClick = null;
  let navHistory = [];
  let navHistoryIndex = -1;
  let restoringHistory = false;
  let layerState = {
    stableAnchors: true,
    bridgeTopics: true,
    fringeTopics: true,
    paths: false,
    papers: false,
    questions: false,
    direction: false,
    context: false,
    geography: false,
    methods: false,
    datasets: false,
  };

  const LAYER_DEFS = [
    { key: "stableAnchors", label: "Stable Anchors", type: "graph", description: "Canonical topic nodes and core local links." },
    { key: "bridgeTopics", label: "Bridge Topics", type: "graph", description: "Second-ring connectors that widen the local map." },
    { key: "fringeTopics", label: "Fringe Topics", type: "graph", description: "Small third-ring discovery nodes on the outer edge of the map." },
    { key: "paths", label: "Paths", type: "overlay", description: "Highlight bridge routes through intermediate topics." },
    { key: "papers", label: "Papers", type: "overlay", description: "Bring supporting paper evidence into focus." },
    { key: "questions", label: "Questions", type: "overlay", description: "Surface nearby question-shaped links and the other side." },
    { key: "direction", label: "Direction", type: "overlay", description: "Show arrowheads and directional summaries on edges." },
    { key: "context", label: "Context", type: "overlay", description: "Expose countries, units, and years on hover and inspect." },
    { key: "geography", label: "Geography", type: "scope", description: "Use country or place queries as a scope overlay." },
    { key: "methods", label: "Methods", type: "scope", description: "Filter or highlight method-shaped entities." },
    { key: "datasets", label: "Datasets", type: "scope", description: "Experimental dataset scope built from existing labels.", note: "Experimental" },
  ];

  const escapeHtml = (value) =>
    String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");

  const escapeAttr = (value) => escapeHtml(value ?? "");
  const formatNumber = (value) => new Intl.NumberFormat("en-US").format(value);
  const safeNumber = (value) => {
    const numeric = Number(value);
    return Number.isFinite(numeric) ? numeric : 0;
  };
  const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
  const normalizeText = (value) =>
    String(value ?? "")
      .toLowerCase()
      .normalize("NFKD")
      .replace(/[^\p{L}\p{N}]+/gu, " ")
      .trim()
      .replace(/\s+/g, " ");
  const singularizeToken = (token) => {
    if (token.endsWith("ies") && token.length > 4) return `${token.slice(0, -3)}y`;
    if (token.endsWith("es") && token.length > 4 && /(ses|xes|zes|ches|shes)$/.test(token)) return token.slice(0, -2);
    if (token.endsWith("s") && token.length > 3 && !token.endsWith("ss")) return token.slice(0, -1);
    return token;
  };
  const tokenize = (value) => Array.from(new Set(normalizeText(value).split(" ").filter(Boolean).map(singularizeToken)));
  const normalizeForSearch = (value) => tokenize(value).join(" ");
  const estimateChipWidth = (label) => clamp(78 + String(label || "").length * 6.4, 86, 248);
  const isInBackbone = (conceptId) => Boolean(graph?.nodeMap?.has(conceptId));
  const rootIsInBackbone = () => Boolean(rootConceptId && isInBackbone(rootConceptId));
  const conceptTitle = (concept) => concept?.plain_label || concept?.label || "";
  const conceptSubtitle = (concept) => {
    const value = String(concept?.subtitle ?? "").trim();
    return value && !["na", "n/a", "nan", "null", "undefined", "none"].includes(value.toLowerCase()) ? value : "";
  };
  const questionSideLabel = (item, side) => {
    if (!item) return "";
    if (side === "source") {
      return item?.source_display_label || item?.source_label || conceptLabel(item?.source_id, "");
    }
    return item?.target_display_label || item?.target_label || conceptLabel(item?.target_id, "");
  };
  const conceptLabel = (conceptId, fallback = "") => {
    const concept = conceptMap.get(conceptId);
    return concept ? conceptTitle(concept) : fallback;
  };
  const extractWorkToken = (value) => {
    const match = String(value || "").match(/W\d+/);
    return match ? match[0] : "";
  };
  const paperOpenAlexUrl = (paper) => {
    const direct = String(paper?.openalex_url || "").trim();
    if (direct.startsWith("https://openalex.org/W")) return direct;
    const token = extractWorkToken(paper?.paper_id || direct);
    return token ? `https://openalex.org/${token}` : "";
  };
  const paperPreferredUrl = (paper) => {
    const direct = String(paper?.url || "").trim();
    return direct || paperOpenAlexUrl(paper);
  };
  const formatCitationCount = (value) => {
    const count = safeNumber(value);
    if (!count) return "";
    return `${formatNumber(count)} citation${count === 1 ? "" : "s"}`;
  };
  const paperCitationLabel = (paper) => {
    const label = String(paper?.citation_label || "").trim();
    if (label) return label;
    return paper?.year ? String(paper.year) : "Year unknown";
  };
  const renderPaperRow = (paper) => {
    const title = String(paper?.title || "").trim();
    if (!title) return "";
    const citationLabel = paperCitationLabel(paper);
    const journal = String(paper?.journal || "").trim();
    const citationCount = formatCitationCount(paper?.citation_count);
    const primaryUrl = paperPreferredUrl(paper);
    const openalexUrl = paperOpenAlexUrl(paper);
    const showOpenAlex = openalexUrl && openalexUrl !== primaryUrl;
    const metaBits = [journal, citationCount].filter(Boolean);
    return `
      <article class="literature-paper-row" title="${escapeAttr(title)}">
        <div class="literature-paper-copy">
          <span class="tiny-label">${escapeHtml(citationLabel)}</span>
          <strong class="literature-paper-title">${escapeHtml(title)}</strong>
          ${
            metaBits.length
              ? `<div class="graph-question-meta graph-question-meta-tight literature-paper-meta">${metaBits
                  .map((item) => `<span>${escapeHtml(item)}</span>`)
                  .join("")}</div>`
              : ""
          }
        </div>
        <div class="literature-paper-links">
          ${primaryUrl ? `<a class="literature-paper-link" href="${escapeAttr(primaryUrl)}" target="_blank" rel="noopener noreferrer">URL</a>` : ""}
          ${showOpenAlex ? `<a class="literature-paper-link" href="${escapeAttr(openalexUrl)}" target="_blank" rel="noopener noreferrer">OpenAlex</a>` : ""}
        </div>
      </article>
    `;
  };
  const buildSyntheticNode = (conceptId) => {
    const concept = conceptMap.get(conceptId);
    if (!concept) return null;
    return {
      id: conceptId,
      label: conceptTitle(concept),
      plain_label: conceptTitle(concept),
      subtitle: conceptSubtitle(concept),
      weighted_degree: safeNumber(concept.weighted_degree),
      distinct_paper_support: safeNumber(concept.distinct_paper_support),
      x: 0.5,
      y: 0.5,
      show_label: true,
    };
  };
  const scoreTextMatch = (text, query, queryTokens, baseWeight) => {
    if (!text) return 0;
    let score = 0;
    if (text === query) score += 120 * baseWeight;
    else if (text.startsWith(query)) score += (90 - Math.min(text.length - query.length, 18)) * baseWeight;
    else if (text.includes(query)) score += 52 * baseWeight;
    const normalizedText = normalizeForSearch(text);
    const normalizedQuery = normalizeForSearch(query);
    if (normalizedText === normalizedQuery) score += 190 * baseWeight;
    else if (normalizedText.startsWith(normalizedQuery)) score += (96 - Math.min(normalizedText.length - normalizedQuery.length, 18)) * baseWeight;
    else if (normalizedText.includes(normalizedQuery)) score += 58 * baseWeight;
    const textTokens = tokenize(text);
    const coveredTokens = queryTokens.filter((token) => textTokens.includes(token)).length;
    if (coveredTokens > 0) {
      score += coveredTokens * 18 * baseWeight;
      if (coveredTokens === queryTokens.length) score += 26 * baseWeight;
    }
    return score;
  };
  const entityLabel = (entity) => entity?.plain_label || entity?.label || "";
  const entityAnchorCandidates = (entity) => Array.isArray(entity?.anchor_candidates) ? entity.anchor_candidates : [];
  const entityPrimaryConceptId = (entity) => entity?.concept_id || entityAnchorCandidates(entity)[0]?.concept_id || "";
  const entityDistinctPaperSupport = (entity) => safeNumber(entity?.distinct_paper_support);
  const entityNeighborCount = (entity) => safeNumber(entity?.neighbor_count);
  const scopeTypeForEntity = (entity) => entity?.scope_type || entity?.entity_type || "";
  const humanizeScopeType = (value) => {
    if (value === "geography") return "Geography";
    if (value === "method") return "Method";
    if (value === "dataset") return "Dataset";
    return "Scope";
  };
  const scopeLayerKey = (value) => {
    if (value === "geography") return "geography";
    if (value === "method") return "methods";
    if (value === "dataset") return "datasets";
    return "";
  };
  const mixItemValue = (item) => (Array.isArray(item) ? item[0] : item?.value || "");
  const mixItemCount = (item) => (Array.isArray(item) ? item[1] : item?.count || 0);
  const edgeDirectionSummary = (edge) => {
    const summary = edgePairSummary(edge);
    if (!summary) {
      const directionMix = Array.isArray(edge?.directionality_mix) ? edge.directionality_mix : [];
      if (!directionMix.length) return "No direction summary";
      return `Direction mix led by ${directionMix
        .slice(0, 2)
        .map((item) => `${humanizeValue(mixItemValue(item))} ${formatNumber(safeNumber(mixItemCount(item)))}`)
        .join(", ")}`;
    }
    if (summary.arrow_mode === "forward") return "Mostly reported in this direction";
    if (summary.arrow_mode === "reverse") return "Mostly reported in the reverse direction";
    if (summary.arrow_mode === "both") return "Bidirectional or mixed directional support";
    return "Undirected or contextual support";
  };
  const formatNetSign = (value) => {
    const numeric = Number(value);
    if (!Number.isFinite(numeric)) return "";
    return numeric > 0 ? `+${numeric.toFixed(2)}` : numeric.toFixed(2);
  };
  const humanizeValue = (value) =>
    String(value ?? "")
      .replaceAll("_", " ")
      .replaceAll("-", " ")
      .replace(/([a-z])([A-Z])/g, "$1 $2")
      .replace(/\s+/g, " ")
      .trim();
  const dominantMixValue = (items) => {
    const top = (Array.isArray(items) ? items : []).slice().sort((left, right) => safeNumber(mixItemCount(right)) - safeNumber(mixItemCount(left)))[0];
    return mixItemValue(top) ? humanizeValue(mixItemValue(top)) : "";
  };
  const compactMixSummary = (items, limit = 2) =>
    (Array.isArray(items) ? items : [])
      .slice(0, limit)
      .map((item) => `${humanizeValue(mixItemValue(item))} ${formatNumber(safeNumber(mixItemCount(item)))}`)
      .filter(Boolean)
      .join(" · ");
  const edgeDirectionBadge = (edge) => {
    const arrowMode = edgeArrowMode(edge);
    if (arrowMode === "forward") return "forward direction";
    if (arrowMode === "reverse") return "reverse direction";
    if (arrowMode === "both") return "mixed direction";
    const directionMix = Array.isArray(edge?.directionality_mix) ? edge.directionality_mix : [];
    const directed = directionMix.find((item) => normalizeText(mixItemValue(item)) === "directed");
    const undirected = directionMix.find((item) => normalizeText(mixItemValue(item)) === "undirected");
    const directedCount = safeNumber(mixItemCount(directed));
    const undirectedCount = safeNumber(mixItemCount(undirected));
    if (directedCount && undirectedCount) return "directed + contextual";
    if (directedCount) return "mostly directed";
    return "undirected/context";
  };
  const edgeRelationshipBadge = (edge) => {
    const top = dominantMixValue(edge?.relationship_type_mix);
    if (!top) return "";
    return top.includes(" ") ? top : `${top.toLowerCase()}-heavy`;
  };
  const edgeRoleBadge = (edge) => dominantMixValue(edge?.edge_role_mix);
  const signBreakdown = (bucket) => {
    const totals = { positive: 0, negative: 0, zero: 0, ambiguous: 0 };
    for (const item of Array.isArray(bucket?.sign_mix) ? bucket.sign_mix : []) {
      const label = normalizeText(mixItemValue(item));
      const count = safeNumber(mixItemCount(item));
      if (!count) continue;
      if (label.includes("positive")) totals.positive += count;
      else if (label.includes("negative")) totals.negative += count;
      else if (label.includes("zero") || label.includes("no effect") || label.includes("null") || label === "none") totals.zero += count;
      else totals.ambiguous += count;
    }
    return totals;
  };
  const signBreakdownLabel = (bucket) => {
    const totals = signBreakdown(bucket);
    const parts = [`+${totals.positive}`, `-${totals.negative}`, `${totals.zero} zero`];
    if (totals.ambiguous) parts.push(`?${totals.ambiguous}`);
    return parts.join(" / ");
  };
  const edgeTitle = (edge) => {
    if (!edge) return "";
    const sourceLabel = conceptLabel(edge.source, edge.source);
    const targetLabel = conceptLabel(edge.target, edge.target);
    const arrowMode = edgeArrowMode(edge);
    const symbol = arrowMode === "forward" ? "→" : arrowMode === "reverse" ? "←" : "↔";
    return `${sourceLabel} ${symbol} ${targetLabel}`;
  };
  const scaleSupportCount = (supportCount, maxSupportCount) => {
    const support = Math.max(0, safeNumber(supportCount));
    const maxSupport = Math.max(1, safeNumber(maxSupportCount));
    if (!support) return 0;
    return clamp(Math.log1p(support) / Math.log1p(maxSupport), 0, 1);
  };
  const dominantPairBucket = (summary) => {
    if (!summary) return null;
    return [summary.x_to_y, summary.y_to_x, summary.undirected]
      .filter(Boolean)
      .sort((left, right) => safeNumber(right.support_count) - safeNumber(left.support_count))[0] || null;
  };
  const edgeSignBadge = (edge) => {
    const dominantBucket = dominantPairBucket(edgePairSummary(edge));
    if (!dominantBucket) return "";
    if (dominantBucket.net_sign === null || dominantBucket.net_sign === undefined) return "";
    return `Net sign ${formatNetSign(dominantBucket.net_sign)}`;
  };
  const nodeContext = (nodeId) => {
    const concept = conceptMap.get(nodeId);
    const graphNode = graph?.nodeMap?.get(nodeId);
    return {
      concept,
      graphNode,
      entity: searchEntityByConceptId.get(nodeId) || null,
      topCountries: concept?.top_countries || graphNode?.top_countries || [],
      topUnits: concept?.top_units || graphNode?.top_units || [],
