      return `${formatNumber(pathCount)} nearby paths and ${formatNumber(mediatorCount)} intermediate topics already connect these two sides.`;
    }
    if (pathCount > 0) return `${formatNumber(pathCount)} nearby paths already connect these two sides.`;
    if (mediatorCount > 0) return `${formatNumber(mediatorCount)} intermediate topics already connect these two sides.`;
    return `Nearby paths and papers already bring these two sides close together.`;
