---
import type { Opportunity } from "../lib/site-data";

interface Props {
  items: Opportunity[];
  title?: string;
  caption?: string;
  sectionId?: string;
  variant?: "home" | "module";
  sampleSize?: number;
  groupLabel?: string;
  initialDelayMs?: number;
}

const {
  items,
  title,
  caption,
  sectionId = "editorial-carousel",
  variant = "module",
  sampleSize = 0,
  groupLabel = "",
  initialDelayMs = 0,
} = Astro.props;

const rootId = `editorial-carousel-${Math.random().toString(36).slice(2, 10)}`;
const questionHrefBase = Astro.url.pathname.startsWith("/broad/")
  ? "/broad/questions/"
  : Astro.url.pathname.startsWith("/fine-preview/")
    ? "/fine-preview/questions/"
    : "/questions/";

const joinPreview = (values: string[]) => values.filter(Boolean).join(", ");
const nearbyTopicsPreview = (item: Opportunity) => joinPreview((item.top_mediator_labels || []).slice(0, 4));
const starterPaperPreview = (item: Opportunity) =>
  (item.representative_papers || [])
    .slice(0, 2)
    .map((paper) => (paper.year > 0 ? `${paper.title} (${paper.year})` : paper.title))
    .join(" | ");
const areaPreview = (item: Opportunity) =>
  item.cross_field
    ? "The two endpoint topics sit in different field shelves."
    : "The two endpoint topics sit in the same nearby field shelf.";
---

<section
  id={rootId}
  class:list={[
    variant === "home" ? "hero-panel editorial-carousel editorial-carousel-home" : "editorial-carousel editorial-carousel-module card",
  ]}
  data-role={sectionId}
  data-sample-size={String(sampleSize)}
  data-initial-delay={String(initialDelayMs)}
>
  <div class="editorial-carousel-head">
    <div class="editorial-carousel-title-block">
      {groupLabel && <span class="tiny-label">{groupLabel}</span>}
      {title && <h2>{title}</h2>}
      {caption && <p class="section-copy">{caption}</p>}
    </div>
    <div class="editorial-carousel-controls" aria-label={`${title || "Question"} controls`}>
      <button class="button-tertiary editorial-carousel-button" type="button" data-role="carousel-prev" aria-label="Previous question">
        <span aria-hidden="true">‹</span>
      </button>
      <button class="button-tertiary editorial-carousel-button" type="button" data-role="carousel-next" aria-label="Next question">
        <span aria-hidden="true">›</span>
      </button>
    </div>
  </div>

  <div class="editorial-carousel-slides">
    {items.map((item, index) => (
      <article
        class="editorial-carousel-slide"
        data-role="editorial-carousel-slide"
        data-pair-key={item.pair_key}
        data-active={index === 0 ? "true" : "false"}
        aria-hidden={index === 0 ? "false" : "true"}
        hidden={index !== 0}
      >
        <div class="editorial-carousel-copy">
          <span class="editorial-carousel-tag">{item.display_category || item.slice_label || "Open question"}</span>
          <h3>{item.display_title || item.public_pair_label}</h3>
          <p class="card-copy">{item.display_why || item.why_now}</p>
          <div class="editorial-carousel-footer">
            <div class="editorial-carousel-evidence">
              <button
                class="editorial-evidence-chip"
                type="button"
                data-role="evidence-chip"
                data-preview-open="false"
                aria-expanded="false"
                aria-label={nearbyTopicsPreview(item) || `${item.supporting_path_count} nearby topics`}
              >
                <span>{item.supporting_path_count} nearby topics</span>
                {nearbyTopicsPreview(item) && <span class="editorial-evidence-preview">{nearbyTopicsPreview(item)}</span>}
              </button>
              <button
                class="editorial-evidence-chip"
                type="button"
                data-role="evidence-chip"
                data-preview-open="false"
                aria-expanded="false"
                aria-label={starterPaperPreview(item) || `${item.representative_papers.length} starter papers`}
              >
                <span>{item.representative_papers.length} starter papers</span>
                {starterPaperPreview(item) && <span class="editorial-evidence-preview editorial-evidence-preview-wide">{starterPaperPreview(item)}</span>}
              </button>
              <button
                class="editorial-evidence-chip"
                type="button"
                data-role="evidence-chip"
                data-preview-open="false"
                aria-expanded="false"
                aria-label={areaPreview(item)}
              >
                <span>{item.cross_field ? "Across fields" : "Same nearby field"}</span>
                <span class="editorial-evidence-preview">{areaPreview(item)}</span>
              </button>
            </div>
            {item.display_first_step && (
              <p class="mini-copy">
                <strong>First step:</strong> {item.display_first_step}
              </p>
            )}
            <div class="button-row editorial-carousel-actions">
              <a class="text-link" href={`${questionHrefBase}#${item.pair_key}`}>See question</a>
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>

  <div class="editorial-carousel-dots" data-role="carousel-dots" role="tablist" aria-label={`${title || "Question"} dots`}></div>
</section>

<script is:inline define:vars={{ rootId }} type="module">
  const root = document.getElementById(rootId);
  if (!(root instanceof HTMLElement)) throw new Error("Editorial carousel root missing");

  const allSlides = Array.from(root.querySelectorAll('[data-role="editorial-carousel-slide"]'));
  const slidesRoot = root.querySelector('.editorial-carousel-slides');
  const dotsRoot = root.querySelector('[data-role="carousel-dots"]');
  const prev = root.querySelector('[data-role="carousel-prev"]');
  const next = root.querySelector('[data-role="carousel-next"]');
  const evidenceChips = Array.from(root.querySelectorAll('[data-role="evidence-chip"]'));
  const sampleSize = Number(root.dataset.sampleSize || "0");
  const initialDelay = Number(root.dataset.initialDelay || "0");
  const seen = (window.__fgEditorialCarouselSeen ||= new Set());

  const shuffle = (values) => {
    const clone = [...values];
    for (let index = clone.length - 1; index > 0; index -= 1) {
      const swapIndex = Math.floor(Math.random() * (index + 1));
      [clone[index], clone[swapIndex]] = [clone[swapIndex], clone[index]];
    }
    return clone;
  };

  const allIndices = allSlides.map((_slide, index) => index);
  const sampledIndices =
    sampleSize > 0 && sampleSize < allIndices.length
      ? shuffle(allIndices).slice(0, sampleSize)
      : allIndices;

  let sampledPosition = 0;
  let paused = false;
  let intervalId = null;

  const chooseInitialPosition = () => {
    const ordered = shuffle(sampledIndices);
    const available = ordered.find((index) => {
      const pairKey = allSlides[index]?.dataset.pairKey || "";
      return pairKey && !seen.has(pairKey);
    });
    const selectedIndex = available ?? ordered[0] ?? sampledIndices[0] ?? 0;
    const selectedPair = allSlides[selectedIndex]?.dataset.pairKey || "";
    if (selectedPair) seen.add(selectedPair);
    sampledPosition = Math.max(0, sampledIndices.indexOf(selectedIndex));
  };

  const renderDots = () => {
    if (!(dotsRoot instanceof HTMLElement)) return;
    dotsRoot.innerHTML = sampledIndices
      .map(
        (_index, position) => `
          <button
            class="editorial-carousel-dot${position === sampledPosition ? " is-active" : ""}"
            type="button"
            role="tab"
            aria-selected="${String(position === sampledPosition)}"
            data-role="carousel-dot"
            data-position="${String(position)}"
          ></button>
        `,
      )
      .join("");
    for (const dot of dotsRoot.querySelectorAll('[data-role="carousel-dot"]')) {
      dot.addEventListener("click", () => {
        sampledPosition = Number(dot.dataset.position || "0");
        render();
      });
    }
  };

  const syncTrackHeight = () => {
    if (!(slidesRoot instanceof HTMLElement)) return;
    let maxHeight = 0;
    for (const slide of allSlides) {
      const previousHidden = slide.hidden;
      const previousPosition = slide.style.position;
      const previousVisibility = slide.style.visibility;
      const previousPointerEvents = slide.style.pointerEvents;

      slide.hidden = false;
      slide.style.position = "absolute";
      slide.style.visibility = "hidden";
      slide.style.pointerEvents = "none";

      maxHeight = Math.max(maxHeight, slide.offsetHeight);

      slide.hidden = previousHidden;
      slide.style.position = previousPosition;
      slide.style.visibility = previousVisibility;
      slide.style.pointerEvents = previousPointerEvents;
    }

    if (maxHeight > 0) {
      slidesRoot.style.minHeight = `${maxHeight}px`;
    }
  };

  const closeAllEvidencePreviews = () => {
    for (const chip of evidenceChips) {
      chip.setAttribute("data-preview-open", "false");
      chip.setAttribute("aria-expanded", "false");
    }
  };

  const toggleEvidencePreview = (chip) => {
    const shouldOpen = chip.getAttribute("data-preview-open") !== "true";
    closeAllEvidencePreviews();
    if (shouldOpen) {
      chip.setAttribute("data-preview-open", "true");
      chip.setAttribute("aria-expanded", "true");
      if (typeof chip.focus === "function") chip.focus();
    }
  };

  const render = () => {
    const activeSlideIndex = sampledIndices[sampledPosition] ?? sampledIndices[0] ?? 0;
    closeAllEvidencePreviews();
    allSlides.forEach((slide, index) => {
      const isActive = index === activeSlideIndex;
      const isVisible = sampledIndices.includes(index) && isActive;
      slide.setAttribute("data-active", String(isActive));
      slide.setAttribute("aria-hidden", String(!isVisible));
      slide.toggleAttribute("hidden", !isVisible);
    });
    renderDots();
  };

  const advance = (direction) => {
    if (sampledIndices.length <= 1) return;
    sampledPosition = (sampledPosition + direction + sampledIndices.length) % sampledIndices.length;
    render();
  };

  const startAutoplay = () => {
    if (intervalId || sampledIndices.length <= 1) return;
    intervalId = window.setInterval(() => {
      if (!paused) advance(1);
    }, 7000);
  };

  const stopAutoplay = () => {
    if (intervalId) window.clearInterval(intervalId);
    intervalId = null;
  };

  chooseInitialPosition();
  syncTrackHeight();
  render();

  prev?.addEventListener("click", () => advance(-1));
  next?.addEventListener("click", () => advance(1));

  for (const chip of evidenceChips) {
    chip.addEventListener("click", (event) => {
      event.stopPropagation();
      toggleEvidencePreview(chip);
    });
    chip.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeAllEvidencePreviews();
        chip.blur();
      }
    });
  }

  document.addEventListener("click", (event) => {
    if (!(event.target instanceof Node) || !root.contains(event.target)) {
      closeAllEvidencePreviews();
      return;
    }
    if (!(event.target instanceof Element) || !event.target.closest('[data-role="evidence-chip"]')) {
      closeAllEvidencePreviews();
    }
  });

  root.addEventListener("mouseenter", () => {
    paused = true;
  });
  root.addEventListener("mouseleave", () => {
    paused = false;
  });
  root.addEventListener("focusin", () => {
    paused = true;
  });
  root.addEventListener("focusout", () => {
    paused = false;
  });
  root.addEventListener("focusout", () => {
    window.setTimeout(() => {
      const activeElement = document.activeElement;
      if (!(activeElement instanceof Node) || !root.contains(activeElement)) {
        closeAllEvidencePreviews();
      }
    }, 0);
  });

  if (initialDelay > 0) {
    window.setTimeout(startAutoplay, initialDelay);
  } else {
    startAutoplay();
  }

  window.addEventListener("beforeunload", stopAutoplay, { once: true });
  window.addEventListener("resize", syncTrackHeight);
</script>
