---
interface Props {
  navPrefix?: string;
  brandHref?: string;
  variantLabel?: string;
  links?: { href: string; label: string; emphasis?: boolean }[];
  currentPath?: string;
}

const {
  navPrefix = "",
  brandHref = navPrefix ? `${navPrefix}/` : "/",
  variantLabel = "",
  links = [
    { href: `${navPrefix}/`, label: "Home" },
    { href: `${navPrefix}/questions/`, label: "Questions" },
    { href: `${navPrefix}/graph/`, label: "Explorer" },
    { href: `${navPrefix}/paper/`, label: "Paper" },
    { href: `${navPrefix}/about/`, label: "About" },
    { href: `${navPrefix}/downloads/`, label: "Downloads" },
    { href: `${navPrefix}/literature/`, label: "Literature Graph", emphasis: true },
  ],
  currentPath = "/",
} = Astro.props;

const normalizePath = (value: string) => {
  if (!value) return "/";
  const trimmed = value.endsWith("/") ? value : `${value}/`;
  return trimmed === "//" ? "/" : trimmed;
};

const normalizedCurrentPath = normalizePath(currentPath);
const isActiveLink = (href: string) => {
  const normalizedHref = normalizePath(href);
  if (normalizedHref === "/") return normalizedCurrentPath === "/";
  return normalizedCurrentPath === normalizedHref || normalizedCurrentPath.startsWith(normalizedHref);
};
---

<header class="site-header">
  <a href={brandHref} class="brand-lockup">
    <span class="brand-mark" aria-hidden="true"></span>
    <span class="brand-copy">
      <span class="brand-name-row">
        <span class="brand-name">Frontier Graph</span>
      </span>
      <span class="brand-beta">Beta</span>
      {variantLabel && <span class="site-variant-pill">{variantLabel}</span>}
    </span>
  </a>
  <div class="site-nav-shell">
    <nav class="site-nav">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "site-nav-link",
            link.emphasis && "is-emphasized",
          ]}
          aria-current={isActiveLink(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>
