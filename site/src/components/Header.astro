---
import { data } from "../lib/site-data";

interface Props {
  navPrefix?: string;
  appUrl?: string;
  appLabel?: string;
  brandHref?: string;
  variantLabel?: string;
  links?: { href: string; label: string }[];
}

const {
  navPrefix = "",
  appUrl = data.app_url,
  appLabel = "Open app",
  brandHref = navPrefix ? `${navPrefix}/` : "/",
  variantLabel = "",
  links = [
    { href: `${navPrefix}/`, label: "Home" },
    { href: `${navPrefix}/questions/`, label: "Questions" },
    { href: `${navPrefix}/graph/`, label: "Graph" },
    { href: `${navPrefix}/paper/`, label: "Paper" },
    { href: `${navPrefix}/downloads/`, label: "Downloads" },
  ],
} = Astro.props;
---

<header class="site-header">
  <a href={brandHref} class="brand-lockup">
    <span class="brand-mark" aria-hidden="true"></span>
    <span>
      <span class="brand-name">FrontierGraph</span>
      {variantLabel && <span class="site-variant-pill">{variantLabel}</span>}
    </span>
  </a>
  <div class="site-nav-shell">
    <nav class="site-nav">
      {links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>
    <div class="site-nav-actions">
      <a href={appUrl} class="header-cta">{appLabel}</a>
    </div>
  </div>
</header>
