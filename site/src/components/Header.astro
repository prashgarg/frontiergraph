---
const links = [
  { href: "/discover/", label: "Discover" },
  { href: "/fields/", label: "Fields" },
  { href: "/method/", label: "Method" },
  { href: "/downloads/", label: "Downloads" },
];

const appUrl = "https://economics-opportunity-ranker-beta-1058669339361.us-central1.run.app";
---

<header class="site-header">
  <a href="/" class="brand-lockup">
    <span class="brand-mark" aria-hidden="true"></span>
    <span>
      <span class="brand-kicker">Public beta</span>
      <span class="brand-name">FrontierGraph</span>
    </span>
  </a>
  <nav class="site-nav">
    {links.map((link) => (
      <a href={link.href}>{link.label}</a>
    ))}
    <a href={appUrl} class="header-cta">Open app</a>
  </nav>
</header>
