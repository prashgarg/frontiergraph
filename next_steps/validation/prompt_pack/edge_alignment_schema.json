        "additionalProperties": false,
        "properties": {
          "gold_edge": {
            "type": "string"
          },
          "best_predicted_edge": {
            "type": "string"
          },
          "edge_overlap_class": {
            "type": "string",
            "enum": [
              "exact_edge_match",
              "same_direction_broader_nodes",
              "same_direction_partial_nodes",
              "same_relation_different_graph_resolution",
              "reversed_direction",
              "context_or_method_edge",
              "no_match",
              "not_recoverable_from_abstract"
            ]
          },
          "gold_edge_recoverable_from_abstract": {
            "type": "string",
            "enum": [
              "yes",
              "partly",
              "no"
            ]
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
