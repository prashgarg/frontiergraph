          },
          "best_gold_edge": {
            "type": "string"
          },
          "edge_overlap_class": {
            "type": "string",
            "enum": [
              "exact_edge_match",
              "same_direction_broader_nodes",
              "same_direction_partial_nodes",
              "same_relation_different_graph_resolution",
              "reversed_direction",
              "context_or_method_edge",
              "no_match",
              "not_recoverable_from_abstract"
            ]
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "predicted_edge",
          "best_gold_edge",
          "edge_overlap_class",
          "notes"
        ]
